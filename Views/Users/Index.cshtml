@model List<NUTRIBITE.Models.UserSignup>

@{
    ViewData["Title"] = "User Directory";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var currentStatus = ViewBag.Status ?? "All";
    var currentSearch = ViewBag.Search ?? "";
    var totalCount = ViewBag.TotalCount ?? 0;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">User Directory</h2>
            <p class="text-muted small mb-0">Manage and monitor all registered customers on the platform.</p>
        </div>
        <div class="d-flex gap-2">
            <form method="get" asp-action="Index" class="d-flex gap-2">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input name="search" class="form-control border-start-0 ps-0" style="min-width: 200px;" 
                           placeholder="Name, email or phone..." value="@currentSearch" />
                </div>
                <select name="status" class="form-select form-select-sm" style="width: auto;" onchange="this.form.submit()">
                    <option value="All" selected="@(currentStatus == "All")">All Status</option>
                    <option value="Active" selected="@(currentStatus == "Active")">Active</option>
                    <option value="Blocked" selected="@(currentStatus == "Blocked")">Blocked</option>
                </select>
                <button type="submit" class="btn btn-sm btn-primary">Filter</button>
                @if (!string.IsNullOrEmpty(currentSearch) || currentStatus != "All")
                {
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
                }
            </form>
        </div>
    </div>

    <!-- Stats row -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3">
                    <div class="text-muted small text-uppercase fw-bold mb-1">Total Users</div>
                    <div class="h4 mb-0 fw-bold text-primary">@ViewBag.TotalUsers</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3">
                    <div class="text-muted small text-uppercase fw-bold mb-1">Active</div>
                    <div class="h4 mb-0 fw-bold text-success">@ViewBag.ActiveUsers</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3">
                    <div class="text-muted small text-uppercase fw-bold mb-1">Blocked</div>
                    <div class="h4 mb-0 fw-bold text-danger">@ViewBag.BlockedUsers</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3">
                    <div class="text-muted small text-uppercase fw-bold mb-1">New (7 Days)</div>
                    <div class="h4 mb-0 fw-bold text-info">@ViewBag.NewUsersThisWeek</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3 border-bottom-0 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold">User List <span class="badge bg-light text-dark ms-2 fw-normal">Showing @Model.Count of @totalCount</span></h6>
            <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-download me-1"></i> Export
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                    <li><a class="dropdown-item" href="#"><i class="bi bi-file-earmark-spreadsheet me-2"></i> CSV</a></li>
                    <li><a class="dropdown-item" href="#"><i class="bi bi-file-earmark-pdf me-2"></i> PDF</a></li>
                </ul>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>User Details</th>
                            <th>Contact</th>
                            <th>Status</th>
                            <th>Registered</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var u in Model)
                            {
                                <tr>
                                    <td class="ps-4 text-muted small">#@u.Id</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            @if (!string.IsNullOrEmpty(u.ProfilePictureUrl))
                                            {
                                                <img src="@u.ProfilePictureUrl" class="rounded-circle me-3" 
                                                     style="width: 36px; height: 36px; object-fit: cover;" 
                                                     onerror="this.src='/images/default-avatar.png';" />
                                            }
                                            else
                                            {
                                                <div class="user-avatar-placeholder me-3">
                                                    @u.Name.Substring(0, 1).ToUpper()
                                                </div>
                                            }
                                            <div>
                                                <div class="fw-semibold">@u.Name</div>
                                                <div class="text-muted extra-small">ID: @u.Id</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="small">
                                            <div class="text-dark"><i class="bi bi-envelope me-1 text-muted"></i>@u.Email</div>
                                            <div class="text-muted"><i class="bi bi-phone me-1"></i>@(string.IsNullOrEmpty(u.Phone) ? "Not provided" : u.Phone)</div>
                                        </div>
                                    </td>
                                    <td>
                                        @if ((u.Status ?? "Active") == "Blocked")
                                        {
                                            <span class="badge bg-soft-danger text-danger border border-danger border-opacity-25 rounded-pill px-3">Blocked</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-soft-success text-success border border-success border-opacity-25 rounded-pill px-3">Active</span>
                                        }
                                    </td>
                                    <td class="small text-muted">
                                        @(u.CreatedAt.HasValue ? u.CreatedAt.Value.ToString("dd MMM yyyy") : "-")
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-light rounded-circle p-1" type="button" data-bs-toggle="dropdown">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 small">
                                                <li><a asp-action="Profile" asp-route-userId="@u.Id" class="dropdown-item"><i class="bi bi-person-badge me-2"></i> Full Profile</a></li>
                                                <li><a asp-action="Edit" asp-route-id="@u.Id" class="dropdown-item"><i class="bi bi-pencil me-2"></i> Edit Details</a></li>
                                                <li><hr class="dropdown-divider"></li>
                                                @if ((u.Status ?? "Active") == "Blocked")
                                                {
                                                    <li><a asp-action="UnblockUser" asp-route-id="@u.Id" class="dropdown-item text-success"><i class="bi bi-unlock me-2"></i> Unblock User</a></li>
                                                }
                                                else
                                                {
                                                    <li><a asp-action="BlockUser" asp-route-id="@u.Id" class="dropdown-item text-warning"><i class="bi bi-lock me-2"></i> Block User</a></li>
                                                }
                                                <li><a asp-action="Delete" asp-route-id="@u.Id" class="dropdown-item text-danger" 
                                                       onclick="return confirm('Permanently delete user #@u.Id?');"><i class="bi bi-trash me-2"></i> Delete</a></li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="bi bi-people display-4 d-block mb-3"></i>
                                        <p class="mb-1 fw-bold text-dark">No users found</p>
                                        <p class="mb-0 small">Try adjusting your search or filters to find what you're looking for.</p>
                                        @if (!string.IsNullOrEmpty(currentSearch) || currentStatus != "All")
                                        {
                                            <a asp-action="Index" class="btn btn-link btn-sm mt-2">Clear all filters</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    @{
        int page = ViewBag.Page ?? 1;
        int totalPages = ViewBag.TotalPages ?? 1;
    }
    @if (totalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(page <= 1 ? "disabled" : "")">
                    <a class="page-link shadow-none" asp-action="Index" asp-route-page="@(page-1)" 
                       asp-route-search="@currentSearch" asp-route-status="@currentStatus">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                @for (int p = 1; p <= totalPages; p++)
                {
                    <li class="page-item @(p == page ? "active" : "")">
                        <a class="page-link shadow-none" asp-action="Index" asp-route-page="@p" 
                           asp-route-search="@currentSearch" asp-route-status="@currentStatus">@p</a>
                    </li>
                }
                <li class="page-item @(page >= totalPages ? "disabled" : "")">
                    <a class="page-link shadow-none" asp-action="Index" asp-route-page="@(page+1)" 
                       asp-route-search="@currentSearch" asp-route-status="@currentStatus">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

<style>
    .user-avatar-placeholder {
        width: 36px;
        height: 36px;
        background: #f3f4f6;
        color: #6b7280;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 0.9rem;
    }
    .bg-soft-success { background-color: rgba(34, 197, 94, 0.1); }
    .bg-soft-danger { background-color: rgba(239, 68, 68, 0.1); }
    .extra-small { font-size: 0.75rem; }
    .page-link { color: #4b5563; border: 1px solid #e5e7eb; margin: 0 2px; border-radius: 4px !important; }
    .page-item.active .page-link { background-color: #22c55e; border-color: #22c55e; color: white; }
    .dropdown-item { padding: 0.5rem 1rem; }
    .dropdown-item:hover { background-color: #f9fafb; }
</style>
