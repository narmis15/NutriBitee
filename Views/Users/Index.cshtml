@model List<NUTRIBITE.Models.UserSignup>

@{
    ViewData["Title"] = "All Users";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var selStatus = ViewBag.Status ?? "All";
}

<link rel="stylesheet" href="~/css/users.css" />

<h2 class="page-title">All Users</h2>

<div class="d-flex gap-3 align-items-center mb-3">
    <form class="d-flex" method="get" asp-action="Index">
        <input type="hidden" name="status" value="@ViewBag.Status" />
        <input name="search" class="form-control form-control-sm me-2" placeholder="Search name or email"
               value="@(ViewBag.Search ?? "")" />
        <button type="submit" class="btn btn-sm btn-approve">Search</button>
    </form>

    <div class="ms-auto d-flex gap-2">
        <form method="get" asp-action="Index" class="d-flex">
            <input type="hidden" name="search" value="@(ViewBag.Search ?? "")" />
            <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                @if (selStatus == "All")
                {
                    <option value="All" selected="selected">All Users</option>
                }
                else
                {
                    <option value="All">All Users</option>
                }

                @if (selStatus == "Active")
                {
                    <option value="Active" selected="selected">Active</option>
                }
                else
                {
                    <option value="Active">Active</option>
                }

                @if (selStatus == "Blocked")
                {
                    <option value="Blocked" selected="selected">Blocked</option>
                }
                else
                {
                    <option value="Blocked">Blocked</option>
                }
            </select>
        </form>
    </div>
</div>

<!-- Stats cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="summary-card p-3">
            <div class="title">Total Users</div>
            <div class="value">@ViewBag.TotalUsers</div>
            <div class="sub text-muted">All registered users</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="summary-card p-3">
            <div class="title">Active</div>
            <div class="value">@ViewBag.ActiveUsers</div>
            <div class="sub text-muted">Users with Active status</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="summary-card p-3">
            <div class="title">Blocked</div>
            <div class="value">@ViewBag.BlockedUsers</div>
            <div class="sub text-muted">Users blocked by admin</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="summary-card p-3">
            <div class="title">New (7 days)</div>
            <div class="value">@ViewBag.NewUsersThisWeek</div>
            <div class="sub text-muted">Registrations this week</div>
        </div>
    </div>
</div>

<div class="table-wrapper">
    <table class="admin-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Status</th>
                <th>Registered</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var u in Model)
                {
                    <tr>
                        <td>#@u.Id</td>
                        <td>@u.Name</td>
                        <td>@u.Email</td>
                        <td>@(string.IsNullOrEmpty(u.Phone) ? "-" : u.Phone)</td>
                        <td>@(string.IsNullOrEmpty(u.Status) ? "Active" : u.Status)</td>
                        <td>@(u.CreatedAt.HasValue ? u.CreatedAt.Value.ToString("dd MMM yyyy") : "-")</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@u.Id" class="btn-action">View</a>
                            <a asp-action="Edit" asp-route-id="@u.Id" class="btn-action btn-approve">Edit</a>

                            @if ((u.Status ?? "Active") == "Blocked")
                            {
                                <a asp-action="UnblockUser" asp-route-id="@u.Id" class="btn-action btn-approve">Unblock</a>
                            }
                            else
                            {
                                <a asp-action="BlockUser" asp-route-id="@u.Id" class="btn-action btn-reject">Block</a>
                            }

                            <a asp-action="Delete" asp-route-id="@u.Id" class="btn-action btn-danger"
                               onclick="return confirm('Delete user #@u.Id? This action cannot be undone.');">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="no-records">No users found</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@{
    int page = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string currentSearch = ViewBag.Search ?? "";
    string currentStatus = ViewBag.Status ?? "All";
}
@if (totalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-3">
        <ul class="pagination">
            <li class="page-item @(page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(page-1)" asp-route-search="@currentSearch" asp-route-status="@currentStatus">Prev</a>
            </li>
            @for (int p = 1; p <= totalPages; p++)
            {
                <li class="page-item @(p == page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@p" asp-route-search="@currentSearch" asp-route-status="@currentStatus">@p</a>
                </li>
            }
            <li class="page-item @(page >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(page+1)" asp-route-search="@currentSearch" asp-route-status="@currentStatus">Next</a>
            </li>
        </ul>
    </nav>
}
