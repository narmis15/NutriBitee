@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    var uid = ViewBag.UserId ?? 0;
}

<style>
    body { background-color: #f8fafc; }
    .profile-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    }
    .profile-avatar-wrapper {
        position: relative;
        display: inline-block;
        margin-top: -60px;
    }
    .profile-avatar {
        width: 120px;
        height: 120px;
        object-fit: cover;
        border-radius: 50%;
        border: 4px solid #fff;
        background-color: #e2e8f0;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }
    .btn-cam {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 34px;
        height: 34px;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #fff;
    }
    .info-group {
        padding: 1rem 0;
        border-bottom: 1px solid #f1f5f9;
    }
    .info-group:last-child {
        border-bottom: none;
    }
</style>

<div class="container py-5" style="max-width: 600px;">
    <!-- Profile Card -->
    <div class="card profile-card pt-5 mt-5 text-center">
        <div class="profile-avatar-wrapper">
            <img id="profilePictureImg" src="/images/default-avatar.png" alt="Profile" class="profile-avatar" onerror="this.src='/images/default-avatar.png'" />
            <button class="btn btn-primary rounded-circle btn-cam shadow-sm" onclick="document.getElementById('profilePictureInput').click()">
                <i class="bi bi-camera"></i>
            </button>
            <form id="uploadProfilePictureForm" enctype="multipart/form-data" class="d-none">
                @Html.AntiForgeryToken()
                <input type="file" name="profilePicture" id="profilePictureInput" onchange="document.getElementById('uploadProfilePictureForm').dispatchEvent(new Event('submit'))" accept="image/*" />
            </form>
        </div>

        <div class="card-body px-4 pb-4">
            <h3 class="fw-bold mb-1 mt-2" id="userName">Loading...</h3>
            <span class="badge bg-success-subtle text-success rounded-pill px-3 py-1 mb-4"><i class="bi bi-check-circle-fill me-1"></i> Active Member</span>

            <!-- Details -->
            <div class="text-start mb-4">
                <div class="info-group">
                    <small class="text-muted text-uppercase fw-bold"><i class="bi bi-envelope me-1"></i> Email</small>
                    <div class="fs-5 text-dark mt-1" id="userEmail">—</div>
                </div>
                <div class="info-group">
                    <small class="text-muted text-uppercase fw-bold"><i class="bi bi-telephone me-1"></i> Phone</small>
                    <div class="fs-5 text-dark mt-1" id="userPhone">—</div>
                </div>
            </div>

            <div class="d-grid gap-3">
                <button class="btn btn-primary rounded-pill py-2 fw-bold" data-bs-toggle="modal" data-bs-target="#editProfileModal">
                    <i class="bi bi-pencil-square me-2"></i> Edit Profile
                </button>
                <div class="d-flex gap-2">
                    <a href="/Delivery/Tracking" class="btn btn-outline-secondary rounded-pill w-50"><i class="bi bi-box-seam me-2"></i>My Orders</a>
                    <a href="/HealthSurvey" class="btn btn-outline-secondary rounded-pill w-50"><i class="bi bi-heart-pulse me-2"></i>Health Survey</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Security Settings -->
    <div class="card profile-card mt-4 border">
        <div class="card-body p-4">
            <h6 class="fw-bold mb-3"><i class="bi bi-shield-lock me-2"></i>Security Settings</h6>
            <form id="changePasswordForm">
                @Html.AntiForgeryToken()
                <div id="pwdError" class="alert alert-danger small d-none"></div>
                <div id="pwdSuccess" class="alert alert-success small d-none">Password updated successfully!</div>
                <div class="mb-3">
                    <input type="password" class="form-control form-control-sm" id="currentPassword" name="currentPassword" placeholder="Current Password" required />
                </div>
                <div class="mb-3">
                    <div class="input-group has-validation">
                        <input type="password" class="form-control form-control-sm" id="newPassword" name="newPassword" placeholder="New Password" required 
                               pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{8,}$" title="Min 8 chars, 1 uppercase, 1 lowercase, 1 digit" />
                        <div class="invalid-feedback text-danger mt-1" style="font-size: 0.8rem;">
                            Password must be at least 8 characters, include an uppercase, a lowercase, and a number.
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="input-group has-validation">
                        <input type="password" class="form-control form-control-sm" id="confirmPassword" name="confirmPassword" placeholder="Confirm New Password" required 
                               pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{8,}$" />
                        <div class="invalid-feedback text-danger mt-1" style="font-size: 0.8rem;">
                            Passwords must match and meet all requirements.
                        </div>
                    </div>
                </div>
                <button type="submit" class="btn btn-outline-primary btn-sm rounded-pill px-4">Update Password</button>
            </form>
        </div>
    </div>

    <!-- Danger Zone -->
    <div class="card profile-card mt-4 border border-danger border-opacity-25" style="background-color: #fffafa;">
        <div class="card-body p-4 d-flex justify-content-between align-items-center">
            <div>
                <h6 class="text-danger fw-bold mb-1"><i class="bi bi-exclamation-triangle-fill me-2"></i>Danger Zone</h6>
                <p class="small text-muted mb-0">Permanently delete your account.</p>
            </div>
            <button class="btn btn-outline-danger btn-sm rounded-pill fw-bold" data-bs-toggle="modal" data-bs-target="#deleteAccountModal">Delete Account</button>
        </div>
    </div>
</div>

<!-- Edit Profile Modal -->
<div class="modal fade" id="editProfileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 16px;">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Edit Profile</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3">
                <form action="/Users/Edit" method="post" id="editProfileForm">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Full Name</label>
                        <input type="text" class="form-control form-control-lg rounded-3" name="Name" id="editName" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Email Address</label>
                        <input type="email" class="form-control form-control-lg rounded-3" name="Email" id="editEmail" required readonly />
                        <div class="form-text">Your email address cannot be changed.</div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold">Phone Number</label>
                        <input type="tel" class="form-control form-control-lg rounded-3" name="Phone" id="editPhone" />
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold">Save Changes</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 16px;">
            @using (Html.BeginForm("DeleteAccount", "Users", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="modal-header border-bottom-0">
                    <h5 class="modal-title text-danger fw-bold">Confirm Deletion</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body py-4">
                    <p class="mb-0 text-center fs-5">Are you sure you want to permanently delete your account? This action cannot be undone.</p>
                </div>
                <div class="modal-footer border-top-0 d-flex justify-content-center pb-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4">Yes, Delete Account</button>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script>
        $(function () {
            // Load Profile Data
            $.getJSON('/Users/GetUserProfileData').done(function (res) {
                if (!res || !res.authenticated) {
                    window.location.replace('/login?returnUrl=/Home/MyProfile');
                    return;
                }

                $('#userName').text(res.Name || '—');
                $('#userEmail').text(res.Email || '—');
                $('#userPhone').text(res.Phone || '—');
                
                if (res.ProfilePictureUrl) {
                    $('#profilePictureImg').attr('src', res.ProfilePictureUrl);
                }

                // Populate Edit Modal
                $('#editName').val(res.Name || '');
                $('#editEmail').val(res.Email || '');
                $('#editPhone').val(res.Phone !== '-' ? res.Phone : '');
            }).fail(function () {
                window.location.replace('/login?returnUrl=/Home/MyProfile');
            });

            // Handle Profile Picture Upload
            $('#uploadProfilePictureForm').on('submit', function(e) {
                e.preventDefault();
                var formData = new FormData(this);

                $.ajax({
                    url: '/Users/UploadProfilePicture',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(response) {
                        if (response.success) {
                            $('#profilePictureImg').attr('src', response.filePath);
                        } else {
                            alert(response.message);
                        }
                    },
                    error: function() {
                        alert('An error occurred while uploading. Please try again.');
                    }
                });
            });
            // Handle Change Password
            $('#changePasswordForm').on('submit', function(e) {
                e.preventDefault();
                $('#pwdError').addClass('d-none');
                $('#pwdSuccess').addClass('d-none');

                if ($('#newPassword').val() !== $('#confirmPassword').val()) {
                    $('#pwdError').text('New password and confirm password do not match.').removeClass('d-none');
                    return;
                }

                if (!this.checkValidity()) {
                    $(this).addClass('was-validated');
                    return;
                }
                
                $(this).removeClass('was-validated');

                $.post('/Users/UpdatePassword', $(this).serialize())
                    .done(function(res) {
                        if (res.success) {
                            $('#pwdSuccess').removeClass('d-none');
                            $('#changePasswordForm')[0].reset();
                        } else {
                            $('#pwdError').text(res.message).removeClass('d-none');
                        }
                    })
                    .fail(function() {
                        $('#pwdError').text('An error occurred. Please try again.').removeClass('d-none');
                    });
            });
        });
    </script>
}