@model List<NUTRIBITE.Models.UserSignup>

@{
    ViewData["Title"] = "Blocked Users";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link rel="stylesheet" href="~/css/users.css" />

<h2 class="page-title">Blocked Users</h2>

<div class="table-wrapper">
    <table class="admin-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Blocked On</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var u in Model)
                {
                    <tr>
                        <td>#@u.Id</td>
                        <td>@u.Name</td>
                        <td>@u.Email</td>
                        <td>@(string.IsNullOrEmpty(u.Phone) ? "-" : u.Phone)</td>
                        <td>@(u.CreatedAt.HasValue ? u.CreatedAt.Value.ToString("dd MMM yyyy") : "-")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="no-records">No blocked users</td>
                </tr>
            }
        </tbody>
    </table>
</div>
