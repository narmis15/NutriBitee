@{
    ViewData["Title"] = "Calorie Analytics";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
}

<div class="dashboard-wrapper">
    <div class="dashboard-header d-flex justify-content-between align-items-center">
        <div>
            <h1 class="dashboard-title">Calorie Analytics</h1>
            <p class="text-muted small mb-0">Global tracking patterns and user consumption metrics.</p>
        </div>

        <div class="d-flex gap-2 align-items-center">
            <div class="input-group input-group-sm shadow-sm">
                <span class="input-group-text bg-white border-end-0 text-muted small">From</span>
                <input id="fromDate" type="date" class="form-control border-start-0 ps-0" />
                <span class="input-group-text bg-white border-end-0 text-muted small border-start">To</span>
                <input id="toDate" type="date" class="form-control border-start-0 ps-0" />
                <button id="applyBtn" class="btn btn-primary">Apply</button>
            </div>
        </div>
    </div>

    <!-- Analytics Cards -->
    <div class="stat-grid mb-4">
        <div class="stat-card">
            <div class="stat-icon-wrapper" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">
                <i class="bi bi-graph-up-arrow"></i>
            </div>
            <div id="avgDaily" class="stat-value">0 kcal</div>
            <div class="stat-label">Avg Daily Consumption</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon-wrapper" style="background: rgba(239, 68, 68, 0.1); color: #ef4444;">
                <i class="bi bi-lightning-fill"></i>
            </div>
            <div id="peakDaily" class="stat-value">0 kcal</div>
            <div class="stat-label">Peak Consumption</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon-wrapper" style="background: rgba(59, 130, 246, 0.1); color: #3b82f6;">
                <i class="bi bi-calendar-check"></i>
            </div>
            <div id="todayTotal" class="stat-value">0 kcal</div>
            <div class="stat-label">Today's Total</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon-wrapper" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">
                <i class="bi bi-bullseye"></i>
            </div>
            <div id="goalMet" class="stat-value">0%</div>
            <div class="stat-label">Recommended Met</div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="admin-card shadow-sm h-100">
                <div class="admin-card-header">
                    <h5 class="admin-card-title">Consumption Trend</h5>
                    <div class="btn-group btn-group-sm">
                        <button type="button" class="btn btn-outline-primary active" onclick="updateView('daily')">Daily</button>
                        <button type="button" class="btn btn-outline-primary" onclick="updateView('weekly')">Weekly</button>
                    </div>
                </div>
                <div class="admin-card-body">
                    <div style="height: 350px;">
                        <canvas id="calorieTrendChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="admin-card shadow-sm h-100">
                <div class="admin-card-header">
                    <h5 class="admin-card-title">Meal Distribution</h5>
                </div>
                <div class="admin-card-body">
                    <div style="height: 350px;">
                        <canvas id="mealBreakdownChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="admin-card shadow-sm mt-4">
        <div class="admin-card-header">
            <h5 class="admin-card-title">Comparative Analysis vs Targets</h5>
        </div>
        <div class="admin-card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4">Metric</th>
                            <th>Current Average</th>
                            <th>Recommended Target</th>
                            <th>Variance</th>
                            <th class="text-end pe-4">Status</th>
                        </tr>
                    </thead>
                    <tbody id="analysisTableBody">
                        <tr><td colspan="5" class="text-center py-5 text-muted">Loading metrics...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (function () {
            const api = '/Reports/GetNutritionAnalytics';
            let calorieChart = null;
            let macroChart = null;

            function renderCharts(data) {
                // 1. Calorie Trend Chart
                const ctxCalorie = document.getElementById('calorieTrendChart').getContext('2d');
                if (calorieChart) calorieChart.destroy();
                
                calorieChart = new Chart(ctxCalorie, {
                    type: 'bar',
                    data: {
                        labels: data.map(d => d.date),
                        datasets: [{
                            label: 'Calories (kcal)',
                            data: data.map(d => d.calories),
                            backgroundColor: 'rgba(16, 185, 129, 0.6)',
                            borderColor: '#10b981',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { tooltip: { enabled: true } }
                    }
                });

                // 2. Macro Breakdown Chart (Stacked Bar)
                const ctxMacro = document.getElementById('mealBreakdownChart').getContext('2d');
                if (macroChart) macroChart.destroy();

                macroChart = new Chart(ctxMacro, {
                    type: 'doughnut',
                    data: {
                        labels: ['Protein', 'Carbs', 'Fats'],
                        datasets: [{
                            data: [
                                data.reduce((s, d) => s + d.protein, 0),
                                data.reduce((s, d) => s + d.carbs, 0),
                                data.reduce((s, d) => s + d.fats, 0)
                            ],
                            backgroundColor: ['#3b82f6', '#f59e0b', '#ef4444']
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { position: 'bottom' } }
                    }
                });
            }

            function updateAnalysisTable(data) {
                const $body = $('#analysisTableBody').empty();
                if (!data || data.length === 0) {
                    $body.html('<tr><td colspan="5" class="text-center py-4">No data available</td></tr>');
                    return;
                }

                data.forEach(d => {
                    const row = `
                        <tr>
                            <td class="ps-4">${d.date}</td>
                            <td>${d.calories} kcal</td>
                            <td>P: ${d.protein.toFixed(1)}g | C: ${d.carbs.toFixed(1)}g | F: ${d.fats.toFixed(1)}g</td>
                            <td>-</td>
                            <td class="text-end pe-4"><span class="badge bg-success-soft text-success">Logged</span></td>
                        </tr>`;
                    $body.append(row);
                });
            }

            function loadData() {
                const from = $('#fromDate').val();
                const to = $('#toDate').val();
                
                $.getJSON(api, { date_from: from, date_to: to })
                    .done(function (res) {
                        if (res && res.success) {
                            renderCharts(res.data);
                            updateAnalysisTable(res.data);
                            
                            // Update summary cards
                            const totalCalories = res.data.reduce((s, d) => s + d.calories, 0);
                            const avgCalories = res.data.length > 0 ? Math.round(totalCalories / res.data.length) : 0;
                            const peakCalories = res.data.length > 0 ? Math.max(...res.data.map(d => d.calories)) : 0;
                            
                            $('#avgDaily').text(avgCalories + ' kcal');
                            $('#peakDaily').text(peakCalories + ' kcal');
                            $('#todayTotal').text((res.data[res.data.length-1]?.calories || 0) + ' kcal');
                        }
                    });
            }

            $(function () {
                const today = new Date();
                const past = new Date();
                past.setDate(today.getDate() - 7);
                $('#fromDate').val(past.toISOString().split('T')[0]);
                $('#toDate').val(today.toISOString().split('T')[0]);
                $('#applyBtn').click(loadData);
                loadData();
            });
        })();
    </script>
}
