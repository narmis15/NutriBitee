@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";

    var userName = HttpContextAccessor.HttpContext.Session.GetString("UserName") ?? "User";
    var userEmail = HttpContextAccessor.HttpContext.Session.GetString("UserEmail") ?? "Not Available";
    var userPhone = HttpContextAccessor.HttpContext.Session.GetString("UserPhone") ?? "Not Available";

    // Temporary values (replace later with DB values)
    var age = 22;
    var weight = 60;
    var height = 165;
    var goal = "Weight Loss";
    var activity = "Moderate";
    var calorieGoal = 1800;
    var caloriesConsumed = 950;

    var progress = (caloriesConsumed * 100) / calorieGoal;
}

<style>

    .profile-container {
        max-width: 1000px;
        margin: 120px auto 80px;
        padding: 0 20px;
    }

    .profile-card {
        background: rgba(255,255,255,0.8);
        backdrop-filter: blur(18px);
        border-radius: 24px;
        padding: 50px;
        box-shadow: 0 30px 80px rgba(0,0,0,0.08);
        border: 1px solid rgba(255,255,255,0.3);
    }

    .profile-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .profile-avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg,#16a34a,#15803d);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 44px;
        font-weight: 700;
        color: white;
        box-shadow: 0 15px 40px rgba(22,163,74,0.4);
    }

    .profile-info h2 {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        color: #064e3b;
    }

    .profile-info p {
        margin: 6px 0;
        color: #6b7280;
        font-size: 14px;
    }

    .section-title {
        font-size: 20px;
        font-weight: 600;
        color: #064e3b;
        margin-bottom: 20px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 20px;
    }

    .info-box {
        background: #f8fafc;
        padding: 20px;
        border-radius: 14px;
        font-size: 14px;
    }

        .info-box strong {
            display: block;
            color: #16a34a;
            margin-bottom: 5px;
        }

    .divider {
        margin: 50px 0;
        border-top: 1px solid rgba(0,0,0,0.05);
    }

    .progress-bar-custom {
        height: 18px;
        background: #e2e8f0;
        border-radius: 20px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg,#16a34a,#22c55e);
    }

    .action-buttons {
        margin-top: 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logout-btn {
        background: #dc2626;
        color: white;
        padding: 12px 25px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

        .logout-btn:hover {
            background: #b91c1c;
        }

    .orders-btn {
        background: #16a34a;
        color: white;
        padding: 12px 25px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
    }

</style>


<div class="profile-container">

    <div class="profile-card">

        <!-- PROFILE TOP -->
        <div class="profile-top">

            <div style="display:flex; gap:30px; align-items:center;">
                <div class="profile-avatar">
                    @userName.Substring(0, 1).ToUpper()
                </div>

                <div class="profile-info">
                    <h2>@userName</h2>
                    <p>@userEmail</p>
                    <p>@userPhone</p>
                    <p>Member since: @DateTime.Now.Year</p>
                </div>
            </div>

        </div>

        <div class="divider"></div>

        <!-- HEALTH SURVEY -->
        <div>
            <div class="section-title">Health Survey Details</div>

            <div class="info-grid">
                <div class="info-box">
                    <strong>Age</strong>
                    @age years
                </div>

                <div class="info-box">
                    <strong>Weight</strong>
                    @weight kg
                </div>

                <div class="info-box">
                    <strong>Height</strong>
                    @height cm
                </div>

                <div class="info-box">
                    <strong>Fitness Goal</strong>
                    @goal
                </div>

                <div class="info-box">
                    <strong>Activity Level</strong>
                    @activity
                </div>

                <div class="info-box">
                    <strong>Daily Calorie Goal</strong>
                    @calorieGoal kcal
                </div>
            </div>
        </div>

        <div class="divider"></div>

        <!-- CALORIE TRACKING -->
        <div>
            <div class="section-title">Today's Calorie Tracking</div>

            <p><strong>Consumed:</strong> @caloriesConsumed kcal / @calorieGoal kcal</p>

            <div class="progress-bar-custom">
                <div class="progress-fill" style="width:@progress%"></div>
            </div>
        </div>

        <div class="divider"></div>

        <!-- ACTION BUTTONS -->
        <div class="action-buttons">

            <a asp-controller="Orders"
               asp-action="MyOrders"
               class="orders-btn">
                View My Orders
            </a>

            <a asp-controller="Auth"
               asp-action="Logout"
               class="logout-btn">
                Logout
            </a>

        </div>

    </div>

</div>