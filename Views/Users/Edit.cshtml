@model NUTRIBITE.Models.UserSignup

@{
    ViewData["Title"] = "Edit User";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var currentStatus = Model?.Status ?? "Active";
}

<link rel="stylesheet" href="~/css/users.css" />

<h3>Edit User</h3>

<form asp-action="Edit" method="post" class="card p-3" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />

    <div class="mb-3">
        <label class="form-label">Name</label>
        <input name="Name" class="form-control" value="@Model.Name" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <input name="Email" type="email" class="form-control" value="@Model.Email" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Phone</label>
        <input name="Phone" class="form-control" value="@Model.Phone" />
    </div>

    <div class="mb-3">
        <label class="form-label">Status</label>
        <select asp-for="Status" class="form-select">
            <option value="Active">Active</option>
            <option value="Blocked">Blocked</option>
        </select>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-approve">Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>