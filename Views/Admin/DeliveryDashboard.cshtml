@model dynamic
@{
    ViewData["Title"] = "Delivery Tracking Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #10b981;
            --primary-dark: #059669;
            --surface: #ffffff;
            --background: #f1f5f9;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --border-soft: #e2e8f0;
            --hover-shadow: 0 15px 30px -10px rgba(16, 185, 129, 0.15);
        }

        body { font-family: 'Outfit', sans-serif; background-color: var(--background); }

        .dash-header {
            background: white; border-radius: 24px; padding: 1.5rem 2.5rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); margin-bottom: 2rem;
            display: flex; justify-content: space-between; align-items: center; border: 1px solid var(--border-soft);
        }

        .metric-card {
            background: white; border-radius: 20px; padding: 1.75rem; text-align: left;
            position: relative; overflow: hidden; border: 1px solid var(--border-soft);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02); transition: all 0.3s ease;
        }

        .metric-card:hover { transform: translateY(-5px); box-shadow: var(--hover-shadow); }
        .mc-icon { font-size: 2rem; margin-bottom: 1rem; opacity: 0.9; }
        .mc-title { color: var(--text-muted); font-size: 0.8rem; font-weight: 700; text-transform: uppercase; margin-bottom: 0.25rem; letter-spacing: 0.5px; }
        .mc-value { font-size: 2.25rem; font-weight: 800; color: var(--text-main); line-height: 1.2; }

        .widget-panel { background: white; border-radius: 24px; border: 1px solid var(--border-soft); box-shadow: 0 4px 10px rgba(0,0,0,0.02); padding: 2rem; margin-bottom: 2rem; }
        .widget-title { font-weight: 800; font-size: 1.25rem; display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;}
        
        .modern-table { width: 100%; border-collapse: separate; border-spacing: 0 10px; }
        .modern-table th { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); font-weight: 800; padding: 0 1rem; }
        .modern-table td { background: var(--background); padding: 1.25rem 1rem; vertical-align: middle; border-top: 1px solid var(--border-soft); border-bottom: 1px solid var(--border-soft); }
        .modern-table td:first-child { border-left: 1px solid var(--border-soft); border-radius: 16px 0 0 16px; font-weight: 700;}
        .modern-table td:last-child { border-right: 1px solid var(--border-soft); border-radius: 0 16px 16px 0; }
        .modern-table tbody tr { transition: transform 0.2s; }
        .modern-table tbody tr:hover { transform: scale(1.01); box-shadow: 0 5px 15px rgba(0,0,0,0.05); }

        .progress-indicator { background: #e2e8f0; height: 8px; border-radius: 4px; overflow: hidden; width: 100%; max-width: 200px;}
        .progress-fill { height: 100%; background: var(--primary); transition: width 0.5s ease; }
        .status-badge { display: inline-block; padding: 0.4rem 1rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; border: 1px solid transparent; }
        
        .date-input-wrapper { background: var(--background); padding: 0.5rem 1rem; border-radius: 12px; font-weight: 600;}
        .date-input-wrapper input { border: none; background: transparent; font-family: 'Outfit'; font-weight: 600; outline: none;}

        .fleet-driver { display: flex; align-items: center; justify-content: space-between; padding: 1rem 0; border-bottom: 1px dashed var(--border-soft); }
        .fleet-driver:last-child { border-bottom: none; }
        .driver-avatar { width: 45px; height: 45px; border-radius: 50%; background: var(--primary); color: white; display: flex; align-items: center; justify-content: center; font-weight: bold; }
    </style>
}

<div class="container-fluid py-4 px-lg-5">
    <div class="dash-header">
        <div>
            <h2 class="mb-1 fw-bold" style="letter-spacing: -0.5px;">Delivery Management Dashboard</h2>
            <p class="text-muted fw-medium mb-0">View and manage all your active deliveries.</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="date-input-wrapper d-flex gap-2">
                <input id="startDate" type="date" /> <span>&rarr;</span> <input id="endDate" type="date" />
            </div>
            <button class="btn btn-dark rounded-pill px-4 fw-bold shadow-sm" onclick="loadDashboard()">Sync Data</button>
        </div>
    </div>

    <!-- METRICS -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="metric-card">
                <div class="mc-icon text-primary"><i class="bi bi-scooter"></i></div>
                <div class="mc-title">Delivery Partners Online</div>
                <div class="mc-value" id="valTotalBoys">@Model.ActivePartnersCount</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <div class="mc-icon text-info"><i class="bi bi-box-seam"></i></div>
                <div class="mc-title">Orders on the Way</div>
                <div class="mc-value" id="valTransit">@Model.InTransitCount</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <div class="mc-icon text-warning"><i class="bi bi-hourglass-split"></i></div>
                <div class="mc-title">Unassigned Orders</div>
                <div class="mc-value" id="valPending">@Model.PendingAssignmentCount</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card bg-dark text-white border-0">
                <div class="mc-icon text-success"><i class="bi bi-check-circle-fill"></i></div>
                <div class="mc-title text-white-50">Completed Orders</div>
                <div class="mc-value d-flex justify-content-between align-items-end">
                    <span id="valCompleted">@Model.CompletedTodayCount</span>
                    <span class="fs-6 fw-medium text-white-50">All Time: <span id="allTimeDeliveredMetric">@Model.CompletedAllTimeCount</span></span>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- ALL ACTIVE ORDERS TRACKING -->
        <div class="col-xl-8">
            <div class="widget-panel" style="min-height: 500px;">
                <div class="widget-title"><i class="bi bi-list-check text-primary fs-3"></i> Active Orders Tracking</div>
                <div class="table-responsive">
                    <table class="modern-table">
                        <thead>
                            <tr>
                                <th>Order Ref</th>
                                <th>Customer Info</th>
                                <th>Order Progress</th>
                                <th>Current Status</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody id="logisticsOrdersContainer">
                            <!-- Populated via AJAX -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- FLEET & CHART -->
        <div class="col-xl-4 d-flex flex-column gap-4">
            <div class="widget-panel flex-grow-1">
                <div class="widget-title"><i class="bi bi-people-fill text-info"></i> Available Delivery Partners</div>
                <div class="fleet-list" id="fleetContainer">
                    <!-- Populated via AJAX -->
                </div>
            </div>

            <div class="widget-panel">
                <div class="widget-title"><i class="bi bi-graph-up text-success"></i> Delivery History Graph</div>
                <div style="height: 200px;"><canvas id="deliveryHistoryChart"></canvas></div>
            </div>
        </div>
    </div>

    <!-- Assign Delivery Modal -->
    <div class="modal fade" id="assignDeliveryModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                <div class="modal-header border-0 bg-light p-4">
                    <h5 class="modal-title fw-bold"><i class="bi bi-send-fill text-primary"></i> Assign Delivery Partner</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 pt-3">
                    <input type="hidden" id="assignOrderId" />
                    <select id="deliveryPersonSelect" class="form-select form-select-lg rounded-4 bg-light fw-medium shadow-sm mb-4">
                        <option value="">Searching riders...</option>
                    </select>
                    <button type="button" id="confirmAssignBtn" class="btn btn-dark w-100 btn-lg rounded-pill fw-bold">Broadcast Task</button>
                </div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let allOrders = [];
        let deliveryChart = null;

        $(document).ready(function() {
            const today = new Date();
            const lastWeek = new Date(); lastWeek.setDate(today.getDate() - 7);
            
            // Format to YYYY-MM-DD avoiding timezone offset issues
            const toTzString = (d) => new Date(d.getTime() - (d.getTimezoneOffset() * 60000)).toISOString().split('T')[0];
            
            $('#endDate').val(toTzString(today));
            $('#startDate').val(toTzString(lastWeek));

            loadDashboard();

            // Real-time tracking hub
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/analyticsHub").withAutomaticReconnect().build();
            connection.on("ReceiveUpdate", () => loadDashboard());
            connection.start().catch(err => console.error(err));
        });

        function loadDashboard() {
            const s = $('#startDate').val(), e = $('#endDate').val();
            // Load Top Metrics & Fleet
            $.get(`/Admin/DeliveryDashboard?period=custom&refDate=${e}&startDate=${s}&endDate=${e}`, function(data) {
                if(data) {
                    $('#valTotalBoys').text(data.ActivePartnersCount || 0);
                    $('#valTransit').text(data.InTransitCount || 0);
                    $('#valPending').text(data.PendingAssignmentCount || 0);
                    $('#valCompleted').text(data.CompletedTodayCount || 0);
                    $('#allTimeDeliveredMetric').text(data.CompletedAllTimeCount || 0);

                    renderFleet(data.Partners);
                    renderChart(data.HistoryTrend);
                }
            });

            // Load Orders Table specifically for tracking
            $.get(`/Admin/GetActiveOrders?from=${s}&to=${e}`, function(data) {
                allOrders = data || [];
                renderLogisticsTable();
            });
        }

        function renderFleet(partners) {
            const $c = $('#fleetContainer').empty();
            if(!partners || !partners.length) { $c.html('<div class="text-muted p-3">No active riders.</div>'); return; }
            partners.forEach(p => {
                const isOnline = p.Status === 'Available';
                const badge = isOnline ? '<span class="text-success small fw-bold">Online</span>' : `<span class="text-warning small fw-bold">${p.Status}</span>`;
                $c.append(`
                    <div class="fleet-driver">
                        <div class="d-flex gap-3 align-items-center">
                            <div class="driver-avatar">${p.Name.charAt(0)}</div>
                            <div><div class="fw-bold text-dark">${p.Name}</div><div class="small text-muted">${p.Phone}</div></div>
                        </div>
                        <div class="text-end">${badge}</div>
                    </div>
                `);
            });
        }

        function getProgressPercent(status) {
            const s = (status || '').toLowerCase();
            if(s.includes('placed') || s.includes('new')) return 10;
            if(s.includes('accept')) return 30;
            if(s.includes('ready')) return 60;
            if(s.includes('transit') || s.includes('way') || s.includes('out')) return 85;
            if(s.includes('deliver') || s.includes('complet')) return 100;
            return 5;
        }

        function getPillColors(status) {
            const s = (status || '').toLowerCase();
            if(s.includes('ready') || s.includes('accept')) return 'background: #fef08a; color: #a16207; border-color: #fde047;';
            if(s.includes('transit') || s.includes('way')) return 'background: #bfdbfe; color: #1d4ed8; border-color: #93c5fd;';
            if(s.includes('deliver')) return 'background: #bbf7d0; color: #15803d; border-color: #86efac;';
            return 'background: #e2e8f0; color: #475569; border-color: #cbd5e1;';
        }

        function renderLogisticsTable() {
            const $c = $('#logisticsOrdersContainer');
            // Filter actively tracking items (exclude completely finished old orders to keep dashboard clean)
            // But we keep today's delivered to show tracked success.
            const today = new Date().toISOString().split('T')[0];
            const active = allOrders.filter(o => 
                o.status !== 'Cancelled' && 
                (getProgressPercent(o.status) < 100 || (o.createdAt && o.createdAt.split('T')[0] === today))
            ).sort((a,b) => getProgressPercent(a.status) - getProgressPercent(b.status)); // Sort pending first

            if(!active.length) {
                $c.html(`<tr><td colspan="5" class="text-center py-5 text-muted"><i class="bi bi-wind fs-1 mb-3 d-block"></i>No active deliveries tracking.</td></tr>`);
                return;
            }

            let html = '';
            active.forEach(o => {
                const pct = getProgressPercent(o.status);
                const colorStyle = getPillColors(o.status);
                let dispatchAction = '';

                // Generate smart action buttons based on status
                if(pct === 60 && !o.deliveryPersonId) {
                    dispatchAction = `<button class="btn btn-sm btn-dark rounded-pill px-3 shadow flex-shrink-0 assign-delivery-btn" data-id="${o.orderId}">Assign Rider</button>`;
                } else if (pct === 60 && o.deliveryPersonId) {
                    dispatchAction = `<button class="btn btn-sm btn-outline-primary rounded-pill px-3 flex-shrink-0 dispatch-btn" data-id="${o.orderId}">Start Transit</button>`;
                } else {
                    dispatchAction = `<a href="/Admin/OrderDetails?orderId=${o.orderId}" class="btn btn-sm btn-light border rounded-pill px-3 shadow-sm">View Details</a>`;
                }

                html += `
                <tr>
                    <td><div class="fw-bold fs-6">#${o.orderId}</div><div class="small text-muted">${o.orderType}</div></td>
                    <td>
                        <div class="fw-bold text-dark">${o.customerName}</div>
                        <div class="small text-muted"><i class="bi bi-geo-alt"></i> ${o.deliveryAddress && o.deliveryAddress.length > 20 ? o.deliveryAddress.substring(0,20)+'...' : (o.deliveryAddress||'Route details')}</div>
                    </td>
                    <td style="width: 250px;">
                        <div class="d-flex justify-content-between small fw-bold text-muted mb-1">
                            <span>Track</span><span>${pct}%</span>
                        </div>
                        <div class="progress-indicator">
                            <div class="progress-fill" style="width: ${pct}%; ${pct === 100 ? 'background: #22c55e;' : ''}"></div>
                        </div>
                    </td>
                    <td><span class="status-badge" style="${colorStyle}">${o.status}</span></td>
                    <td class="text-end d-flex gap-2 justify-content-end align-items-center h-100 mt-2">
                        ${dispatchAction}
                    </td>
                </tr>`;
            });
            $c.html(html);
        }

        function renderChart(historyData) {
            if(!historyData || !historyData.length) return;
            const ctx = document.getElementById('deliveryHistoryChart').getContext('2d');
            if (deliveryChart) deliveryChart.destroy();
            deliveryChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: historyData.map(d => d.Label),
                    datasets: [{
                        label: 'Fulfillment Count',
                        data: historyData.map(d => d.Value),
                        backgroundColor: '#10b981',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, display: false }, x: { display: false } }
                }
            });
        }

        // Action Bindings
        $(document).on('click', '.assign-delivery-btn', function() {
            $('#assignOrderId').val($(this).data('id'));
            $('#assignDeliveryModal').modal('show');
            $.get('/Admin/GetDeliveryPersonnel', function(data) {
                const s = $('#deliveryPersonSelect').empty().append('<option value="">-- Choose Rider --</option>');
                (data||[]).forEach(p => s.append(`<option value="${p.id}">${p.name}</option>`));
            });
        });

        $('#confirmAssignBtn').click(function() {
            const oid = $('#assignOrderId').val(), pid = $('#deliveryPersonSelect').val();
            if(!pid) return alert('Select Rider');
            const btn = $(this).prop('disabled', true).text('Broadcasting...');
            $.post('/Admin/AssignDelivery', { orderId: oid, deliveryPersonId: pid, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() }, function(res) {
                btn.prop('disabled',false).text('Broadcast Task');
                if(res.success) { $('#assignDeliveryModal').modal('hide'); loadDashboard(); } else alert(res.message);
            });
        });

        $(document).on('click', '.dispatch-btn', function() {
            const id = $(this).data('id');
            if(!confirm("Mark order #" + id + " as In Transit?")) return;
            $(this).prop('disabled', true).text('...');
            $.post('/Admin/MarkInTransit', { orderId: id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() }, function(res) {
                if(res.success) loadDashboard(); else alert(res.message);
            });
        });
    </script>
}
