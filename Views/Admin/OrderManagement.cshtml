@{
    ViewData["Title"] = "Order Management";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-orders.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        .extra-small { font-size: 0.75rem; }
        .fw-500 { font-weight: 500; }
        .table-wrapper { border: 1px solid #edf2f7; }
        .filter-box input:focus { outline: none; }
        .admin-table thead th { background-color: #f8fafc; color: #64748b; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.025em; border-bottom: 1px solid #e2e8f0; }
        .admin-table tbody td { border-bottom: 1px solid #f1f5f9; padding: 1rem 0.75rem; }
    </style>
}

@Html.AntiForgeryToken()

<div class="table-wrapper p-4 bg-white rounded-4 shadow-sm">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0 fw-bold text-dark">Order Management</h3>
            <p class="text-muted small mb-0">Track and manage incoming meal orders</p>
        </div>

        <div class="d-flex align-items-center gap-3">
            <div class="filter-box bg-light p-2 rounded-pill d-flex align-items-center border px-3">
                <label class="small fw-bold text-muted me-3 mb-0"><i class="bi bi-calendar3 me-1"></i> RANGE:</label>
                <input id="fromDate" type="date" class="form-control form-control-sm border-0 bg-transparent text-dark mx-1" style="width: 130px;" />
                <span class="mx-2 text-muted small fw-bold">to</span>
                <input id="toDate" type="date" class="form-control form-control-sm border-0 bg-transparent text-dark me-3" style="width: 130px;" />
                <button id="applyFilter" class="btn btn-sm btn-dark rounded-pill px-4 fw-bold">
                    Filter
                </button>
            </div>
        </div>
    </div>

    <!-- KPI Summary Row -->
    <div id="summaryCards" class="row g-4 mb-4">
        <!-- Will be populated by JS -->
    </div>

    <div class="row g-4 mb-4">
        <!-- Order Volume Trend -->
        <div class="col-lg-8">
            <div class="card p-4 h-100 border-0 bg-light rounded-4">
                <div class="d-flex justify-content-end align-items-center mb-4">
                    <div style="font-size:0.8rem;" class="text-muted" id="trendPeriodLabel">Selected Range</div>
                </div>
                <div class="chart-container" style="height: 250px; position: relative;">
                    <canvas id="ordersTrendChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Status Distribution -->
        <div class="col-lg-4">
            <div class="card p-4 h-100 border-0 bg-light rounded-4">
                <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-pie-chart-fill me-2 text-warning"></i>Status Distribution</h5>
                <div class="chart-container" style="height: 200px; position: relative;">
                    <canvas id="statusDistChart"></canvas>
                </div>
                <div id="statusLegend" class="mt-3">
                    <!-- Custom legend will go here -->
                </div>
            </div>
        </div>
    </div>

    <!-- Submenu -->
    <nav class="admin-submenu mb-4 d-flex gap-2">
        <a asp-controller="Admin"
           asp-action="OrderManagement"
           class="btn btn-sm @(ViewContext.RouteData.Values["action"].ToString() == "OrderManagement" ? "btn-success" : "btn-outline-success") rounded-pill px-3">
            Active Management
        </a>
        <a asp-controller="Admin" asp-action="CancelledOrders" class="btn btn-sm btn-outline-danger rounded-pill px-3">
            Cancelled Orders
        </a>
    </nav>

    <!-- Status tabs -->
    <ul class="nav nav-tabs mb-4" id="statusTabs" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" data-status="All" href="#">
                All <span class="ms-1 opacity-75" id="count-All">0</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-status="New" href="#">
                New <span class="ms-1 opacity-75" id="count-New">0</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-status="Accepted" href="#">
                Accepted <span class="ms-1 opacity-75" id="count-Accepted">0</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-status="Ready" href="#">
                Ready <span class="ms-1 opacity-75" id="count-Ready">0</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-status="In Progress" href="#">
                Processing <span class="ms-1 opacity-75" id="count-In Progress">0</span>
            </a>
        </li>
    </ul>

    <!-- Orders table -->
    <div class="table-responsive">
        <table class="table admin-table align-middle" id="ordersTable">
            <thead>
                <tr>
                    <th class="ps-4">ID</th>
                    <th>Customer</th>
                    <th>Order Info</th>
                    <th>Address</th>
                    <th>Payment</th>
                    <th>Status</th>
                    <th class="text-end pe-4">Details</th>
                </tr>
            </thead>
            <tbody>
                <!-- rows injected by script -->
            </tbody>
        </table>
    </div>

    <div id="noOrders" class="no-records" style="display:none;">
        <div class="py-5">
            <i class="bi bi-inbox text-muted display-4"></i>
            <p class="mt-3 fs-5">No active orders found in this category.</p>
        </div>
    </div>
</div>


@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

    <script>
        "use strict";
        (function ($) {
            const pollIntervalMs = 20000; 
            let pollTimer = null;
            let currentFilter = "All";
            let ordersChart = null;
            let statusChart = null;
            const token = $('input[name="__RequestVerificationToken"]').first().val();

            function initDefaults() {
                const today = new Date();
                const past = new Date();
                past.setMonth(today.getMonth() - 1);
                $('#fromDate').val(past.toISOString().slice(0,10));
                $('#toDate').val(today.toISOString().slice(0,10));
            }
            initDefaults();

            function updateTrendPeriodLabel() {
                const from = new Date($('#fromDate').val());
                const to = new Date($('#toDate').val());
                $('#trendPeriodLabel').text(`${from.toLocaleDateString(undefined, {month:'short', day:'numeric'})} - ${to.toLocaleDateString(undefined, {month:'short', day:'numeric', year:'numeric'})}`);
            }

            function renderSummary(summary) {
                const $c = $('#summaryCards').empty();
                const colors = ['primary', 'success', 'warning', 'danger'];
                const icons = ['bi-cart-fill', 'bi-currency-rupee', 'bi-percent', 'bi-x-circle-fill'];
                
                summary.forEach((s, i) => {
                    const color = colors[i % colors.length];
                    const icon = icons[i % icons.length];
                    const col = $(`
                        <div class="col-md-3">
                            <div class="card bg-${color} text-white p-3 shadow-sm h-100 border-0 rounded-4" style="background-opacity: 0.9;">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="small fw-bold text-uppercase mb-1" style="opacity: 0.8">${s.title || s.Title}</div>
                                        <div class="h4 fw-bold mb-0">${s.value || s.Value}</div>
                                    </div>
                                    <div class="h3 mb-0" style="opacity: 0.3">
                                        <i class="bi ${icon}"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `);
                    $c.append(col);
                });
            }

            function renderTrend(trendData) {
                const labels = trendData.labels || trendData.Labels || [];
                const revenue = trendData.revenue || trendData.Revenue || [];
                const orders = trendData.orders || trendData.Orders || [];
                const canvas = document.getElementById('ordersTrendChart');
                if (!canvas) return;
                const ctx = canvas.getContext('2d');

                if (ordersChart) ordersChart.destroy();

                if (labels.length === 0) {
                    ctx.font = "14px Inter";
                    ctx.fillStyle = "#888";
                    ctx.textAlign = "center";
                    ctx.fillText("No trend data available for this range", canvas.width/2, canvas.height/2);
                    return;
                }

                ordersChart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [
                            {
                                label: 'Orders',
                                data: orders,
                                borderColor: '#4e73df',
                                backgroundColor: 'rgba(78, 115, 223, 0.1)',
                                fill: true,
                                tension: 0.4,
                                yAxisID: 'y'
                            }
                        ]
                    },
                    options: { 
                        responsive: true, maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: { 
                            x: { 
                                display: true,
                                title: { display: true, text: 'Date', font: { weight: 'bold' } }
                            }, 
                            y: { 
                                display: true,
                                title: { display: true, text: 'Number of Orders', font: { weight: 'bold' } },
                                beginAtZero: true,
                                ticks: { precision: 0 }
                            } 
                        }
                    }
                });
            }

            function renderStatusDist(rows) {
                const canvas = document.getElementById('statusDistChart');
                if (!canvas) return;
                const ctx = canvas.getContext('2d');
                if (statusChart) statusChart.destroy();

                const counts = {};
                if (!rows || rows.length === 0) {
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    $('#statusLegend').empty();
                    return;
                }

                rows.forEach(r => {
                    const status = r.status || r.Status || 'New';
                    counts[status] = (counts[status] || 0) + 1;
                });

                const labels = Object.keys(counts);
                const data = Object.values(counts);
                const colors = ['#4e73df', '#1cc88a', '#f6c23e', '#e74a3b', '#36b9cc', '#858796'];

                statusChart = new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{ data: data, backgroundColor: colors.slice(0, labels.length), borderWidth: 0 }]
                    },
                    options: {
                        responsive: true, maintainAspectRatio: false,
                        plugins: { legend: { display: false } }, cutout: '75%'
                    }
                });

                const $legend = $('#statusLegend').empty();
                labels.forEach((label, i) => {
                    const percent = Math.round((data[i] / rows.length) * 100);
                    $legend.append(`
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle me-2" style="width:10px; height:10px; background-color:${colors[i]}"></div>
                                <span class="small fw-bold text-muted">${label}</span>
                            </div>
                            <span class="small fw-bold">${percent}%</span>
                        </div>
                    `);
                });
            }

            function fetchAnalytics() {
                const q = { 
                    from: $('#fromDate').val(), 
                    to: $('#toDate').val(), 
                    status: 'All', 
                    period: 'daily' 
                };
                $.getJSON('/Reports/GetOrderReportsData', q).done(function (res) {
                    renderSummary(res.summary || res.Summary || []);
                    renderTrend(res.trend || res.Trend || {});
                    renderStatusDist(res.orders || res.Orders || []);
                    updateTrendPeriodLabel();
                });
            }

            // SignalR Setup
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/analyticsHub")
                .build();

            connection.on("ReceiveUpdate", function (message) {
                console.log("Real-time order update: ", message);
                if (window.notify) window.notify.info(message);
                fetchOrders(); 
            });

            connection.start().catch(err => console.error(err.toString()));

            function formatBadge(status) {
                let cls = "status-new";
                if (status === "Accepted") cls = "status-accepted";
                else if (status.includes("Ready")) cls = "status-ready";
                else if (status === "In Transit" || status === "On the Way") cls = "status-transit";
                else if (status === "Picked" || status === "Delivered") cls = "status-picked";
                else if (status === "Flagged") cls = "status-flagged";
                else if (status === "Cancelled") cls = "status-cancelled";
                
                return `<span class="badge ${cls}">${status}</span>`;
            }

            function buildActionButtons(order) {
                const id = order.orderId;
                const status = order.status;
                
                let buttons = `<a href="/Admin/OrderDetails?orderId=${id}" class="btn btn-sm btn-outline-secondary rounded-pill me-1 px-3 d-inline-block"><i class="bi bi-eye"></i> Details</a>`;
                
                if (status === "Placed" || status === "New") {
                    buttons += `<button class="btn btn-sm btn-success rounded-pill px-3 accept-order-btn" data-id="${id}"><i class="bi bi-check2"></i> Accept</button>`;
                } else if (status === "Accepted") {
                    buttons += `<button class="btn btn-sm btn-primary rounded-pill px-3 ready-order-btn" data-id="${id}"><i class="bi bi-box-seam"></i> Mark Ready</button>`;
                }
                
                return buttons;
            }

            function renderOrders(list) {
                const $tbody = $('#ordersTable tbody');
                $tbody.empty();

                if (!list || list.length === 0) {
                    $('#noOrders').show();
                    $('#ordersTable').hide();
                    return;
                }

                $('#noOrders').hide();
                $('#ordersTable').show();

                const counts = { "All": list.length, "New": 0, "Accepted": 0, "Ready": 0, "In Progress": 0 };
                list.forEach(o => {
                    let tabStatus = o.status;
                    if (o.status === "New" || o.status === "Placed") tabStatus = "New";
                    else if (o.status.includes("Ready")) tabStatus = "Ready";
                    else if (o.status === "In Transit" || o.status === "On the Way") tabStatus = "In Progress";

                    if (counts.hasOwnProperty(tabStatus)) counts[tabStatus]++;
                });

                for (const k in counts) {
                    const id = 'count-' + k;
                    $('#' + id.replace(/\s/g, '\\ ')).text(counts[k]);
                }

                list.forEach(order => {
                    let tabStatus = order.status;
                    if (order.status === "New" || order.status === "Placed") tabStatus = "New";
                    else if (order.status.includes("Ready")) tabStatus = "Ready";
                    else if (order.status === "In Transit" || order.status === "On the Way") tabStatus = "In Progress";

                    if (currentFilter !== "All" && currentFilter !== tabStatus) return;

                    const date = order.createdAt ? new Date(order.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) : '--:--';

                    const $tr = $('<tr>').attr('data-id', order.orderId);
                    $tr.append(`<td class="ps-4 fw-bold text-primary">#${order.orderId}</td>`);
                    $tr.append(`<td>
                        <div class="fw-bold text-dark">${order.customerName || 'Guest User'}</div>
                        <div class="text-muted extra-small"><i class="bi bi-telephone"></i> ${order.customerPhone || 'N/A'}</div>
                    </td>`);
                    $tr.append(`<td>
                        <div class="fw-500">${order.totalItems} Items</div>
                        <div class="text-muted extra-small"><i class="bi bi-tag"></i> ${order.orderType || 'Delivery'}</div>
                    </td>`);
                    
                    const fullAddr = order.deliveryAddress || 'Local Address';
                    const addrDisplay = fullAddr.length > 35 ? (fullAddr.substring(0, 32) + '...') : fullAddr;
                    $tr.append(`<td>
                        <div class="small text-dark fw-500 text-truncate" style="max-width: 220px;" title="${fullAddr}">${addrDisplay}</div>
                        <div class="text-muted extra-small mt-1"><i class="bi bi-geo-alt"></i> Delivery Point</div>
                    </td>`);
                    
                    $tr.append(`<td><span class="fw-bold text-dark">₹${order.totalAmount || '--'}</span><br/><small class="text-muted extra-small">${order.paymentStatus || 'Paid'}</small></td>`);
                    $tr.append(`<td>${formatBadge(order.status)}</td>`);
                    $tr.append(`<td class="text-end pe-4">${buildActionButtons(order)}</td>`);

                    $tbody.append($tr);
                });
                // Update stats counts if needed (lastUpdated label is removed)
            }

            function fetchOrders() {
                const from = $('#fromDate').val();
                const to = $('#toDate').val();
                
                $.ajax({
                    url: '/Admin/GetActiveOrders',
                    method: 'GET',
                    data: { from: from, to: to },
                    success: function (data) { 
                        window.lastOrderList = data;
                        renderOrders(data); 
                    },
                    error: function (xhr) { 
                        console.error("Fetch orders failed:", xhr);
                    }
                });
            }

            $('#applyFilter').on('click', function() {
                fetchOrders();
                fetchAnalytics();
            });

            // Action Buttons Logic
            $(document).on('click', '.accept-order-btn', function() {
                const id = $(this).data('id');
                if (!confirm(`Mark order #${id} as Accepted?`)) return;
                performAction(id, '/Admin/AcceptOrder');
            });

            $(document).on('click', '.ready-order-btn', function() {
                const id = $(this).data('id');
                if (!confirm(`Mark order #${id} as Ready for Delivery?`)) return;
                performAction(id, '/Admin/MarkReady');
            });

            function performAction(id, url) {
                $.ajax({
                    url: url,
                    method: 'POST',
                    data: { 
                        orderId: id, 
                        __RequestVerificationToken: token 
                    },
                    success: function(res) {
                        if (res.success) {
                            fetchOrders();
                        } else {
                            alert("Error: " + res.message);
                        }
                    },
                    error: function(xhr) {
                        console.error(xhr);
                        alert("An error occurred while communicating with the server.");
                    }
                });
            }

            $('#statusTabs').on('click', 'a', function (e) {
                e.preventDefault();
                $('#statusTabs a').removeClass('active');
                $(this).addClass('active');
                currentFilter = $(this).data('status');
                renderOrders(window.lastOrderList || []); 
            });

            // Polling
            function startPolling() {
                if (pollTimer) return;
                pollTimer = setInterval(fetchOrders, pollIntervalMs);
                fetchOrders();
            }
            function stopPolling() { clearInterval(pollTimer); pollTimer = null; }

            $(function () { 
                startPolling(); 
                fetchAnalytics();
            });

        })(jQuery);
    </script>
}
