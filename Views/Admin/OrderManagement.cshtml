@{
    ViewData["Title"] = "Order Management";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-orders.css" asp-append-version="true" />
}

@Html.AntiForgeryToken()

<div class="table-wrapper card-glass p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Order Management</h3>

        <div class="d-flex align-items-center">
            <span id="liveIndicator" class="badge bg-success me-2">Live</span>
            <label class="form-check-label me-2">Auto-refresh</label>
            <input id="autoRefreshToggle" class="form-check-input" type="checkbox" checked />
            <span id="lastUpdated" class="ms-3 text-muted"></span>
        </div>
    </div>

    <!-- Submenu -->
    <nav class="admin-submenu mb-4">
        <a asp-controller="Admin"
           asp-action="OrderDetails"
           class="submenu-link @(ViewContext.RouteData.Values["action"].ToString() == "OrderDetails" ? "active" : "")">
            Order Details
        </a>       
        <a asp-controller="Admin" asp-action="CancelledOrders" class="submenu-link">Cancelled Orders</a>
    </nav>

    <!-- Status tabs -->
    <ul class="nav nav-tabs mb-3" id="statusTabs" role="tablist">
        <li class="nav-item"><a class="nav-link active" data-status="All" href="#">All <span class="badge bg-light text-dark ms-1" id="count-All">0</span></a></li>
        <li class="nav-item"><a class="nav-link" data-status="New" href="#">New <span class="badge bg-light text-dark ms-1" id="count-New">0</span></a></li>
        <li class="nav-item"><a class="nav-link" data-status="Accepted" href="#">Accepted <span class="badge bg-light text-dark ms-1" id="count-Accepted">0</span></a></li>
        <li class="nav-item"><a class="nav-link" data-status="Ready" href="#">Ready <span class="badge bg-light text-dark ms-1" id="count-Ready">0</span></a></li>
        <li class="nav-item"><a class="nav-link" data-status="In Progress" href="#">In Progress <span class="badge bg-light text-dark ms-1" id="count-In Progress">0</span></a></li>
    </ul>

    <!-- Orders table -->
    <div class="table-responsive">
        <table class="table admin-table" id="ordersTable">
            <thead>
                <tr>
                    <th>Order Id</th>
                    <th>Customer</th>
                    <th>Items</th>
                    <th>Delivery Address</th>
                    <th>Payment</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- rows injected by script -->
            </tbody>
        </table>
    </div>

    <div id="noOrders" class="no-records" style="display:none;">
        No active orders.
    </div>
</div>

<!-- Assign Delivery Modal -->
<div class="modal fade" id="assignDeliveryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content card-glass">
            <div class="modal-header">
                <h5 class="modal-title">Assign Delivery Person</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="assignOrderId" />
                <div class="mb-3">
                    <label class="form-label">Select Delivery Partner</label>
                    <select id="deliveryPersonSelect" class="form-select">
                        <option value="">Loading partners...</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmAssignBtn" class="btn btn-primary">Assign Now</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

    <script>
        "use strict";
        (function ($) {
            const pollIntervalMs = 15000; // 15s (increased because we have SignalR now)
            let pollTimer = null;
            let currentFilter = "All";
            const token = $('input[name="__RequestVerificationToken"]').first().val();

            // SignalR Setup
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/analyticsHub")
                .build();

            connection.on("ReceiveUpdate", function (message) {
                console.log("Real-time order update: ", message);
                window.notify.info(message);
                fetchOrders(); // Refresh table on update
            });

            connection.start().catch(err => console.error(err.toString()));

            const statusClass = {
                "New": "order-row-new",
                "Accepted": "order-row-accepted",
                "Ready for Pickup": "order-row-ready",
                "Ready for Delivery": "order-row-ready",
                "Picked": "order-row-picked",
                "In Transit": "order-row-picked",
                "Flagged": "order-row-flagged"
            };

            function formatBadge(status) {
                let cls = "badge bg-secondary";
                if (status === "New") cls = "badge bg-warning text-dark";
                else if (status === "Accepted") cls = "badge bg-info text-dark";
                else if (status === "Ready for Pickup" || status === "Ready for Delivery") cls = "badge bg-success";
                else if (status === "Picked" || status === "In Transit") cls = "badge bg-primary";
                else if (status === "Flagged") cls = "badge bg-danger";
                return '<span class="' + cls + '">' + status + '</span>';
            }

            function buildActionButtons(order) {
                let btns = [];
                const status = order.status;
                const id = order.orderId;

                if (status === "New" || status === "Placed") {
                    btns.push('<button class="btn btn-sm glow btn-success action-btn me-1" data-action="AcceptOrder" data-id="' + id + '">Accept</button>');
                } else if (status === "Accepted") {
                    btns.push('<button class="btn btn-sm glow btn-warning action-btn me-1" data-action="MarkReady" data-id="' + id + '">Mark Ready</button>');
                } else if (status === "Ready for Delivery") {
                    if (!order.deliveryPersonId) {
                        btns.push('<button class="btn btn-sm glow btn-info assign-delivery-btn me-1" data-id="' + id + '">Assign Delivery</button>');
                    } else {
                        btns.push('<button class="btn btn-sm glow btn-primary action-btn me-1" data-action="MarkInTransit" data-id="' + id + '">In Transit</button>');
                    }
                } else if (status === "In Transit") {
                    btns.push('<button class="btn btn-sm glow btn-success action-btn me-1" data-action="MarkDelivered" data-id="' + id + '">Delivered</button>');
                } else if (status === "Ready for Pickup") {
                    btns.push('<button class="btn btn-sm glow btn-primary action-btn me-1" data-action="MarkPicked" data-id="' + id + '">Mark Picked</button>');
                }

                if (order.deliveryPersonId && (status === "Ready for Delivery" || status === "In Transit")) {
                    btns.push('<span class="badge bg-info d-block mt-1">Partner Assigned</span>');
                }

                return btns.join('');
            }

            function renderOrders(list) {
                const $tbody = $('#ordersTable tbody');
                $tbody.empty();

                if (!list || list.length === 0) {
                    $('#noOrders').show();
                    $('#ordersTable').hide();
                    return;
                }

                $('#noOrders').hide();
                $('#ordersTable').show();

                const counts = { "All": list.length, "New": 0, "Accepted": 0, "Ready": 0, "In Progress": 0 };
                list.forEach(o => {
                    let tabStatus = o.status;
                    if (o.status === "New" || o.status === "Placed") tabStatus = "New";
                    else if (o.status === "Ready for Pickup" || o.status === "Ready for Delivery") tabStatus = "Ready";
                    else if (o.status === "Picked" || o.status === "In Transit") tabStatus = "In Progress";

                    if (counts.hasOwnProperty(tabStatus)) counts[tabStatus]++;
                });

                for (const k in counts) {
                    const id = 'count-' + k;
                    $('#' + id.replace(/\s/g, '\\ ')).text(counts[k]);
                }

                list.forEach(order => {
                    let tabStatus = order.status;
                    if (order.status === "New" || order.status === "Placed") tabStatus = "New";
                    else if (order.status === "Ready for Pickup" || order.status === "Ready for Delivery") tabStatus = "Ready";
                    else if (order.status === "Picked" || order.status === "In Transit") tabStatus = "In Progress";

                    const cls = statusClass[order.status] || '';
                    if (currentFilter !== "All" && currentFilter !== tabStatus) {
                        return;
                    }

                    const orderLink = '<a href="/Admin/OrderDetails?orderId=' + order.orderId + '" class="fw-bold">#' + order.orderId + '</a>';

                    const $tr = $('<tr>').addClass(cls).attr('data-id', order.orderId);
                    $tr.append($('<td>').html(orderLink));
                    $tr.append($('<td>').html('<strong>' + (order.customerName || 'Guest') + '</strong><br/><small class="text-muted">' + (order.customerPhone || 'No Phone') + '</small>'));
                    $tr.append($('<td>').text(order.totalItems + ' items'));
                    
                    const details = (order.deliveryAddress || 'No Address');
                    const deliveryInfo = `<br/><small class="text-info">${order.deliveryStatus || 'Unassigned'}</small>`;
                    $tr.append($('<td>').html('<small>' + details + '</small>' + deliveryInfo));
                    
                    $tr.append($('<td>').text(order.paymentStatus || 'Pending'));
                    $tr.append($('<td>').html(formatBadge(order.status)));
                    $tr.append($('<td>').html(buildActionButtons(order)));

                    $tbody.append($tr);
                });
                $('#lastUpdated').text('Updated: ' + new Date().toLocaleTimeString());
            }

            function fetchOrders() {
                $('#liveIndicator').removeClass('bg-danger').addClass('bg-success').text('Live');
                $.ajax({
                    url: '/Admin/GetActiveOrders',
                    method: 'GET',
                    dataType: 'json',
                    success: function (data) { 
                        $('#noOrders').hide();
                        $('#ordersTable').show();
                        renderOrders(data); 
                    },
                    error: function (xhr) { 
                        console.error("Fetch orders failed:", xhr);
                        $('#liveIndicator').removeClass('bg-success').addClass('bg-danger').text('Disconnected');
                        if ($('#ordersTable tbody tr').length === 0) {
                            $('#ordersTable').hide();
                            $('#noOrders').html('Error loading orders. <button class="btn btn-sm btn-outline-primary ms-2" onclick="location.reload()">Retry</button>').show();
                        }
                    }
                });
            }

            $(document).on('click', '.action-btn', function (e) {
                e.preventDefault();
                const $btn = $(this);
                const action = $btn.data('action');
                const id = $btn.data('id');
                const originalHtml = $btn.html();

                $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span>');
                $.post({
                    url: '/Admin/' + action,
                    data: { orderId: id, __RequestVerificationToken: token },
                    dataType: 'json',
                    success: function (res) {
                        if (res.success) {
                            window.notify.success(res.message || 'Action completed');
                            fetchOrders();
                        } else {
                            window.notify.error(res.message || 'Action failed');
                            $btn.prop('disabled', false).html(originalHtml);
                        }
                    },
                    error: function () {
                        window.notify.error('Network error. Please try again.');
                        $btn.prop('disabled', false).html(originalHtml);
                    }
                });
            });

            // Delivery Assignment Handlers
            $(document).on('click', '.assign-delivery-btn', function () {
                const orderId = $(this).data('id');
                $('#assignOrderId').val(orderId);
                $('#assignDeliveryModal').modal('show');

                // Fetch personnel
                $.get('/Admin/GetDeliveryPersonnel', function (data) {
                    const $select = $('#deliveryPersonSelect').empty();
                    if (!data || data.length === 0) {
                        $select.append('<option value="">No partners found</option>');
                        return;
                    }
                    data.forEach(p => {
                        $select.append(`<option value="${p.id}">${p.name} (${p.phone})</option>`);
                    });
                });
            });

            $('#confirmAssignBtn').on('click', function () {
                const orderId = $('#assignOrderId').val();
                const personId = $('#deliveryPersonSelect').val();

                if (!personId) {
                    alert('Please select a delivery partner');
                    return;
                }

                $(this).prop('disabled', true).text('Assigning...');

                $.post({
                    url: '/Admin/AssignDelivery',
                    data: { orderId: orderId, deliveryPersonId: personId, __RequestVerificationToken: token },
                    success: function (res) {
                        if (res.success) {
                            $('#assignDeliveryModal').modal('hide');
                            fetchOrders();
                        } else {
                            alert(res.message || 'Failed to assign');
                        }
                    },
                    complete: function () {
                        $('#confirmAssignBtn').prop('disabled', false).text('Assign Now');
                    }
                });
            });

            $('#statusTabs').on('click', 'a', function (e) {
                e.preventDefault();
                $('#statusTabs a').removeClass('active');
                $(this).addClass('active');
                currentFilter = $(this).data('status');
                fetchOrders();
            });

            $('#autoRefreshToggle').on('change', function () {
                const enabled = $(this).is(':checked');
                if (enabled) startPolling(); else stopPolling();
            });

            function startPolling() {
                if (pollTimer) return;
                pollTimer = setInterval(fetchOrders, pollIntervalMs);
                fetchOrders();
            }

            function stopPolling() {
                if (!pollTimer) return;
                clearInterval(pollTimer);
                pollTimer = null;
            }

            $(function () { startPolling(); $(document).on('orders:refresh', fetchOrders); });
        })(jQuery);
    </script>
}
