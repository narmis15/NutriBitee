@model IEnumerable<NUTRIBITE.Models.Subscription>

@{
    ViewData["Title"] = "Platform Subscriptions";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Platform Subscriptions</h2>
            <p class="text-muted mb-0">Oversee all recurring meal subscriptions across the entire platform.</p>
        </div>
        <div class="d-flex gap-3">
            <select id="monthFilter" class="form-select rounded-pill shadow-sm" style="width: 180px; border: 1px solid #e9ecef;">
                <option value="">All Months</option>
                <option value="2026-03">March 2026</option>
                <option value="2026-04">April 2026</option>
                <option value="2026-05">May 2026</option>
            </select>
        </div>
    </div>

    @{
        var totalSubs = Model.Count();
        var activeSubs = Model.Count(s => s.Status == "Active");
        var cancelledSubs = Model.Count(s => s.Status == "Cancelled");
        var monthlySubs = Model.Count(s => s.SubscriptionType == "Monthly");
    }

    <!-- KPI Summary Row -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white p-3 shadow-sm h-100 border-0 rounded-4" style="--bs-bg-opacity: 0.9;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small fw-bold text-uppercase mb-1" style="opacity: 0.8">Total Subscriptions</div>
                        <div class="h4 fw-bold mb-0">@totalSubs</div>
                    </div>
                    <div class="h3 mb-0" style="opacity: 0.3"><i class="bi bi-card-checklist"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white p-3 shadow-sm h-100 border-0 rounded-4" style="--bs-bg-opacity: 0.9;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small fw-bold text-uppercase mb-1" style="opacity: 0.8">Active</div>
                        <div class="h4 fw-bold mb-0">@activeSubs</div>
                    </div>
                    <div class="h3 mb-0" style="opacity: 0.3"><i class="bi bi-play-circle-fill"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white p-3 shadow-sm h-100 border-0 rounded-4" style="--bs-bg-opacity: 0.9;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small fw-bold text-uppercase mb-1" style="opacity: 0.8">Monthly Plans</div>
                        <div class="h4 fw-bold mb-0">@monthlySubs</div>
                    </div>
                    <div class="h3 mb-0" style="opacity: 0.3"><i class="bi bi-calendar-month"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white p-3 shadow-sm h-100 border-0 rounded-4" style="--bs-bg-opacity: 0.9;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small fw-bold text-uppercase mb-1" style="opacity: 0.8">Cancelled</div>
                        <div class="h4 fw-bold mb-0">@cancelledSubs</div>
                    </div>
                    <div class="h3 mb-0" style="opacity: 0.3"><i class="bi bi-x-circle-fill"></i></div>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="mb-3">
                <i class="bi bi-calendar-x text-muted border rounded-circle p-4" style="font-size: 3rem;"></i>
            </div>
            <h4 class="fw-bold text-muted mt-4">No Platform Subscriptions</h4>
            <p class="text-muted">There are currently no active user subscriptions in the database.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 text-secondary small fw-bold text-uppercase">Customer</th>
                            <th class="text-secondary small fw-bold text-uppercase">Vendor</th>
                            <th class="text-secondary small fw-bold text-uppercase">Subscribed Food</th>
                            <th class="text-secondary small fw-bold text-uppercase">Frequency</th>
                            <th class="text-secondary small fw-bold text-uppercase">Start Date</th>
                            <th class="text-secondary small fw-bold text-uppercase">Status</th>
                        </tr>
                    </thead>
                    <tbody id="subsTableBody">
                        @foreach (var sub in Model)
                        {
                            <tr data-date="@sub.StartDate.ToString("yyyy-MM")">
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@(sub.User?.Name ?? "Unknown")</div>
                                    <div class="small text-muted">@(sub.User?.Email ?? "-")</div>
                                </td>
                                <td>
                                    @if(sub.Vendor != null)
                                    {
                                        <div class="fw-bold text-dark">@sub.Vendor.VendorName</div>
                                    }
                                    else if(sub.Food != null && sub.Food.VendorId != null)
                                    {
                                        <div class="fw-bold text-dark">Vendor ID: @sub.Food.VendorId</div>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Unknown</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        @if (sub.Food != null)
                                        {
                                            <div>
                                                <div class="fw-bold text-dark">@sub.Food.Name</div>
                                                <div class="text-success small fw-bold">₹@sub.PricePerDelivery / delivery</div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">Food unavailable</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2 py-1">
                                        @sub.SubscriptionType
                                    </span>
                                </td>
                                <td>
                                    <div class="small text-muted">@sub.StartDate.ToString("MMM dd, yyyy")</div>
                                </td>
                                <td>
                                    @if(sub.Status == "Active")
                                    {
                                        <span class="badge bg-success-subtle text-success px-2 py-1"><i class="bi bi-check-circle-fill me-1"></i>Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary px-2 py-1">@sub.Status</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#monthFilter").on("change", function () {
                var monthText = $(this).val();

                $("#subsTableBody tr").each(function () {
                    var rowDate = $(this).data("date") || "";
                    if (monthText) {
                        $(this).toggle(rowDate === monthText);
                    } else {
                        $(this).show();
                    }
                });
            });
        });
    </script>
}
