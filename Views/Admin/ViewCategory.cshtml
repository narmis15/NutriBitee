@using NUTRIBITE.Models
@model IEnumerable<NUTRIBITE.Models.AddCategory>

@{
    ViewData["Title"] = "View Food Categories";
}

<h3 class="page-title">View Food Categories</h3>

<div class="table-wrapper">
    <table class="admin-table">
        <thead>
            <tr>
                <!-- SERIAL NUMBER -->
                <th>Sr No.</th>

                <!-- PRODUCT CATEGORY -->
                <th>
                    <a asp-action="ViewCategory"
                       asp-route-sortOrder="@ViewBag.CategorySort"
                       class="sortable">
                        Product Category ⇅
                    </a>
                </th>

                <!-- PRODUCT IMAGE -->
                <th>Product Image</th>

                <!-- ACTION -->
                <th style="text-align:center;">Action</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                int sr = 1;

                foreach (var item in Model)
                {
                    <tr>
                        <!-- SERIAL NUMBER -->
                        <td>@sr</td>

                        <!-- CATEGORY NAME -->
                        <td>@item.ProductCategory</td>

                        <!-- CATEGORY IMAGE -->
                        <td class="image-cell">
                            @if (!string.IsNullOrEmpty(item.ProductPic))
                            {
                                <img src="~/images/Product/@item.ProductPic"
                                     alt="@item.ProductCategory"
                                     class="category-thumb"
                                     onerror="this.onerror=null;this.src='/images/Product/default.jpg';" />
                            }
                            else
                            {
                                <img src="~/images/Product/default.jpg"
                                     alt="No Image"
                                     class="category-thumb" />
                            }
                        </td>

                        <!-- ACTION BUTTONS -->
                        <td class="action-cell">
                            <a asp-action="EditCategory"
                               asp-route-id="@item.Cid"
                               class="btn-action btn-approve">
                                Edit
                            </a>

                            <a asp-action="DeleteCategory"
                               asp-route-id="@item.Cid"
                               class="btn-action btn-reject"
                               onclick="return confirm('Are you sure you want to delete this category?');">
                                Delete
                            </a>
                        </td>
                    </tr>

                    sr++;
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="no-records">
                        No records found
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>