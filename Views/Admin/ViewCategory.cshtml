@using NUTRIBITE.Models
@model IEnumerable<NUTRIBITE.Models.AddCategory>

@{
    ViewData["Title"] = "Food Categories";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Food Categories</h2>
            <p class="text-muted small mb-0">Manage your product categories and their visual representation.</p>
        </div>
        <a asp-action="AddFoodCategory" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Add New Category
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4" style="width: 80px;">Sr No.</th>
                            <th>
                                <a asp-action="ViewCategory" asp-route-sortOrder="@ViewBag.CategorySort" class="text-decoration-none text-muted">
                                    Product Category <i class="bi bi-arrow-down-up ms-1"></i>
                                </a>
                            </th>
                            <th>Preview Image</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int sr = 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-medium text-muted">@sr.ToString("D2")</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="category-icon-box me-3">
                                                <i class="bi bi-tag-fill text-primary"></i>
                                            </div>
                                            <span class="fw-semibold">@item.ProductCategory</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="category-preview-wrapper">
                                            @if (!string.IsNullOrEmpty(item.ProductPic))
                                            {
                                                <img src="~/images/Product/@item.ProductPic" alt="@item.ProductCategory" class="rounded shadow-sm" style="width: 60px; height: 40px; object-fit: cover;" onerror="this.src='/images/Product/default.jpg';" />
                                            }
                                            else
                                            {
                                                <img src="~/images/Product/default.jpg" alt="No Image" class="rounded shadow-sm" style="width: 60px; height: 40px; object-fit: cover;" />
                                            }
                                        </div>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="EditCategory" asp-route-id="@item.Cid" class="btn btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="DeleteCategory" asp-route-id="@item.Cid" class="btn btn-outline-danger" title="Delete" onclick="return confirm('Are you sure?');">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                sr++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="bi bi-folder-x display-4 d-block mb-3"></i>
                                        <p class="mb-0">No categories found in the database.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .category-icon-box {
        width: 32px;
        height: 32px;
        background: rgba(var(--bs-primary-rgb), 0.1);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .table-hover tbody tr:hover {
        background-color: rgba(0,0,0,0.02);
    }
    .category-preview-wrapper img {
        transition: transform 0.2s;
    }
    .category-preview-wrapper img:hover {
        transform: scale(1.1);
    }
</style>