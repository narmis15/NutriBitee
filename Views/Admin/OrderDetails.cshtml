@{
    ViewData["Title"] = "Order Details";
}
@section Styles {
    <link rel="stylesheet" href="~/css/admin-orders.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .timeline-steps {
            display: flex;
            justify-content: space-between;
            position: relative;
            margin-top: 2rem;
            padding-bottom: 1rem;
        }
        .timeline-steps::before {
            content: '';
            position: absolute;
            top: 20px;
            left: 0;
            width: 100%;
            height: 4px;
            background: #e9ecef;
            z-index: 1;
        }
        .timeline-step {
            position: relative;
            z-index: 2;
            text-align: center;
            flex: 1;
        }
        .timeline-icon {
            width: 40px;
            height: 40px;
            line-height: 40px;
            border-radius: 50%;
            background: #e9ecef;
            color: #6c757d;
            margin: 0 auto 10px;
            font-size: 1.2rem;
            border: 4px solid #fff;
            transition: all 0.3s;
        }
        .timeline-step.active .timeline-icon {
            background: #2d6a4f;
            color: #fff;
            box-shadow: 0 0 0 4px rgba(45, 106, 79, 0.2);
        }
        .timeline-label {
            font-size: 0.85rem;
            font-weight: bold;
            color: #6c757d;
        }
        .timeline-step.active .timeline-label {
            color: #2d6a4f;
        }
        /* Progress line overlay */
        .timeline-steps.progress-1::before { background: linear-gradient(to right, #2d6a4f 0%, #e9ecef 0%); }
        .timeline-steps.progress-2::before { background: linear-gradient(to right, #2d6a4f 25%, #e9ecef 25%); }
        .timeline-steps.progress-3::before { background: linear-gradient(to right, #2d6a4f 50%, #e9ecef 50%); }
        .timeline-steps.progress-4::before { background: linear-gradient(to right, #2d6a4f 75%, #e9ecef 75%); }
        .timeline-steps.progress-5::before { background: linear-gradient(to right, #2d6a4f 100%, #e9ecef 100%); }
    </style>
}

<div class="card-glass p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">Order Details</h3>
        <a asp-action="OrderManagement" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Back to Management
        </a>
    </div>
    @Html.AntiForgeryToken()

    <div id="orderDetailsContainer">
        <div class="text-center py-5" id="loadingState">
            <div class="spinner-border text-success" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">Fetching order details...</p>
        </div>
        <p class="text-muted d-none" id="initialState">Select an order from Order Management or refresh this page with ?orderId={orderId}.</p>
    </div>
</div>

@section Scripts {
<script>
    (function() {
        const orderId = '@(ViewBag.OrderId ?? "")';
        const container = document.getElementById('orderDetailsContainer');
        const loadingState = document.getElementById('loadingState');
        const initialState = document.getElementById('initialState');

        if (!orderId || orderId === '0') {
            loadingState.classList.add('d-none');
            initialState.classList.remove('d-none');
            return;
        }

        function fetchOrderDetails(id, retryCount = 0) {
            fetch(`@Url.Action("GetOrderDetails","Admin")?orderId=${id}`)
                .then(r => {
                    if (!r.ok) throw new Error(`HTTP error! status: ${r.status}`);
                    return r.json();
                })
                .then(data => {
                    if (data.error) {
                        container.innerHTML = `<div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            ${data.error}
                        </div>`;
                        return;
                    }
                    renderOrder(data);
                })
                .catch(err => {
                    console.error("Fetch error:", err);
                    if (retryCount < 3) {
                        const delay = Math.pow(2, retryCount) * 1000;
                        setTimeout(() => fetchOrderDetails(id, retryCount + 1), delay);
                    } else {
                        container.innerHTML = `<div class="alert alert-danger">
                            <h5><i class="bi bi-wifi-off me-2"></i> Connection Error</h5>
                            <p>Unable to retrieve order details. Please check your network and try again.</p>
                            <button class="btn btn-outline-danger btn-sm mt-2" onclick="location.reload()">
                                <i class="bi bi-arrow-clockwise me-1"></i> Retry Now
                            </button>
                        </div>`;
                    }
                });
        }

        function escapeHtml(text) {
            if (text === null || text === undefined) return '';
            const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
            return text.toString().replace(/[&<>"']/g, function(m) { return map[m]; });
        }

        function renderOrder(data) {
            // Support both PascalCase and camelCase property names
            const orderId = data.OrderId ?? data.orderId;
            const status = data.Status ?? data.status;
            const orderDateTime = data.OrderDateTime ?? data.orderDateTime;
            const customerName = data.CustomerName ?? data.customerName;
            const customerPhone = data.CustomerPhone ?? data.customerPhone;
            const deliveryAddress = data.DeliveryAddress ?? data.deliveryAddress;
            const deliveryNotes = data.DeliveryNotes ?? data.deliveryNotes;
            const paymentMode = data.PaymentMode ?? data.paymentMode;
            const amount = data.Amount ?? data.amount;
            const commissionAmount = data.CommissionAmount ?? data.commissionAmount;
            const vendorAmount = data.VendorAmount ?? data.vendorAmount;
            const transactionId = data.TransactionId ?? data.transactionId;
            const isRefunded = data.IsRefunded ?? data.isRefunded;
            const refundStatus = data.RefundStatus ?? data.refundStatus;
            const items = data.Items ?? data.items ?? [];
            const deliveryPersonId = data.DeliveryPersonId ?? data.deliveryPersonId;
            const deliveryAgentName = data.DeliveryAgentName ?? data.deliveryAgentName;

            const timelineHtml = `
                    <div class="info-group mt-4 pt-3 border-top">
                        <h5 class="mb-3">Delivery Tracking Timeline</h5>
                        ${renderTimeline(status)}
                    </div>`;

            let html = `<div class="row g-4">
                <div class="col-md-7">
                    <div class="info-group mb-4">
                        <h5 class="border-bottom pb-2 mb-3">Order Information</h5>
                        <dl class="row mb-0">
                            <dt class="col-sm-4 text-muted fw-normal">Order ID</dt>
                            <dd class="col-sm-8 fw-bold">#${orderId}</dd>

                            <dt class="col-sm-4 text-muted fw-normal">Status</dt>
                            <dd class="col-sm-8">
                                <span class="badge rounded-pill bg-info text-dark">${escapeHtml(status)}</span>
                            </dd>

                            <dt class="col-sm-4 text-muted fw-normal">Date & Time</dt>
                            <dd class="col-sm-8">${escapeHtml(orderDateTime)}</dd>
                        </dl>
                    </div>

                    <div class="info-group">
                        <h5 class="border-bottom pb-2 mb-3">Customer Details</h5>
                        <dl class="row mb-0">
                            <dt class="col-sm-4 text-muted fw-normal">Name</dt>
                            <dd class="col-sm-8">${escapeHtml(customerName)}</dd>

                            <dt class="col-sm-4 text-muted fw-normal">Phone</dt>
                            <dd class="col-sm-8">${escapeHtml(customerPhone)}</dd>
                            
                            <dt class="col-sm-4 text-muted fw-normal">Delivery Address</dt>
                            <dd class="col-sm-8">${escapeHtml(deliveryAddress || 'Local Address')}</dd>
                            <dt class="col-sm-4 text-muted fw-normal">Delivery Notes</dt>
                            <dd class="col-sm-8"><em class="text-muted small">${escapeHtml(deliveryNotes || 'No notes provided')}</em></dd>
                            
                            <dt class="col-sm-4 text-muted fw-normal">Delivery Agent</dt>
                            <dd class="col-sm-8">${deliveryPersonId ? `<span class="badge bg-secondary"><i class="bi bi-person-badge me-1"></i>${escapeHtml(deliveryAgentName || 'Unknown Agent')}</span>` : '<span class="text-muted small">Not Assigned</span>'}</dd>
                        </dl>
                    </div>
                    
                    ${timelineHtml}
                </div>

                <div class="col-md-5">
                    <div class="info-group mb-4 bg-light p-3 rounded shadow-sm">
                        <h5 class="border-bottom pb-2 mb-3">Payment Summary</h5>
                        <dl class="row mb-0">
                            <dt class="col-sm-6 text-muted fw-normal">Payment Mode</dt>
                            <dd class="col-sm-6 text-end">${escapeHtml(paymentMode || 'N/A')}</dd>

                            <dt class="col-sm-6 text-muted fw-normal">Total Amount</dt>
                            <dd class="col-sm-6 text-end fw-bold">₹${amount}</dd>

                            <dt class="col-sm-6 text-muted fw-normal small">Commission (10%)</dt>
                            <dd class="col-sm-6 text-end small text-danger">- ₹${commissionAmount}</dd>

                            <dt class="col-sm-6 text-muted fw-normal">Vendor Payout</dt>
                            <dd class="col-sm-6 text-end text-success fw-bold">₹${vendorAmount}</dd>
                        </dl>
                        
                        ${isRefunded || refundStatus === "Completed" ? `
                        <div class="mt-3 pt-2 border-top">
                            <div class="alert alert-success m-0 p-2 text-center fw-bold">
                                <i class="bi bi-arrow-return-left me-1"></i> Payment Refunded
                            </div>
                        </div>` : ''}

                        ${transactionId ? `
                        <div class="mt-3 pt-2 border-top">
                            <small class="text-muted d-block mb-1">Transaction ID</small>
                            <code class="small text-break">${escapeHtml(transactionId)}</code>
                        </div>` : ''}
                    </div>

                    <div class="info-group">
                        <h5 class="border-bottom pb-2 mb-3">Order Items</h5>
                        <div class="list-group list-group-flush">
                            ${items.map(i => `
                                <div class="list-group-item bg-transparent px-0 border-0">
                                    <div class="d-flex align-items-center">
                                        ${(i.imageUrl || i.ImageUrl) ? `<img src="${escapeHtml(i.imageUrl || i.ImageUrl)}" alt="${escapeHtml(i.name || i.Name)}" class="rounded me-3 shadow-sm border" style="width: 50px; height: 50px; object-fit: cover;" onerror="this.src='/images/placeholder.jpg'" />` : `<div class="bg-light rounded d-flex align-items-center justify-content-center me-3 text-muted border shadow-sm" style="width: 50px; height: 50px;"><i class="bi bi-egg-fried"></i></div>`}
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span class="fw-bold">${escapeHtml(i.name || i.Name)} <span class="text-muted small bg-light px-2 py-1 ms-2 rounded-pill shadow-sm">x${i.quantity || i.Quantity}</span></span>
                                            </div>
                                            ${(i.instructions || i.Instructions) ? `<small class="text-muted d-block mt-1"><i class="bi bi-chat-left-text me-1"></i>${escapeHtml(i.instructions || i.Instructions)}</small>` : ''}
                                        </div>
                                    </div>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                </div>
            </div>`;

            let btns = [];
            if (status === "Accepted") {
                btns.push('<button class="btn btn-warning action-btn" data-action="MarkReady" data-id="' + orderId + '"><i class="bi bi-check-circle me-1"></i> Mark Ready</button>');
            } else if (status === "Ready for Delivery") {
                btns.push('<button class="btn btn-primary action-btn" data-action="MarkPicked" data-id="' + orderId + '"><i class="bi bi-truck me-1"></i> Mark In Transit</button>');
            }

            if (status === "Accepted" || status === "Ready for Delivery") {
                if (!deliveryPersonId) {
                    btns.push('<button class="btn btn-info assign-delivery-btn" data-id="' + orderId + '"><i class="bi bi-person-plus me-1"></i> Assign Delivery</button>');
                }
            }

            if (status === "Cancelled" && (!isRefunded && refundStatus !== "Completed")) {
                // Add Razorpay Refund Mockup Button
                btns.push('<button class="btn btn-danger action-btn refund-btn" onclick="initiateRazorpayRefund(' + orderId + ', \'' + escapeHtml(customerName) + '\', ' + amount + ')"><i class="bi bi-arrow-counterclockwise me-1"></i> Refund via Razorpay</button>');
            }

            if (btns.length > 0) {
                html += `<div class="mt-4 pt-3 border-top d-flex gap-2 justify-content-end">${btns.join('')}</div>`;
            }

            container.innerHTML = html;
        }

        function renderTimeline(status) {
            if (status === 'Cancelled') {
                return `<div class="alert alert-danger text-center"><i class="bi bi-x-circle-fill me-2"></i> Order was Cancelled</div>`;
            }

            const steps = [
                { s: 'Placed', i: 'bi-bag-check-fill' },
                { s: 'Accepted', i: 'bi-shop' },
                { s: 'Ready for Delivery', i: 'bi-box-seam' },
                { s: 'In Transit', i: 'bi-truck' },
                { s: 'Delivered', i: 'bi-house-heart-fill' }
            ];

            let currentIndex = steps.findIndex(x => x.s === status);
            // Fallback rules if status string differs slightly
            if (status.includes("Pending")) currentIndex = 0;
            if (status === "Completed") currentIndex = 4;
            
            if (currentIndex === -1) currentIndex = 0; // Default

            let progressClass = `progress-${currentIndex + 1}`;
            
            let timelineHtml = `<div class="timeline-steps ${progressClass}">`;
            steps.forEach((step, idx) => {
                let activeClass = idx <= currentIndex ? 'active' : '';
                timelineHtml += `
                    <div class="timeline-step ${activeClass}">
                        <div class="timeline-icon"><i class="bi ${step.i}"></i></div>
                        <div class="timeline-label">${step.s}</div>
                    </div>`;
            });
            timelineHtml += `</div>`;
            return timelineHtml;
        }

        window.initiateRazorpayRefund = function(orderId, customer, amount) {
            Swal.fire({
                title: 'Processing Refund',
                html: 'Connecting to Razorpay gateway for <b>' + customer + '</b>...<br/><br/><h3 class="text-danger">- ₹' + amount + '</h3>',
                icon: 'info',
                timer: 2500,
                timerProgressBar: true,
                showConfirmButton: false,
                willOpen: () => {
                    Swal.showLoading();
                }
            }).then((result) => {
                // Trigger backend after simulation completes
                $.post({
                    url: '/Admin/UpdateRefundStatus',
                    data: { 
                        orderId: orderId, 
                        status: 'Completed',
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').length > 0 ? $('input[name="__RequestVerificationToken"]').val() : ''
                    },
                    success: function (res) {
                        if (res.success) {
                            Swal.fire("Refund Completed", "Amount reversed successfully to customer.", "success")
                            .then(() => fetchOrderDetails(orderId));
                        } else {
                            Swal.fire("Refund Failed", res.message || "An error occurred", "error");
                        }
                    }
                });
            });
        };

        fetchOrderDetails(orderId);
    })();
</script>
}
