@{
    ViewData["Title"] = "Order Details";
}
@section Styles {
    <link rel="stylesheet" href="~/css/admin-orders.css" asp-append-version="true" />
}

<div class="card-glass p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">Order Details</h3>
        <a asp-action="OrderManagement" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Back to Management
        </a>
    </div>

    <div id="orderDetailsContainer">
        <div class="text-center py-5" id="loadingState">
            <div class="spinner-border text-success" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">Fetching order details...</p>
        </div>
        <p class="text-muted d-none" id="initialState">Select an order from Order Management or refresh this page with ?orderId={orderId}.</p>
    </div>
</div>

@section Scripts {
<script>
    (function() {
        const orderId = '@(ViewBag.OrderId ?? "")';
        const container = document.getElementById('orderDetailsContainer');
        const loadingState = document.getElementById('loadingState');
        const initialState = document.getElementById('initialState');

        if (!orderId) {
            loadingState.classList.add('d-none');
            initialState.classList.remove('d-none');
            return;
        }

        function fetchOrderDetails(id, retryCount = 0) {
            fetch(`@Url.Action("GetOrderDetails","Admin")?orderId=${id}`)
                .then(r => {
                    if (!r.ok) throw new Error(`HTTP error! status: ${r.status}`);
                    return r.json();
                })
                .then(data => {
                    if (data.error) {
                        container.innerHTML = `<div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            ${data.error}
                        </div>`;
                        return;
                    }
                    renderOrder(data);
                })
                .catch(err => {
                    console.error("Fetch error:", err);
                    if (retryCount < 3) {
                        const delay = Math.pow(2, retryCount) * 1000;
                        setTimeout(() => fetchOrderDetails(id, retryCount + 1), delay);
                    } else {
                        container.innerHTML = `<div class="alert alert-danger">
                            <h5><i class="bi bi-wifi-off me-2"></i> Connection Error</h5>
                            <p>Unable to retrieve order details. Please check your network and try again.</p>
                            <button class="btn btn-outline-danger btn-sm mt-2" onclick="location.reload()">
                                <i class="bi bi-arrow-clockwise me-1"></i> Retry Now
                            </button>
                        </div>`;
                    }
                });
        }

        function escapeHtml(text) {
            if (text === null || text === undefined) return '';
            const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
            return text.toString().replace(/[&<>"']/g, function(m) { return map[m]; });
        }

        function renderOrder(data) {
            let html = `<div class="row g-4">
                <div class="col-md-7">
                    <div class="info-group mb-4">
                        <h5 class="border-bottom pb-2 mb-3">Order Information</h5>
                        <dl class="row mb-0">
                            <dt class="col-sm-4 text-muted fw-normal">Order ID</dt>
                            <dd class="col-sm-8 fw-bold">#${data.OrderId}</dd>

                            <dt class="col-sm-4 text-muted fw-normal">Status</dt>
                            <dd class="col-sm-8">
                                <span class="badge rounded-pill bg-info text-dark">${escapeHtml(data.Status)}</span>
                            </dd>

                            <dt class="col-sm-4 text-muted fw-normal">Type</dt>
                            <dd class="col-sm-8">
                                <span class="badge ${data.OrderType === 'Delivery' ? 'bg-purple' : 'bg-secondary'}">${data.OrderType}</span>
                            </dd>

                            <dt class="col-sm-4 text-muted fw-normal">Date & Time</dt>
                            <dd class="col-sm-8">${escapeHtml(data.OrderDateTime)}</dd>
                        </dl>
                    </div>

                    <div class="info-group">
                        <h5 class="border-bottom pb-2 mb-3">Customer Details</h5>
                        <dl class="row mb-0">
                            <dt class="col-sm-4 text-muted fw-normal">Name</dt>
                            <dd class="col-sm-8">${escapeHtml(data.CustomerName)}</dd>

                            <dt class="col-sm-4 text-muted fw-normal">Phone</dt>
                            <dd class="col-sm-8">${escapeHtml(data.CustomerPhone)}</dd>
                            
                            ${data.OrderType === 'Delivery' 
                                ? `<dt class="col-sm-4 text-muted fw-normal">Delivery Address</dt>
                                   <dd class="col-sm-8">${escapeHtml(data.DeliveryAddress)}</dd>
                                   <dt class="col-sm-4 text-muted fw-normal">Delivery Notes</dt>
                                   <dd class="col-sm-8"><em class="text-muted small">${escapeHtml(data.DeliveryNotes || 'No notes provided')}</em></dd>`
                                : `<dt class="col-sm-4 text-muted fw-normal">Pickup Slot</dt>
                                   <dd class="col-sm-8">${escapeHtml(data.PickupSlot)}</dd>`
                            }
                        </dl>
                    </div>
                </div>

                <div class="col-md-5">
                    <div class="info-group mb-4 bg-light p-3 rounded shadow-sm">
                        <h5 class="border-bottom pb-2 mb-3">Payment Summary</h5>
                        <dl class="row mb-0">
                            <dt class="col-sm-6 text-muted fw-normal">Payment Mode</dt>
                            <dd class="col-sm-6 text-end">${escapeHtml(data.PaymentMode || 'N/A')}</dd>

                            <dt class="col-sm-6 text-muted fw-normal">Total Amount</dt>
                            <dd class="col-sm-6 text-end fw-bold">₹${data.Amount}</dd>

                            <dt class="col-sm-6 text-muted fw-normal small">Commission (10%)</dt>
                            <dd class="col-sm-6 text-end small text-danger">- ₹${data.CommissionAmount}</dd>

                            <dt class="col-sm-6 text-muted fw-normal">Vendor Payout</dt>
                            <dd class="col-sm-6 text-end text-success fw-bold">₹${data.VendorAmount}</dd>
                        </dl>
                        ${data.TransactionId ? `
                        <div class="mt-3 pt-2 border-top">
                            <small class="text-muted d-block mb-1">Transaction ID</small>
                            <code class="small text-break">${escapeHtml(data.TransactionId)}</code>
                        </div>` : ''}
                    </div>

                    <div class="info-group">
                        <h5 class="border-bottom pb-2 mb-3">Order Items</h5>
                        <div class="list-group list-group-flush">
                            ${(data.Items || []).map(i => `
                                <div class="list-group-item bg-transparent px-0 border-0">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span>${escapeHtml(i.Name)} <span class="text-muted small">x${i.Quantity}</span></span>
                                    </div>
                                    ${i.Instructions ? `<small class="text-muted d-block mt-1"><i class="bi bi-chat-left-text me-1"></i>${escapeHtml(i.Instructions)}</small>` : ''}
                                </div>
                            `).join('')}
                        </div>
                    </div>
                </div>
            </div>`;

            let btns = [];
            if (data.Status === "Accepted") {
                btns.push('<button class="btn btn-warning action-btn" data-action="MarkReady" data-id="' + data.OrderId + '"><i class="bi bi-check-circle me-1"></i> Mark Ready</button>');
            } else if (data.Status === "Ready for Pickup" && data.OrderType === "Pickup") {
                btns.push('<button class="btn btn-primary action-btn" data-action="MarkPicked" data-id="' + data.OrderId + '"><i class="bi bi-hand-thumbs-up me-1"></i> Mark Picked</button>');
            } else if (data.Status === "Ready for Delivery" && data.OrderType === "Delivery") {
                btns.push('<button class="btn btn-primary action-btn" data-action="MarkPicked" data-id="' + data.OrderId + '"><i class="bi bi-truck me-1"></i> Mark In Transit</button>');
            }

            if (data.OrderType === "Delivery" && (data.Status === "Accepted" || data.Status === "Ready for Delivery")) {
                if (!data.DeliveryPersonId) {
                    btns.push('<button class="btn btn-info assign-delivery-btn" data-id="' + data.OrderId + '"><i class="bi bi-person-plus me-1"></i> Assign Delivery</button>');
                }
            }

            if (btns.length > 0) {
                html += `<div class="mt-4 pt-3 border-top d-flex gap-2 justify-content-end">${btns.join('')}</div>`;
            }

            container.innerHTML = html;
        }

        fetchOrderDetails(orderId);
    })();
</script>
}
