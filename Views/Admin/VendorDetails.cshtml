@model NUTRIBITE.Models.VendorSignup
@{
    ViewData["Title"] = "Vendor Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    
    var orders = ViewBag.Orders as List<NUTRIBITE.Models.OrderTable> ?? new List<NUTRIBITE.Models.OrderTable>();
    var foods = ViewBag.Foods as List<NUTRIBITE.Models.Food> ?? new List<NUTRIBITE.Models.Food>();
    var ratings = ViewBag.Ratings as List<NUTRIBITE.Models.Rating> ?? new List<NUTRIBITE.Models.Rating>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a href="@Url.Action("ManageVendor", "Admin")" class="text-decoration-none text-muted mb-2 d-inline-block">
            <i class="bi bi-arrow-left me-1"></i> Back to Vendors
        </a>
        <h2 class="fw-bold mb-0">Vendor Details</h2>
    </div>
</div>

<div class="row g-4">
    <!-- Left Column: Profile -->
    <div class="col-lg-4">
        <!-- Profile Card -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body text-center p-4">
                <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center mx-auto mb-3 shadow" style="width: 100px; height: 100px; font-size: 2.5rem;">
                    @(Model.VendorName?.Substring(0, 1).ToUpper() ?? "V")
                </div>
                <h4 class="fw-bold mb-1">@Model.VendorName</h4>
                <div class="text-dark fw-medium mb-1">
                    <i class="bi bi-person-badge text-primary me-1"></i> 
                    @(string.IsNullOrEmpty(Model.OwnerName) ? "Owner Details Not Available" : Model.OwnerName)
                </div>
                <p class="text-muted mb-3"><i class="bi bi-envelope text-secondary me-1"></i> @Model.Email</p>
                
                <div class="d-flex justify-content-between text-start border-top pt-3 mt-3">
                    <div>
                        <small class="text-muted d-block fw-bold mb-1">Phone</small>
                        <span>@(string.IsNullOrEmpty(Model.Phone) ? "Not provided" : Model.Phone)</span>
                    </div>
                    <div class="text-end">
                        <small class="text-muted d-block fw-bold mb-1">Joined</small>
                        <span>@(Model.CreatedAt?.ToString("MMM dd, yyyy") ?? "Unknown")</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                <h6 class="fw-bold mb-0"><i class="bi bi-shop text-primary me-2"></i>Store Info</h6>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                        <span class="text-muted">Status</span>
                        @if(Model.IsApproved){
                            <span class="badge bg-success">Approved</span>
                        }else{
                            <span class="badge bg-warning">Pending</span>
                        }
                    </li>
                    <li class="list-group-item px-0 d-flex flex-column">
                        <span class="text-muted mb-1">Address</span>
                        <span class="fw-bold text-dark">@Model.Address</span>
                    </li>
                    <li class="list-group-item px-0 d-flex flex-column">
                        <span class="text-muted mb-1">UPI ID</span>
                        <span class="fw-bold text-dark">@Model.UpiId</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Right Column: Activity & Orders -->
    <div class="col-lg-8">
        <!-- Stats overview -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm bg-primary text-white">
                    <div class="card-body p-3 d-flex align-items-center">
                        <div class="fs-1 me-3 opacity-75"><i class="bi bi-bag-check"></i></div>
                        <div>
                            <h3 class="mb-0 fw-bold">@orders.Count</h3>
                            <small class="text-white-50 text-uppercase fw-bold">Total Orders</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm bg-success text-white">
                    <div class="card-body p-3 d-flex align-items-center">
                        <div class="fs-1 me-3 opacity-75"><i class="bi bi-currency-rupee"></i></div>
                        <div>
                            <h3 class="mb-0 fw-bold">₹@orders.Where(o => o.Status != "Cancelled").Sum(o => o.TotalAmount)</h3>
                            <small class="text-white-50 text-uppercase fw-bold">Gross Sales</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm bg-info text-white">
                    <div class="card-body p-3 d-flex align-items-center">
                        <div class="fs-1 me-3 opacity-75"><i class="bi bi-cup-hot"></i></div>
                        <div>
                            <h3 class="mb-0 fw-bold">@foods.Count</h3>
                            <small class="text-white-50 text-uppercase fw-bold">Menu Items</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <ul class="nav nav-tabs mb-3" id="vendorTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-bold" id="orders-tab" data-bs-toggle="tab" data-bs-target="#orders" type="button" role="tab">Fulfillment History</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold" id="foods-tab" data-bs-toggle="tab" data-bs-target="#foods" type="button" role="tab">Menu Profile</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold" id="ratings-tab" data-bs-toggle="tab" data-bs-target="#ratings" type="button" role="tab">User Ratings</button>
            </li>
        </ul>
        
        <div class="tab-content" id="vendorTabsContent">
            <!-- Orders Tab -->
            <div class="tab-pane fade show active" id="orders" role="tabpanel">
                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-3">Order ID</th>
                                    <th>Date</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in orders.Take(20))
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold">
                                            <a href="@Url.Action("OrderDetails", "Admin", new { orderId = order.OrderId })">#@order.OrderId</a>
                                        </td>
                                        <td>@(order.CreatedAt?.ToString("dd MMM yyyy"))</td>
                                        <td>₹@order.TotalAmount</td>
                                        <td>
                                            @if (order.Status == "Cancelled")
                                            {
                                                <span class="badge bg-danger">Cancelled</span>
                                            }
                                            else if (order.Status == "Delivered")
                                            {
                                                <span class="badge bg-success">Delivered</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">@order.Status</span>
                                            }
                                        </td>
                                    </tr>
                                }
                                @if (!orders.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">No orders found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Foods Tab -->
            <div class="tab-pane fade" id="foods" role="tabpanel">
                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-3">Food Name</th>
                                    <th>Price</th>
                                    <th>Calories</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var food in foods)
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold">@food.Name</td>
                                        <td>₹@food.Price</td>
                                        <td>@food.Calories kcal</td>
                                        <td>
                                            @if (food.Status == "Active")
                                            {
                                                <span class="badge bg-success">Available</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Hidden</span>
                                            }
                                        </td>
                                    </tr>
                                }
                                @if (!foods.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">No active menu items.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Ratings Tab -->
            <div class="tab-pane fade" id="ratings" role="tabpanel">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        @foreach (var rating in ratings)
                        {
                            <div class="mb-3 border-bottom pb-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <h6 class="fw-bold mb-0">@(rating.User?.Name ?? "Anonymous User")</h6>
                                    <small class="text-muted">@(rating.Date?.ToString("dd MMM yyyy") ?? "-")</small>
                                </div>
                                <div class="mb-2">
                                    @for(int i=0; i<5; i++){
                                        if (i < (rating.Ratings ?? 0)) {
                                            <i class="bi bi-star-fill text-warning"></i>
                                        } else {
                                            <i class="bi bi-star text-muted"></i>
                                        }
                                    }
                                </div>
                                <p class="mb-0 text-muted small">@rating.Message</p>
                            </div>
                        }
                        @if (!ratings.Any())
                        {
                            <div class="text-center py-4 text-muted">No ratings or reviews mapped to this vendor.</div>
                        }
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
