@{
    ViewData["Title"] = "Vendor Payouts Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark">Vendor Payouts</h2>
            <p class="text-muted">Manage and verify payments to vendors across the platform.</p>
        </div>
        <div class="d-flex gap-2">
            <input type="month" id="payoutMonthPicker" class="form-control" value="@DateTime.Now.AddMonths(-1).ToString("yyyy-MM")" />
            <button id="btnProcessMonthly" class="btn btn-success text-nowrap">
                <i class="bi bi-gear-fill"></i> Process Monthly
            </button>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="card border-0 shadow-sm p-3 mb-4">
        <div class="row g-3 align-items-center">
            <div class="col-md-3">
                <label class="small fw-bold text-muted mb-1">Status</label>
                <select id="statusFilter" class="form-select">
                    <option value="">All Statuses</option>
                    <option value="Pending" selected>Pending</option>
                    <option value="PaidToVendor">Paid</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="small fw-bold text-muted mb-1">Search Vendor</label>
                <input type="text" id="vendorSearch" class="form-control" placeholder="Vendor Name or Email..." />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button id="applyFilters" class="btn btn-primary w-100">Apply Filters</button>
            </div>
        </div>
    </div>

    <!-- Payouts Table -->
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Details</th>
                        <th>Vendor</th>
                        <th>Period</th>
                        <th>Total Sales</th>
                        <th>Commission (10%)</th>
                        <th>Vendor Amount</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody id="payoutsBody">
                    <tr>
                        <td colspan="8" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        
        <div class="card-footer bg-white border-0 py-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="text-muted small">Showing <span id="showingCount">0</span> of <span id="totalCount">0</span> payouts</div>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0" id="pagination">
                        <!-- Pagination injected here -->
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="payoutModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Confirm Payout</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to mark this payout as <strong>Paid</strong>? This action will update the vendor's records and cannot be undone.</p>
                <div class="p-3 bg-light rounded">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Vendor:</span>
                        <span id="modalVendor" class="fw-bold"></span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Amount:</span>
                        <span id="modalAmount" class="fw-bold text-success"></span>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmPayoutBtn" class="btn btn-success px-4">Confirm Payment</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentPage = 1;
        const pageSize = 20;
        let selectedPayoutId = null;
        const payoutModal = new bootstrap.Modal(document.getElementById('payoutModal'));

        async function loadPayouts(page = 1) {
            const status = document.getElementById('statusFilter').value;
            const search = document.getElementById('vendorSearch').value;
            const body = document.getElementById('payoutsBody');
            
            // Show loading spinner
            body.innerHTML = `<tr><td colspan="7" class="text-center py-5">
                <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
                <div class="mt-2 text-muted small">Loading payouts...</div>
            </td></tr>`;

            try {
                const response = await fetch(`/api/admin/payouts/list?page=${page}&pageSize=${pageSize}&status=${status}&search=${search}`);
                
                if (response.ok) {
                    const data = await response.json();
                    renderPayouts(data.items);
                    renderPagination(data.totalItems, data.page, data.pageSize);
                    document.getElementById('showingCount').textContent = data.items.length;
                    document.getElementById('totalCount').textContent = data.totalItems;
                    currentPage = data.page;
                } else if (response.status === 401) {
                    body.innerHTML = '<tr><td colspan="7" class="text-center py-5"><div class="text-danger fw-bold">Unauthorized. Please log in as Admin.</div></td></tr>';
                } else {
                    body.innerHTML = '<tr><td colspan="7" class="text-center py-5"><div class="text-danger">Error loading data (Status: ' + response.status + '). Please try again.</div></td></tr>';
                }
            } catch (error) {
                console.error('Error loading payouts:', error);
                body.innerHTML = '<tr><td colspan="7" class="text-center py-5"><div class="text-danger">Network error. Please check your connection.</div></td></tr>';
            }
        }

        function renderPayouts(payouts) {
            const body = document.getElementById('payoutsBody');
            if (payouts.length === 0) {
                body.innerHTML = '<tr><td colspan="8" class="text-center py-5">No payouts found matching your filters.</td></tr>';
                return;
            }

            body.innerHTML = payouts.map(p => `
                <tr>
                    <td class="ps-4">
                        ${p.orderId ? `<span class="badge bg-light text-dark border">Order #${p.orderId}</span>` : `<span class="badge bg-primary">Monthly Aggregate</span>`}
                        <div class="text-muted extra-small">ID: #${p.id}</div>
                    </td>
                    <td>
                        <div class="fw-bold">${p.vendorName}</div>
                        <div class="text-muted small">${p.vendorEmail}</div>
                    </td>
                    <td>
                        <div class="fw-bold">${p.payoutMonth || 'N/A'}</div>
                    </td>
                    <td>₹${p.totalSales.toFixed(2)}</td>
                    <td class="text-danger">- ₹${p.commissionDeducted.toFixed(2)}</td>
                    <td class="fw-bold text-success">₹${p.amount.toFixed(2)}</td>
                    <td>
                        <span class="badge ${p.status === 'Pending' ? 'bg-warning-subtle text-warning' : 'bg-success-subtle text-success'} rounded-pill px-3">
                            ${p.status === 'PaidToVendor' ? 'Paid' : p.status}
                        </span>
                    </td>
                    <td class="text-end pe-4">
                        ${p.status === 'Pending' ? `
                            <button class="btn btn-sm btn-outline-success rounded-pill px-3" onclick="openPayoutModal(${p.id}, '${p.vendorName}', ${p.amount})">
                                Mark as Paid
                            </button>
                        ` : `
                            <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" disabled>
                                Already Paid
                            </button>
                        `}
                    </td>
                </tr>
            `).join('');
        }

        function renderPagination(totalItems, page, size) {
            const totalPages = Math.ceil(totalItems / size);
            const pagination = document.getElementById('pagination');
            
            let html = '';
            for (let i = 1; i <= totalPages; i++) {
                html += `
                    <li class="page-item ${i === page ? 'active' : ''}">
                        <button class="page-link" onclick="loadPayouts(${i})">${i}</button>
                    </li>
                `;
            }
            pagination.innerHTML = html;
        }

        function openPayoutModal(id, vendor, amount) {
            selectedPayoutId = id;
            document.getElementById('modalVendor').textContent = vendor;
            document.getElementById('modalAmount').textContent = `₹${amount.toFixed(2)}`;
            payoutModal.show();
        }

        document.getElementById('confirmPayoutBtn').addEventListener('click', async () => {
            if (!selectedPayoutId) return;
            
            const btn = document.getElementById('confirmPayoutBtn');
            btn.disabled = true;
            btn.textContent = 'Processing...';

            try {
                const response = await fetch(`/api/admin/payouts/${selectedPayoutId}/mark-paid`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                if (response.ok) {
                    payoutModal.hide();
                    loadPayouts(currentPage);
                } else {
                    alert('Failed to process payout. Please try again.');
                }
            } catch (error) {
                console.error('Error processing payout:', error);
            } finally {
                btn.disabled = false;
                btn.textContent = 'Confirm Payment';
            }
        });

        document.getElementById('applyFilters').addEventListener('click', () => loadPayouts(1));

        document.getElementById('btnProcessMonthly').addEventListener('click', async () => {
            const val = document.getElementById('payoutMonthPicker').value;
            if(!val) return;
            const [year, month] = val.split('-');
            
            if(!confirm(`Are you sure you want to process monthly payouts for ${val}?`)) return;

            const btn = document.getElementById('btnProcessMonthly');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Processing...';

            try {
                const response = await fetch(`/Admin/ProcessMonthlyPayouts?year=${year}&month=${month}`, { method: 'POST' });
                const res = await response.json();
                alert(res.message);
                if(res.success) loadPayouts(1);
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred.');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-gear-fill"></i> Process Monthly';
            }
        });

        // Initial Load
        loadPayouts();
    </script>
}
