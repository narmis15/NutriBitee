        @@keyframes pulse-blue-anim {
            0% { box-shadow: 0 0 0 0 rgba(13, 202, 240, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(13, 202, 240, 0); }
            100% { box-shadow: 0 0 0 0 rgba(13, 202, 240, 0); }
        }
