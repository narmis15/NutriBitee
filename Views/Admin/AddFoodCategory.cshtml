@{
    ViewData["Title"] = "Add Food Category";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold mb-1">Add Food Category</h2>
                    <p class="text-muted small mb-0">Create new categories to organize your food inventory.</p>
                </div>
                <a asp-action="ViewCategory" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Back to List
                </a>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="AddFoodCategory" method="post" enctype="multipart/form-data">
                        
                        <div class="row g-4">
                            <!-- PRODUCT CATEGORY -->
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Product Category</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-tag"></i></span>
                                    <select name="ProductCategory" class="form-select" id="productCatSelect">
                                        <option>Veg</option>
                                        <option>Non-Veg</option>
                                        <option>Eggitarian</option>
                                        <option>Jain</option>
                                        <option>Vegan</option>
                                        <option value="Other">Other</option>
                                    </select>
                                    <input type="text" name="CustomProductCategory" id="customProductCat" 
                                           class="form-control d-none" placeholder="Enter custom category name" />
                                </div>
                            </div>

                            <!-- MEAL CATEGORY -->
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Meal Category</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-egg-fried"></i></span>
                                    <select name="MealCategory" class="form-select" id="mealCatSelect">
                                        @if (ViewBag.SpecifiedCategories != null)
                                        {
                                            foreach (var cat in (string[])ViewBag.SpecifiedCategories)
                                            {
                                                <option>@cat</option>
                                            }
                                        }
                                        else
                                        {
                                            <option>Special Thali</option>
                                            <option>Deluxe Thali</option>
                                            <option>Classic Thali</option>
                                            <option>Comfort Thali</option>
                                            <option>Standard Thali</option>
                                            <option>Jain Thali</option>
                                            <option>Rice Combo</option>
                                            <option>Healthy</option>
                                            <option>Breakfast</option>
                                            <option>Low Calorie Meals</option>
                                            <option>Protein Meal</option>
                                            <option>Salads</option>
                                        }
                                        <option value="Other">Other</option>
                                    </select>
                                    <input type="text" name="CustomMealCategory" id="customMealCat" 
                                           class="form-control d-none" placeholder="Enter custom meal name" />
                                </div>
                            </div>

                            <!-- IMAGE UPLOAD -->
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Category Image</label>
                                <div class="upload-zone p-4 text-center border-dashed rounded bg-light">
                                    <i class="bi bi-cloud-arrow-up display-4 text-primary mb-2"></i>
                                    <input type="file" name="CategoryImage" class="form-control mt-2" accept="image/*" />
                                    <p class="small text-muted mt-2 mb-0">Allowed formats: JPG, PNG, WEBP (Max 2MB)</p>
                                </div>
                            </div>

                            <div class="col-12 mt-4">
                                <button type="submit" class="btn btn-primary px-5 py-2 fw-bold">
                                    <i class="bi bi-check-circle me-2"></i> Create Category
                                </button>
                            </div>
                        </div>
                    </form>

                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success mt-4 border-0 shadow-sm d-flex align-items-center">
                            <i class="bi bi-check-circle-fill me-2 fs-4"></i>
                            <div>@ViewBag.Success</div>
                        </div>
                    }
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger mt-4 border-0 shadow-sm d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
                            <div>@ViewBag.Error</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .border-dashed {
        border: 2px dashed #dee2e6 !important;
    }
    .upload-zone:hover {
        border-color: #22c55e !important;
        background-color: rgba(34, 197, 94, 0.05) !important;
    }
    .form-select:focus, .form-control:focus {
        border-color: #22c55e;
        box-shadow: 0 0 0 0.25rem rgba(34, 197, 94, 0.25);
    }
</style>

@section Scripts {
    <script>
        document.getElementById('productCatSelect').addEventListener('change', function() {
            const customInput = document.getElementById('customProductCat');
            if (this.value === 'Other') {
                customInput.classList.remove('d-none');
                customInput.required = true;
            } else {
                customInput.classList.add('d-none');
                customInput.required = false;
            }
        });

        document.getElementById('mealCatSelect').addEventListener('change', function() {
            const customInput = document.getElementById('customMealCat');
            if (this.value === 'Other') {
                customInput.classList.remove('d-none');
                customInput.required = true;
            } else {
                customInput.classList.add('d-none');
                customInput.required = false;
            }
        });
    </script>
}
