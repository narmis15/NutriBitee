@{
    ViewData["Title"] = "Delivery Optimization Plan — NutriBite";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark">Delivery Optimization Plan</h2>
            <p class="text-muted">Data-driven strategy to enhance logistics performance and reduce operational overhead.</p>
        </div>
        <div class="btn-group">
            <button class="btn btn-outline-primary"><i class="bi bi-download"></i> Export PDF</button>
            <button class="btn btn-primary"><i class="bi bi-play-fill"></i> Run Simulation</button>
        </div>
    </div>

    <!-- KPI OVERVIEW -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4">
                <div class="d-flex justify-content-between">
                    <h6 class="text-muted text-uppercase small fw-bold">Throughput (Orders/Hr)</h6>
                    <span class="badge bg-success-subtle text-success">+15% Target</span>
                </div>
                <div class="d-flex align-items-end mt-2">
                    <h3 class="mb-0 fw-bold">42.5</h3>
                    <span class="ms-2 text-muted small">Current: 37.0</span>
                </div>
                <div class="progress mt-3" style="height: 6px;">
                    <div class="progress-bar bg-success" style="width: 85%;"></div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4">
                <div class="d-flex justify-content-between">
                    <h6 class="text-muted text-uppercase small fw-bold">Avg. Delivery Time</h6>
                    <span class="badge bg-primary-subtle text-primary">-20% Target</span>
                </div>
                <div class="d-flex align-items-end mt-2">
                    <h3 class="mb-0 fw-bold">28m</h3>
                    <span class="ms-2 text-muted small">Current: 35m</span>
                </div>
                <div class="progress mt-3" style="height: 6px;">
                    <div class="progress-bar bg-primary" style="width: 75%;"></div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4">
                <div class="d-flex justify-content-between">
                    <h6 class="text-muted text-uppercase small fw-bold">Operational Cost/Order</h6>
                    <span class="badge bg-danger-subtle text-danger">-10% Target</span>
                </div>
                <div class="d-flex align-items-end mt-2">
                    <h3 class="mb-0 fw-bold">₹18.50</h3>
                    <span class="ms-2 text-muted small">Current: ₹20.55</span>
                </div>
                <div class="progress mt-3" style="height: 6px;">
                    <div class="progress-bar bg-danger" style="width: 60%;"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- BOTTLENECK ANALYSIS -->
        <div class="col-lg-7 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Bottleneck Analysis & Insights</h5>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <h6 class="fw-bold text-primary"><i class="bi bi-exclamation-triangle-fill me-2"></i>Peak Hour Congestion</h6>
                        <p class="small text-muted">Orders between 12 PM - 2 PM experience a 40% increase in prep time, delaying dispatch.</p>
                        <div class="alert alert-warning border-0 small">
                            <strong>Recommendation:</strong> Reallocate 2 additional prep staff from the evening shift to lunch shift.
                        </div>
                    </div>
                    <div class="mb-4">
                        <h6 class="fw-bold text-primary"><i class="bi bi-geo-alt-fill me-2"></i>Route Inefficiency</h6>
                        <p class="small text-muted">Current manual assignment leads to 15% overlap in delivery routes within the same sectors.</p>
                        <div class="alert alert-info border-0 small">
                            <strong>Technology Upgrade:</strong> Implement Automated Multi-Stop Route Optimization (VRP).
                        </div>
                    </div>
                    <div>
                        <h6 class="fw-bold text-primary"><i class="bi bi-people-fill me-2"></i>Idle Delivery Fleet</h6>
                        <p class="small text-muted">Outside peak hours, 30% of the fleet remains idle, increasing fixed operational costs.</p>
                        <div class="alert alert-success border-0 small">
                            <strong>Strategy:</strong> Introduce "Flash Sales" for low-demand periods to boost non-peak volume.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- IMPLEMENTATION ROADMAP -->
        <div class="col-lg-5 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold">Implementation Roadmap (Q2)</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item p-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-bold">Week 1-2: Baseline Sync</div>
                                    <div class="text-muted small">Sync historical data and setup real-time performance tracking.</div>
                                </div>
                                <span class="badge bg-success rounded-pill">Done</span>
                            </div>
                        </li>
                        <li class="list-group-item p-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-bold text-primary">Week 3-5: Tech Integration</div>
                                    <div class="text-muted small">Deploy Google Maps Matrix API for smart route clustering.</div>
                                </div>
                                <span class="badge bg-warning text-dark rounded-pill">In Progress</span>
                            </div>
                        </li>
                        <li class="list-group-item p-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-bold">Week 6-8: Fleet Reallocation</div>
                                    <div class="text-muted small">Adjust shift timings and incentives based on sector demand.</div>
                                </div>
                                <span class="badge bg-light text-dark rounded-pill">Planned</span>
                            </div>
                        </li>
                        <li class="list-group-item p-3 border-0">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-bold">Week 9-12: Scale & Audit</div>
                                    <div class="text-muted small">Audit performance against 15/20/10 targets and refine.</div>
                                </div>
                                <span class="badge bg-light text-dark rounded-pill">Planned</span>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- RISK MITIGATION -->
    <div class="card border-0 shadow-sm mt-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold">Risk Mitigation Checklist</h5>
        </div>
        <div class="card-body">
            <div class="row row-cols-1 row-cols-md-2 g-3">
                <div class="col">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" checked disabled>
                        <label class="form-check-label small">Ensure redundant backup for Route Optimization API</label>
                    </div>
                </div>
                <div class="col">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" checked disabled>
                        <label class="form-check-label small">Establish driver feedback loop for "Ready for Delivery" UX</label>
                    </div>
                </div>
                <div class="col">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" disabled>
                        <label class="form-check-label small">Verify compliance with labor laws for shift reallocation</label>
                    </div>
                </div>
                <div class="col">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" disabled>
                        <label class="form-check-label small">Conduct weekly cost audit to prevent budget overruns</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .extra-small { font-size: 0.7rem; }
        .bg-success-subtle { background-color: #dcfce7 !important; }
        .bg-primary-subtle { background-color: #dbeafe !important; }
        .bg-danger-subtle { background-color: #fee2e2 !important; }
    </style>
}
