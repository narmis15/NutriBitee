@model IEnumerable<NUTRIBITE.Models.VendorSignup>

@{
    ViewData["Title"] = "Manage Vendors";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-manage-vendors.css" asp-append-version="true" />
}
<h2 class="page-title">Manage Vendors</h2>

<div class="admin-full-wrapper">

    <div class="table-responsive">
        <table class="admin-table">

            <thead>
                <tr>
                    <th>ID</th>
                    <th>Vendor</th>
                    <th>Email</th>
                    <th>Created</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var vendor in Model)
                {
                    <tr>

                        <td>#@vendor.VendorId</td>

                        <td>
                            <div class="vendor-info">
                                <div class="vendor-avatar">
                                    @vendor.VendorName.Substring(0, 1).ToUpper()
                                </div>
                                <div class="vendor-name">
                                    @vendor.VendorName
                                </div>
                            </div>
                        </td>

                        <td>@vendor.Email</td>

                        <td>@(vendor.CreatedAt.HasValue ? vendor.CreatedAt.Value.ToString("dd MMM yyyy") : "-")</td>

                        <td>
                            @if (vendor.IsApproved)
                            {
                                <span class="status-badge approved">Approved</span>
                            }
                            else if (vendor.IsRejected)
                            {
                                <span class="status-badge rejected">Rejected</span>
                            }
                            else
                            {
                                <span class="status-badge pending">Pending</span>
                            }
                        </td>

                    </tr>
                }
            </tbody>

        </table>
    </div>

</div>