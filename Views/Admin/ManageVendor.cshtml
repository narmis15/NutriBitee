@model IEnumerable<NUTRIBITE.Models.VendorSignup>

@{
    ViewData["Title"] = "Manage Vendors";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Vendor Management</h2>
            <p class="text-muted small mb-0">Monitor and manage registered vendors on your platform.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="NewVendorRequest" class="btn btn-outline-primary rounded-pill px-4 fw-bold">
                <i class="bi bi-person-plus me-1"></i> New Requests
            </a>
            <a asp-action="Payouts" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                <i class="bi bi-wallet2 me-1"></i> Vendor Payouts
            </a>
        </div>
    </div>

    <!-- Stats Row -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3 bg-white text-center h-100">
                <div class="text-muted small fw-bold text-uppercase mb-1">Total Vendors</div>
                <div class="h3 fw-bold text-primary mb-0">@ViewBag.TotalVendors</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3 bg-white text-center h-100">
                <div class="text-muted small fw-bold text-uppercase mb-1">Approved</div>
                <div class="h3 fw-bold text-success mb-0">@ViewBag.ApprovedVendors</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3 bg-white text-center h-100">
                <div class="text-muted small fw-bold text-uppercase mb-1">Pending</div>
                <div class="h3 fw-bold text-warning mb-0">@ViewBag.PendingVendors</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3 bg-white text-center h-100">
                <div class="text-muted small fw-bold text-uppercase mb-1">Rejected</div>
                <div class="h3 fw-bold text-danger mb-0">@ViewBag.RejectedVendors</div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Vendor Details</th>
                            <th>Contact Info</th>
                            <th>Joined On</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var vendor in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">#@vendor.VendorId</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="vendor-avatar-circle me-3">
                                            @vendor.VendorName.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-semibold">@vendor.VendorName</div>
                                            <div class="text-muted extra-small">
                                                <i class="bi bi-person text-primary"></i> 
                                                @(string.IsNullOrEmpty(vendor.OwnerName) ? (vendor.Description ?? "Kitchen Partner") : vendor.OwnerName)
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="small">
                                        <div class="text-dark">@vendor.Email</div>
                                        <div class="text-muted">@(vendor.Phone ?? "No Phone")</div>
                                    </div>
                                </td>
                                <td class="small text-muted">
                                    @(vendor.CreatedAt.HasValue ? vendor.CreatedAt.Value.ToString("dd MMM yyyy") : "-")
                                </td>
                                <td>
                                    @if (vendor.IsApproved)
                                    {
                                        <span class="badge bg-soft-success text-success border border-success border-opacity-25 rounded-pill px-3">Approved</span>
                                    }
                                    else if (vendor.IsRejected)
                                    {
                                        <span class="badge bg-soft-danger text-danger border border-danger border-opacity-25 rounded-pill px-3">Rejected</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-soft-warning text-warning border border-warning border-opacity-25 rounded-pill px-3">Pending</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-light rounded-circle p-1" type="button" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 small">
                                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="VendorDetails" asp-route-id="@vendor.VendorId"><i class="bi bi-eye me-2"></i> View Details</a></li>
                                            @if (!vendor.IsApproved && !vendor.IsRejected)
                                            {
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <form asp-action="ApproveVendor" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@vendor.VendorId" />
                                                        <button type="submit" class="dropdown-item text-success"><i class="bi bi-check-circle me-2"></i> Approve</button>
                                                    </form>
                                                </li>
                                                <li>
                                                    <form asp-action="RejectVendor" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@vendor.VendorId" />
                                                        <button type="submit" class="dropdown-item text-danger"><i class="bi bi-x-circle me-2"></i> Reject</button>
                                                    </form>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .vendor-avatar-circle {
        width: 38px;
        height: 38px;
        background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.9rem;
    }
    .bg-soft-success { background-color: rgba(34, 197, 94, 0.1); }
    .bg-soft-danger { background-color: rgba(239, 68, 68, 0.1); }
    .bg-soft-warning { background-color: rgba(245, 158, 11, 0.1); }
    .extra-small { font-size: 0.75rem; }
    .dropdown-item { padding: 0.5rem 1rem; }
    .dropdown-item:hover { background-color: rgba(0,0,0,0.03); }
</style>