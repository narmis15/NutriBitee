        function updateChartVisibility() {
            // Ensure all chart containers are visible
            ['revenueChart','ordersChart','lossChart','userRegChart','statusDistChart','categoryChart','vendorFinanceChart']
                .forEach(id => { const el = document.getElementById(id); if (el) el.closest('.chart-container').style.display = ''; });
        }

        function renderAlerts(alerts) {
            const feed = document.getElementById('activityFeed');
            feed.innerHTML = alerts.map(a => `
                <div class="activity-item">
                    <div class="activity-dot bg-${getAlertColor(a.type)}"></div>
                    <div class="activity-content">
                        <div class="activity-action">${a.type}</div>
                        <div class="activity-details">${a.message}</div>
                    </div>
                    <div class="activity-time">${a.time}</div>
                </div>
            `).join('');
        }

        function getAlertColor(type) {
            type = type.toLowerCase();
            if (type.includes('order')) return 'success';
            if (type.includes('payment')) return 'primary';
            if (type.includes('security') || type.includes('cancelled')) return 'danger';
            if (type.includes('system')) return 'info';
            return 'warning';
        }

        document.getElementById('refreshData').addEventListener('click', () => updateDashboard(true));
        document.getElementById('dashboardPeriod').addEventListener('change', updateDashboard);

        // Initial load
        document.addEventListener('DOMContentLoaded', updateDashboard);
        
        // Auto refresh every 5 minutes
        setInterval(updateDashboard, 300000);
    </script>
