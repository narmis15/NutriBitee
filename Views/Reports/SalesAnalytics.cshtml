@{
    ViewData["Title"] = "Sales Analytics";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap');

    .premium-admin-page { 
        padding: 30px; 
        background: #f8fafc; 
        min-height: calc(100vh - 60px); 
        font-family: 'Outfit', sans-serif;
        color: #334155;
    }
    
    .premium-title {
        font-size: 1.85rem;
        font-weight: 700;
        background: linear-gradient(to right, #0f172a, #475569);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -0.5px;
    }

    /* Cards */
    .glass-card {
        background: #ffffff;
        border: 1px solid rgba(0, 0, 0, 0.04);
        border-radius: 20px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
        transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    }
    
    .glass-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
        border-color: rgba(0, 0, 0, 0.08);
    }

    /* KPI Widgets */
    .kpi-widget { position: relative; overflow: hidden; padding: 26px; height: 100%; display: flex; flex-direction: column; justify-content: center;}
    
    .kpi-glow {
        position: absolute;
        width: 160px;
        height: 160px;
        border-radius: 50%;
        filter: blur(55px);
        opacity: 0.15;
        top: -50px;
        right: -40px;
        transition: opacity 0.4s ease;
        pointer-events: none;
    }
    .kpi-widget:hover .kpi-glow { opacity: 0.35; }

    .glow-primary { background: #3b82f6; }
    .glow-success { background: #10b981; }
    .glow-danger { background: #ef4444; }

    .kpi-icon-wrapper {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        flex-shrink: 0;
    }
    
    .icon-primary { background: rgba(59, 130, 246, 0.1); color: #2563eb; border: 1px solid rgba(59, 130, 246, 0.2); }
    .icon-success { background: rgba(16, 185, 129, 0.1); color: #059669; border: 1px solid rgba(16, 185, 129, 0.2); }
    .icon-danger { background: rgba(239, 68, 68, 0.1); color: #dc2626; border: 1px solid rgba(239, 68, 68, 0.2); }

    .kpi-value { font-size: 2.2rem; font-weight: 700; color: #0f172a; letter-spacing: -0.5px; line-height: 1.2; margin-bottom: 4px; }
    .kpi-label { font-size: 0.85rem; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.8px; }
    .kpi-subtext { font-size: 0.8rem; color: #94a3b8; font-weight: 400; margin-top: auto; padding-top: 8px;}

    /* Filter Controls */
    .admin-controls {
        background: #ffffff;
        border: 1px solid rgba(0, 0, 0, 0.06);
        border-radius: 100px;
        padding: 8px 16px;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }

    .glass-input, .glass-select {
        background: transparent;
        border: none;
        color: #334155;
        font-family: inherit;
        font-size: 0.9rem;
        font-weight: 500;
        outline: none;
        cursor: pointer;
    }
    
    .glass-select option { background: #ffffff; color: #334155; }
    
    .btn-apply {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        border: none;
        border-radius: 100px;
        color: white;
        font-weight: 600;
        font-size: 0.85rem;
        padding: 8px 20px;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(37, 99, 235, 0.2);
    }
    .btn-apply:hover { box-shadow: 0 6px 20px rgba(37, 99, 235, 0.35); transform: translateY(-2px); color: white;}
    .btn-apply:active { transform: translateY(0); }

    /* Chart Container */
    .chart-container-wrapper { padding: 24px; }
    .chart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .chart-title { font-weight: 700; font-size: 1.15rem; color: #0f172a; display: flex; align-items: center; gap: 10px; }
    .chart-container { height: 380px; position: relative; width: 100%; }

    /* Period Nav */
    .period-nav {
        background: #f1f5f9;
        padding: 6px;
        border-radius: 100px;
        display: inline-flex; align-items: center; gap: 8px; 
    }
    .nav-btn {
        background: #ffffff;
        border: 1px solid rgba(0,0,0,0.05);
        color: #475569;
        width: 32px; height: 32px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.2s;
        cursor: pointer;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
    }
    .nav-btn:hover { background: #3b82f6; border-color: #3b82f6; color: #fff; transform: scale(1.05); }
    #currentPeriodLabel { color: #334155; font-weight: 600; font-size: 0.9rem; min-width: 120px; text-align: center; }

    /* Table Styles */
    .table-container-wrapper { padding: 0; overflow: hidden; }
    .table-header { padding: 24px; border-bottom: 1px solid rgba(0,0,0,0.04); display: flex; justify-content: space-between; align-items: center; background: #ffffff;}
    
    .glass-table { border-collapse: separate; border-spacing: 0; width: 100%; margin-bottom: 0; }
    .glass-table th {
        background: #f8fafc;
        color: #64748b; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px;
        padding: 16px 24px;
        border-bottom: 1px solid rgba(0,0,0,0.04);
        white-space: nowrap;
    }
    .glass-table td {
        padding: 18px 24px;
        color: #334155; font-weight: 500; font-size: 0.95rem;
        border-bottom: 1px solid rgba(0,0,0,0.03);
        vertical-align: middle;
        transition: background 0.2s;
    }
    .glass-table tbody tr:hover td { background: #f8fafc; }
    .glass-table tbody tr:last-child td { border-bottom: none; }

    .badge-soft-primary { background: rgba(59,130,246,0.1); color: #2563eb; padding: 5px 12px; border-radius: 100px; font-weight: 600; font-size: 0.8rem; letter-spacing: 0.5px;}

    /* Progress bars */
    .glass-progress { background: #e2e8f0; border-radius: 100px; height: 8px; overflow: hidden; }
    .glass-progress-bar { height: 100%; border-radius: 100px; position: relative; }
    .glass-progress-bar::after {
        content: ""; position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(to right, transparent, rgba(255,255,255,0.4), transparent);
        animation: shine 2.5s infinite ease-in-out;
    }
    @@keyframes shine { 100% { left: 200%; } }

    /* Custom Scrollbar */
    .table-responsive::-webkit-scrollbar { height: 8px; width: 8px; }
    .table-responsive::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 10px; }
    .table-responsive::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    .table-responsive::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

    /* Overrides */
    body { background-color: #f8fafc; }
    .content { background-color: transparent !important; }
    .topbar { background-color: #ffffff !important; border-bottom: 1px solid rgba(0,0,0,0.04) !important; color: #0f172a !important; }
    .financial-stat-row { display: flex; justify-content: space-between; margin-bottom: 8px; align-items: flex-end; }
</style>

<div class="premium-admin-page">
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-4">
        <div>
            <h3 class="premium-title mb-1">Sales Analytics</h3>
            <p class="mb-0" style="color: #64748b; font-weight: 400; letter-spacing: 0.3px;">Monitor financial performance, order metrics, and profit forecasting.</p>
        </div>
        <div class="admin-controls">
            <i class="bi bi-calendar4-week text-primary ms-2" style="opacity: 0.7;"></i>
            <span class="small fw-bold me-1" style="color: #64748b; letter-spacing: 1px;">DATE</span>
            <input id="fromDate" type="date" class="glass-input" style="width: 125px;" />
            <span class="px-1" style="color: #94a3b8;">—</span>
            <input id="toDate" type="date" class="glass-input me-2" style="width: 125px;" />
            
            <div class="vr mx-1" style="width: 1px; height: 20px; background: #e2e8f0;"></div>
            
            <i class="bi bi-clock-history text-info ms-2" style="opacity: 0.7;"></i>
            <select id="period" class="glass-select ms-1 me-2" style="width: 100px;">
                <option value="today">Today</option>
                <option value="weekly">Weekly</option>
                <option selected value="monthly">Monthly</option>
                <option value="yearly">Yearly</option>
            </select>

            <button id="apply" class="btn-apply d-flex align-items-center gap-2">
                <i class="bi bi-funnel-fill" style="font-size: 0.85rem;"></i> Filter
            </button>
        </div>
    </div>

    <!-- KPI Row -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="glass-card kpi-widget">
                <div class="kpi-glow glow-primary"></div>
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="kpi-label">Gross Revenue</div>
                    <div class="kpi-icon-wrapper icon-primary"><i class="bi bi-currency-rupee"></i></div>
                </div>
                <div id="totalRevenue" class="kpi-value">₹0.00</div>
                <div class="kpi-subtext"><i class="bi bi-arrow-up-right me-1 text-primary"></i> Total earnings in selected period</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-card kpi-widget">
                <div class="kpi-glow glow-success"></div>
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="kpi-label">Estimated Profit</div>
                    <div class="kpi-icon-wrapper icon-success"><i class="bi bi-graph-up-arrow"></i></div>
                </div>
                <div id="profit" class="kpi-value">₹0.00</div>
                <div class="kpi-subtext"><i class="bi bi-shield-check me-1 text-success"></i> 10% Platform commission share</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-card kpi-widget">
                <div class="kpi-glow glow-danger"></div>
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="kpi-label">Lost Revenue</div>
                    <div class="kpi-icon-wrapper icon-danger"><i class="bi bi-graph-down-arrow"></i></div>
                </div>
                <div id="totalLossValue" class="kpi-value">₹0.00</div>
                <div class="kpi-subtext"><i class="bi bi-exclamation-triangle me-1 text-danger"></i> Due to cancelled orders</div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <!-- Revenue Trends Chart -->
        <div class="col-xl-8">
            <div class="glass-card chart-container-wrapper h-100">
                <div class="chart-header pb-0">
                    <div class="chart-title">
                        <span class="bg-primary bg-opacity-10 text-primary p-2 rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;"><i class="bi bi-bar-chart-fill"></i></span>
                        Revenue Trends
                    </div>
                </div>
                <div class="chart-container">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Mini Payout/Loss Widget -->
        <div class="col-xl-4">
            <div class="glass-card p-4 h-100 d-flex flex-column">
                <div class="chart-title mb-4">
                    <span class="bg-success bg-opacity-10 text-success p-2 rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;"><i class="bi bi-wallet2"></i></span>
                    Financial Health
                </div>
                
                <div id="financialBreakdown" class="flex-grow-1 d-flex flex-column justify-content-center gap-4 flex-md-column">
                    <!-- Dynamic content -->
                </div>
                
                <div class="mt-4 pt-4 border-top d-flex justify-content-center">
                    <div class="d-flex align-items-center p-3 rounded-3 w-100" style="background: #f8fafc; border: 1px solid #f1f5f9;">
                        <div class="flex-shrink-0 bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <i class="bi bi-info-circle-fill"></i>
                        </div>
                        <div class="ms-3">
                            <div style="font-size: 0.75rem; color: #64748b; font-weight: 600; text-transform: uppercase;">Commission Base</div>
                            <div style="font-size: 1.1rem; font-weight: 700; color: #0f172a;">10.0% Fixed Rate</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Revenue Breakdown Table -->
    <div class="glass-card table-container-wrapper">
        <div class="table-header">
            <div class="chart-title mb-0">
                <span class="bg-info bg-opacity-10 text-info p-2 rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;"><i class="bi bi-table"></i></span>
                Detailed Breakdown
            </div>
            <div class="badge" style="background: #e0f2fe; color: #0284c7; padding: 6px 14px; border-radius: 100px; font-weight: 600; letter-spacing: 0.5px;">
                Periodically Grouped
            </div>
        </div>
        <div class="table-responsive">
            <table id="breakdownTable" class="glass-table">
                <thead>
                    <tr>
                        <th class="ps-4">Period Indicator</th>
                        <th>Status / Vol</th>
                        <th>Gross Revenue</th>
                        <th>Avg. Order Value</th>
                        <th>Net Profit</th>
                        <th class="pe-4 text-danger">Lost (Cancelled)</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Populated by JS -->
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>

    <script>
        Chart.register(ChartDataLabels);
        
        // Light theme defaults for Chart.js
        Chart.defaults.color = '#64748b';
        Chart.defaults.font.family = "'Outfit', sans-serif";

        (function () {
            const url = '/Reports/GetSalesAnalyticsData';
            const $from = $('#fromDate');
            const $to = $('#toDate');
            const $period = $('#period');

            function initDates() {
                $from.val('');
                $to.val('');
            }

            function renderSummary(m) {
                $('#totalRevenue').text('₹' + (m.totalRevenue ?? m.TotalRevenue ?? 0).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}));
                $('#totalLossValue').text('₹' + (m.totalLoss ?? m.TotalLoss ?? 0).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}));
                $('#profit').text('₹' + (m.profit ?? m.Profit ?? 0).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}));
            }

            function renderBreakdown(rows) {
                const $b = $('#breakdownTable tbody').empty();
                if (!rows || rows.length === 0) {
                    $b.append('<tr><td colspan="6" class="text-center py-5" style="color: #64748b;"><i class="bi bi-inbox fs-1 d-block mb-3" style="opacity: 0.3;"></i>No analytical data available for this range</td></tr>');
                    return;
                }
                rows.forEach(r => {
                    const revenue = Number(r.revenue || r.Revenue || 0);
                    const profit = Number(r.profit || r.Profit || 0);
                    const loss = Number(r.loss || r.Loss || 0);
                    const avg = Number(r.avgOrderValue || r.AvgOrderValue || 0);
                    
                    $b.append(`
                        <tr>
                            <td class="ps-4 fw-bold" style="color: #0f172a;">${r.periodLabel || r.PeriodLabel}</td>
                            <td><span class="badge-soft-primary"><i class="bi bi-box me-1"></i> ${r.orders || r.Orders} Orders</span></td>
                            <td class="fw-bold" style="color: #334155;">₹${revenue.toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
                            <td style="color: #475569;">₹${avg.toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
                            <td class="fw-bold" style="color: #059669;">+ ₹${profit.toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
                            <td class="pe-4 fw-bold" style="color: #dc2626;">- ₹${loss.toLocaleString(undefined, {minimumFractionDigits: 2})}</td>
                        </tr>
                    `);
                });

                // Update Financial Health Widget
                const totalRev = rows.reduce((a, b) => a + Number(b.revenue || b.Revenue || 0), 0);
                const totalProfit = rows.reduce((a, b) => a + Number(b.profit || b.Profit || 0), 0);
                const totalLoss = rows.reduce((a, b) => a + Number(b.loss || b.Loss || 0), 0);
                
                const profitPercent = totalRev > 0 ? ((totalProfit / totalRev) * 100).toFixed(1) : "0.0";
                const lossPercent = totalRev > 0 ? ((totalLoss / totalRev) * 100).toFixed(1) : "0.0";

                $('#financialBreakdown').html(`
                    <div class="flex-fill" style="background: #f0fdf4; padding: 20px; border-radius: 16px; border: 1px solid #dcfce7;">
                        <div class="financial-stat-row">
                            <span style="font-size: 0.85rem; font-weight: 600; color: #166534; text-transform: uppercase;">Profit Margin</span>
                            <span style="font-size: 1.25rem; font-weight: 700; color: #15803d;">${profitPercent}%</span>
                        </div>
                        <div class="glass-progress mt-2" style="background: #dcfce7;">
                            <div class="glass-progress-bar" style="width: ${profitPercent}%; background: linear-gradient(to right, #10b981, #10b981); box-shadow: 0 0 10px rgba(16,185,129,0.3);"></div>
                        </div>
                    </div>
                    
                    <div class="flex-fill" style="background: #fef2f2; padding: 20px; border-radius: 16px; border: 1px solid #fee2e2;">
                        <div class="financial-stat-row">
                            <span style="font-size: 0.85rem; font-weight: 600; color: #991b1b; text-transform: uppercase;">Cancellation Loss</span>
                            <span style="font-size: 1.25rem; font-weight: 700; color: #b91c1c;">${lossPercent}%</span>
                        </div>
                        <div class="glass-progress mt-2" style="background: #fee2e2;">
                            <div class="glass-progress-bar" style="width: ${lossPercent}%; background: linear-gradient(to right, #ef4444, #ef4444); box-shadow: 0 0 10px rgba(239,68,68,0.3);"></div>
                        </div>
                    </div>
                `);
            }

            let chart = null;
            let currentRefDate = new Date();

            function updatePeriodLabel(period, date) {
                const label = document.getElementById('currentPeriodLabel');
                if (!label) return;

                const isCurrent = isSamePeriod(period, date, new Date());
                
                if (period === 'today') {
                    label.innerText = isCurrent ? "Today" : date.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
                } else if (period === 'weekly') {
                    const start = new Date(date);
                    start.setDate(date.getDate() - date.getDay());
                    const end = new Date(start);
                    end.setDate(start.getDate() + 6);
                    label.innerText = isCurrent ? "This Week" : `${start.toLocaleDateString(undefined, { month: 'short', day: 'numeric' })} - ${end.toLocaleDateString(undefined, { month: 'short', day: 'numeric' })}`;
                } else if (period === 'monthly') {
                    label.innerText = isCurrent ? "This Month" : date.toLocaleDateString(undefined, { month: 'long', year: 'numeric' });
                } else if (period === 'yearly') {
                    label.innerText = isCurrent ? "This Year" : date.getFullYear();
                } else {
                    label.innerText = "All-Time";
                }
            }

            function isSamePeriod(period, d1, d2) {
                if (period === 'today') return d1.toDateString() === d2.toDateString();
                if (period === 'weekly') {
                    const s1 = new Date(d1); s1.setDate(d1.getDate() - d1.getDay());
                    const s2 = new Date(d2); s2.setDate(d2.getDate() - d2.getDay());
                    return s1.toDateString() === s2.toDateString();
                }
                if (period === 'monthly') return d1.getMonth() === d2.getMonth() && d1.getFullYear() === d2.getFullYear();
                if (period === 'yearly') return d1.getFullYear() === d2.getFullYear();
                return true;
            }

            function renderChart(trend) {
                const labels = (trend || []).map(t => t.label || t.Label);
                const revenue = (trend || []).map(t => Number(t.revenue ?? t.Revenue));
                const periodLabel = $period.find('option:selected').text();

                const ctx = document.getElementById('revenueChart').getContext('2d');
                
                const gradient = ctx.createLinearGradient(0, 0, 0, 400);
                gradient.addColorStop(0, 'rgba(59, 130, 246, 0.2)');
                gradient.addColorStop(1, 'rgba(59, 130, 246, 0)');

                if (chart) {
                    chart.data.labels = labels;
                    chart.data.datasets[0].data = revenue;
                    chart.options.scales.x.title.text = 'Time Period (' + periodLabel + ')';
                    chart.update();
                    return;
                }

                chart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [
                            {
                                label: 'Revenue (₹)',
                                data: revenue,
                                borderColor: '#3b82f6',
                                backgroundColor: gradient,
                                borderWidth: 3,
                                fill: true,
                                tension: 0.4,
                                pointBackgroundColor: '#ffffff',
                                pointBorderColor: '#3b82f6',
                                pointBorderWidth: 2,
                                pointRadius: 4,
                                pointHoverRadius: 6,
                                pointHoverBackgroundColor: '#2563eb',
                                pointHoverBorderColor: '#ffffff'
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: { mode: 'index', intersect: false },
                        plugins: { 
                            legend: { display: false },
                            datalabels: { display: false },
                            tooltip: {
                                backgroundColor: '#ffffff',
                                titleColor: '#0f172a',
                                bodyColor: '#334155',
                                borderColor: 'rgba(0,0,0,0.1)',
                                borderWidth: 1,
                                padding: 12,
                                boxPadding: 6,
                                usePointStyle: true,
                                callbacks: {
                                    label: function(context) {
                                        let label = context.dataset.label || '';
                                        if (label) { label += ': '; }
                                        if (context.parsed.y !== null) {
                                            label += '₹' + context.parsed.y.toLocaleString();
                                        }
                                        return label;
                                    }
                                }
                            }
                        },
                        scales: { 
                            x: { 
                                grid: { color: 'rgba(0, 0, 0, 0.04)', drawBorder: false },
                                title: { display: true, text: 'Time Period (' + periodLabel + ')', color: '#64748b', font: { weight: '600', size: 11, family: "'Outfit', sans-serif" } },
                                ticks: { color: '#64748b', font: {family: "'Outfit', sans-serif"} }
                            }, 
                            y: { 
                                type: 'linear',
                                display: true,
                                position: 'left',
                                beginAtZero: true,
                                grid: { color: 'rgba(0, 0, 0, 0.05)', drawBorder: false, borderDash: [5, 5] },
                                title: { display: false },
                                ticks: { 
                                    color: '#64748b', 
                                    font: {family: "'Outfit', sans-serif"},
                                    callback: (val) => '₹' + (val >= 1000 ? (val/1000) + 'k' : val) 
                                }
                            }
                        }
                    }
                });
            }

            function loadSalesData() {
                const period = $period.val();
                let actualPeriod = period === 'today' ? 'daily' : period;
                
                updatePeriodLabel(period, currentRefDate);
                const q = { 
                    from: $from.val(), 
                    to: $to.val(), 
                    period: actualPeriod,
                    refDate: (!$from.val() && !$to.val()) ? currentRefDate.toISOString() : null
                };
                
                $('.chart-container').css('opacity', '0.5');
                
                $.getJSON(url, q).done(function (res) {
                    $('.chart-container').css('opacity', '1');
                    renderSummary(res);
                    renderBreakdown(res.breakdown || res.Breakdown || []);
                    renderChart(res.trend || res.Trend || []);
                }).fail(function () {
                    $('.chart-container').css('opacity', '1');
                    alert('Failed to load sales data');
                });
            }

            function navigatePeriod(direction) {
                $from.val('');
                $to.val('');
                const period = $period.val();
                if (period === 'today') currentRefDate.setDate(currentRefDate.getDate() + direction);
                else if (period === 'weekly') currentRefDate.setDate(currentRefDate.getDate() + (direction * 7));
                else if (period === 'monthly') currentRefDate.setMonth(currentRefDate.getMonth() + direction);
                else if (period === 'yearly') currentRefDate.setFullYear(currentRefDate.getFullYear() + direction);
                loadSalesData();
            }

            $(function () {
                initDates();
                loadSalesData();
                $('#apply').on('click', loadSalesData);

                $('#prevPeriod').on('click', () => navigatePeriod(-1));
                $('#nextPeriod').on('click', () => navigatePeriod(1));
                $('#dateSelector').on('change', (e) => {
                    if (e.target.value) {
                        currentRefDate = new Date(e.target.value);
                        loadSalesData();
                    }
                });
                
                $period.on('change', function() {
                    $from.val('');
                    $to.val('');
                    loadSalesData();
                });
            });
        })();
    </script>
}
