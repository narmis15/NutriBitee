@model List<NUTRIBITE.Models.OrderTable>

@if (Model != null && Model.Any())
{
    @Html.AntiForgeryToken()
    foreach (var order in Model.OrderByDescending(o => o.CreatedAt))
    {
        var statusClass = "status-picked";
        if (order.Status == "Cancelled")
        {
            statusClass = "status-cancelled";
        }
        else if (order.Status == "Pending Payment")
        {
            statusClass = "status-pending-payment";
        }

        <div class="order-card" data-status="@order.Status" data-date="@order.CreatedAt?.ToString("yyyy-MM-dd")" data-id="@order.OrderId" data-items="@string.Join(",", order.OrderItems.Select(i => i.ItemName))">
            <div class="order-info">
                <h5>Order #@order.OrderId</h5>
                <span>@order.CreatedAt?.ToString("dd MMM yyyy, hh:mm tt")</span>
                <div class="mt-2">
                    @foreach (var item in order.OrderItems)
                    {
                        var imgSrc = item.Food?.ImagePath ?? item.BulkItemData?.ImagePath ?? "/images/Meals/Standard_Thali.jpeg";
                        <div class="d-flex align-items-center mb-2">
                            <img src="@imgSrc" style="width: 40px; height: 40px; object-fit: cover; border-radius: 6px;" class="me-2 shadow-sm" />
                            <span class="badge bg-light text-dark border">@item.Quantity x @item.ItemName</span>
                        </div>
                    }
                </div>
            </div>

            <div class="d-flex align-items-center gap-4">
                <div class="text-end">
                    <div class="fw-bold fs-5">₹@order.TotalAmount</div>
                    <span class="order-status @statusClass">@order.Status</span>
                </div>

                <div class="d-flex flex-column gap-2">
                    @if (order.Status == "Delivered" || order.Status == "Completed")
                    {
                        <button class="btn btn-sm btn-success rounded-pill px-3 reorder-btn" data-id="@order.OrderId">
                            <i class="bi bi-arrow-repeat me-1"></i> Reorder
                        </button>
                    }

                    @if (order.Status == "Delivered")
                    {
                        <button class="btn btn-sm btn-success rounded-pill px-3 rate-order-btn" 
                                data-id="@order.OrderId" 
                                data-items='@Json.Serialize(order.OrderItems.Where(i => i.FoodId != null).Select(i => new { foodId = i.FoodId ?? 0, itemName = i.ItemName, vendorId = order.VendorId }))'>
                            <i class="bi bi-star-fill me-1"></i> Rate Food
                        </button>
                    }

                    @if (order.Status != "Cancelled" && order.Status != "Completed" && order.Status != "Delivered")
                    {
                        <a href="/Home/TrackOrder?orderId=@order.OrderId" class="btn btn-sm btn-primary rounded-pill px-3">
                            <i class="bi bi-geo-alt me-1"></i> Track
                        </a>

                        <button class="btn btn-sm btn-outline-danger rounded-pill px-3 cancel-order-btn" data-id="@order.OrderId">
                            <i class="bi bi-x-circle me-1"></i> Cancel
                        </button>
                    }
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-box display-1 text-muted d-block mb-3"></i>
        <p class="text-muted">No orders found.</p>
        <a href="/" class="btn btn-primary rounded-pill mt-2">Explore Menu</a>
    </div>
}
