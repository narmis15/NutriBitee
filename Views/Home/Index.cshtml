@{
    ViewData["Title"] = "NutriBite — Home";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<!-- HERO -->
<div class="hero-section">
    <div class="hero-top">
        <div class="hero-left">
            <div class="eyebrow">100% Homemade</div>
            <h1>Discover Balanced Homemade Meals</h1>
            <p>
                Fresh, calorie-counted meals prepared by verified home chefs.
                Daily deliveries tailored to your goals.
            </p>
            <a asp-controller="Meals" asp-action="Index" class="cta-btn">
                Start Ordering
            </a>
        </div>

        <div class="hero-right">
            <div class="food-circle">
                <img src="~/images/hero/hero-food.png" />
            </div>
        </div>
    </div>

    <!-- FEATURES -->
    <div class="features">
        <div class="feature-card">
            <h4>🔥 Calorie Counted</h4>
            <p>Clear nutritional info for every meal.</p>
        </div>
        <div class="feature-card">
            <h4>🥗 Fresh Daily</h4>
            <p>Cooked fresh and delivered same day.</p>
        </div>

        <div class="feature-card">
            <h4>🏡 Homemade</h4>
            <p>Prepared by verified home chefs.</p>
        </div>
    </div>
    


    <!-- ===============================
       AUDIENCE MEALS SECTION
    ================================= -->

    <section id="studentMeals">

        <div class="container">

            <div class="audience-title text-center mb-5">
                <span></span>
                <h4>SPECIALLY FOR YOU</h4>
                <span></span>
            </div>

            <div class="combos-grid">

                <!-- ===============================
                     STUDENTS
                ================================ -->
                <div class="combo-card text-center">

                    <div class="combo-image">
                        <img src="~/images/categories/student.jpeg" alt="Students">
                    </div>

                    <a asp-controller="Students"
                       asp-action="Index"
                       class="btn add-cart">
                        STUDENTS
                    </a>

                </div>


                <!-- ===============================
                     ELDERLY
                ================================ -->
                <div class="combo-card text-center">

                    <div class="combo-image">
                        <img src="~/images/categories/elderly.jpeg" alt="Elderly">
                    </div>

                    <a asp-controller="Elderly"
                       asp-action="Index"
                       class="btn add-cart">
                        ELDERLY
                    </a>

                </div>


                <!-- ===============================
                     CORPORATE
                ================================ -->
                <div class="combo-card text-center">

                    <div class="combo-image">
                        <img src="~/images/categories/corporate.jpeg" alt="Corporate">
                    </div>

                    <a asp-controller="Corporate"
                       asp-action="Index"
                       class="btn add-cart">
                        CORPORATE
                    </a>

                </div>

            </div>

        </div>

    </section>
   
   
</div>

<!-- MEAL CATEGORIES -->
<section class="meals-grid-section soft-section">
    <div class="container">

        <div class="text-center mb-5">
            <h2 class="section-title">Meal Categories</h2>
            <p class="text-muted">
                Choose a meal plan or browse by category
            </p>
        </div>

        <div class="meals-grid">

            <a class="meal-card" href="/Menu/Category?name=Standard Thali">
                <div class="meal-img-wrap">
                    <img src="~/images/meals/Standard_Thali.jpeg" />
                </div>
                <div class="meal-label">Standard Thali</div>
            </a>

            <a class="meal-card" href="/Menu/Category?name=Special Thali">
                <div class="meal-img-wrap">
                    <img src="~/images/meals/Special_Thali.jpeg" />
                </div>
                <div class="meal-label">Special Thali</div>
            </a>

            <a class="meal-card" href="/Menu/Category?name=Deluxe Thali">
                <div class="meal-img-wrap">
                    <img src="~/images/meals/Deluxe_Thali.jpeg" />
                </div>
                <div class="meal-label">Deluxe Thali</div>
            </a>

            <a class="meal-card" href="/Menu/Category?name=Classical Thali">
                <div class="meal-img-wrap">
                    <img src="~/images/meals/Classical_Thali.jpeg" />
                </div>
                <div class="meal-label">Classical Thali</div>
            </a>

            <a class="meal-card" href="/Menu/Category?name=Comfort Thali">
                <div class="meal-img-wrap">
                    <img src="~/images/meals/Comfort_Thali.jpeg" />
                </div>
                <div class="meal-label">Comfort Thali</div>
            </a>

            <a class="meal-card" href="/Menu/Category?name=Jain Thali">
                <div class="meal-img-wrap">
                    <img src="~/images/meals/Jain_Thali.jpeg" />
                </div>
                <div class="meal-label">Jain Thali</div>
            </a>

            <a class="meal-card" href="/Menu/Category?name=Rice Combo">
                <div class="meal-img-wrap">
                    <img src="~/images/meals/Rice_Combo.jpeg" />
                </div>
                <div class="meal-label">Rice Combo</div>
            </a>

            <a class="meal-card" href="/Menu/Category?name=Low Calorie Meal">
                <div class="meal-img-wrap">
                    <img src="~/images/meals/low-calorie.jpg" />
                </div>
                <div class="meal-label">Low Calorie</div>
            </a>

            <a class="meal-card" href="/Menu/Category?name=Protein Meal">
                <div class="meal-img-wrap">
                    <img src="~/images/meals/protein.jpg" />
                </div>
                <div class="meal-label">Protein Meal</div>
            </a>

            <a class="meal-card" href="/Menu/Category?name=Salads">
                <div class="meal-img-wrap">
                    <img src="~/images/meals/salads.jpeg" />
                </div>
                <div class="meal-label">Salad Bowl</div>
            </a>

        </div>
    </div>
</section>