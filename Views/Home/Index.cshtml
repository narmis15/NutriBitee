@{
    ViewData["Title"] = "NutriBite — Home";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<!-- HERO -->
<div class="hero-section">
    <div class="hero-top">
        <div class="hero-left">
            <div class="eyebrow">100% Homemade</div>
            <h1>Discover Balanced Homemade Meals</h1>
            <p>
                Fresh, calorie-counted meals prepared by verified home chefs.
                Daily deliveries tailored to your goals.
            </p>
            <a href="#mealCategories" class="cta-btn">
                Start Ordering
            </a>
        </div>

        <div class="hero-right">
            <div class="food-circle">
                <img src="~/images/hero/hero-food.png" />
            </div>
        </div>
    </div>

        <!-- FEATURES -->
        <div class="features">
            <div class="feature-card">
                <h4>🔥 Calorie Counted</h4>
                <p>Clear nutritional info for every meal.</p>
            </div>

            <div class="feature-card">
                <h4>🥗 Fresh Daily</h4>
                <p>Cooked fresh and delivered same day.</p>
            </div>

        <div class="feature-card">
            <h4>🏡 Homemade</h4>
            <p>Prepared by verified home chefs.</p>
        </div>
    </div>
</div>

<!-- MEAL CATEGORIES -->
<section class="meals-grid-section soft-section">
    <div class="container" id="mealCategories">

        <div class="text-center mb-5">
            <h2 class="section-title">Meal Categories</h2>
            <p class="text-muted">
                Choose a meal plan or browse by category
            </p>
        </div>

        <div class="meals-grid">
            @if (ViewBag.Categories != null && (ViewBag.Categories as IEnumerable<NUTRIBITE.Models.AddCategory>).Any())
            {
                foreach (var cat in (ViewBag.Categories as IEnumerable<NUTRIBITE.Models.AddCategory>))
                {
                    <a class="meal-card" href="/Menu/Category?name=@Uri.EscapeDataString(cat.MealCategory ?? "")">
                        <div class="meal-img-wrap">
                            <img src="~/images/Meals/@(cat.MealPic ?? "default.jpg")" onerror="this.src='/images/Meals/Standard_Thali.jpeg';" />
                        </div>
                        <div class="meal-label">@cat.MealCategory</div>
                    </a>
                }
            }
            else
            {
                <a class="meal-card" href="/Menu/Category?name=Standard Thali">
                    <div class="meal-img-wrap">
                        <img src="~/images/meals/Standard_Thali.jpeg" />
                    </div>
                    <div class="meal-label">Standard Thali</div>
                </a>

                <a class="meal-card" href="/Menu/Category?name=Special Thali">
                    <div class="meal-img-wrap">
                        <img src="~/images/meals/Special_Thali.jpeg" />
                    </div>
                    <div class="meal-label">Special Thali</div>
                </a>

                <a class="meal-card" href="/Menu/Category?name=Deluxe Thali">
                    <div class="meal-img-wrap">
                        <img src="~/images/meals/Deluxe_Thali.jpeg" />
                    </div>
                    <div class="meal-label">Deluxe Thali</div>
                </a>
            }
        </div>
    </div>
</section>
<!-- ===============================
       AUDIENCE MEALS SECTION
    ================================= -->

<section id="studentMeals">

    <div class="container">

        <div class="audience-title text-center mb-5">
            <span></span>
            <h4>SPECIALLY FOR YOU</h4>
            <span></span>
        </div>

        <div class="combos-grid">

            <!-- ===============================
                 STUDENTS
            ================================ -->
            <div class="combo-card text-center">

                <div class="combo-image">
                    <img src="~/images/categories/student.jpeg" alt="Students">
                </div>

                <a asp-controller="Students"
                   asp-action="Index"
                   class="btn add-cart">
                    STUDENTS
                </a>

            </div>


            <!-- ===============================
                 ELDERLY
            ================================ -->
            <div class="combo-card text-center">

                <div class="combo-image">
                    <img src="~/images/categories/elderly.jpeg" alt="Elderly">
                </div>

                <a asp-controller="Elderly"
                   asp-action="Index"
                   class="btn add-cart">
                    ELDERLY
                </a>

            </div>


            <!-- ===============================
                 CORPORATE
            ================================ -->
            <div class="combo-card text-center">

                <div class="combo-image">
                    <img src="~/images/categories/corporate.jpeg" alt="Corporate">
                </div>

                <a asp-controller="Corporate"
                   asp-action="Index"
                   class="btn add-cart">
                    CORPORATE
                </a>

            </div>

        </div>

    </div>

</section>

<!-- ===============================
       NUTRIBITE INFO SECTION
================================= -->

<section class="nutribite-info">

    <div class="container">

        <div class="row">

            <!-- LEFT SIDE -->

            <div class="col-md-4">

                <div class="brand-block">

                    <img src="~/images/hero/Nutribitelogo.png"
                         class="footer-logo" />

                    <p>
                        NutriBite connects people with healthy homemade meals prepared by trusted home chefs, making nutritious and calorie-counted food
                    </p>

                </div>

            </div>


            <!-- COMPANY -->

            <div class="col-md-3">

                <h5>Company</h5>

                <ul class="footer-links">

                    <li>
                        <a asp-controller="Home" asp-action="About">
                            About Us
                        </a>
                    </li>

                    <li>
                        <a href="#">
                            Why NutriBite
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Vendor" asp-action="Register">
                            Join as Vendor
                        </a>
                    </li>

                    <li>
                        <a href="#">
                            Careers
                        </a>
                    </li>

                </ul>

            </div>


            <!-- INFORMATION -->

            <div class="col-md-3">

                <h5>Information</h5>

                <ul class="footer-links">

                    <li>
                        <a href="#">Privacy Policy</a>
                    </li>

                    <li>
                        <a href="#">Terms & Conditions</a>
                    </li>

                    <li>
                        <a href="#">Cancellation & Refunds</a>
                    </li>

                </ul>

            </div>


            <!-- CONTACT -->

            <div class="col-md-2">

                <h5>Contact Us</h5>

                <p class="contact-item">
                    📞 +91 9876543210
                </p>

                <p class="contact-item">
                    ✉ support@nutribite.com
                </p>

            </div>

        </div>

    </div>

</section>