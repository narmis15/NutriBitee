@model IEnumerable<NUTRIBITE.Models.Food>
@{
    ViewData["Title"] = "Image Checker";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Database Food Images Checker</h2>
        <span class="badge bg-primary fs-6">@Model.Count() Items Found</span>
    </div>

    <div class="row g-4">
        @foreach (var food in Model)
        {
            <div class="col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                    <img src="@(string.IsNullOrEmpty(food.ImagePath) ? "/images/Meals/Standard_Thali.jpeg" : food.ImagePath)" 
                         alt="@food.Name" 
                         style="height: 200px; object-fit: cover; width: 100%; border-bottom: 2px solid #e9ecef;"
                         onerror="this.onerror=null;this.src='/images/Meals/Standard_Thali.jpeg';" />
                    <div class="card-body">
                        <h6 class="fw-bold mb-2 text-dark">@food.Name</h6>
                        <p class="text-muted small mb-1">
                            <i class="bi bi-tag-fill me-1"></i> @food.FoodType
                        </p>
                        <p class="text-muted small mb-0 text-break" style="font-size: 0.75rem;">
                            <i class="bi bi-folder-fill me-1"></i> @food.ImagePath
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
