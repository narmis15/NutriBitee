@using NUTRIBITE.Models
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    var user = ViewBag.User as UserSignup;
    var survey = ViewBag.Survey as HealthSurvey;
}

<style>
    :root {
        --profile-bg: #f8fafc;
        --sidebar-active: #3d7055;
        --sidebar-text: #4a5568;
        --card-shadow: 0 4px 12px rgba(0,0,0,0.05);
    }

    body { background-color: var(--profile-bg); }

    .profile-container {
        max-width: 95%;
        margin: 2rem auto;
        display: flex;
        gap: 2rem;
        padding: 0 2rem;
    }

    /* Sidebar Styles */
    .profile-sidebar {
        width: 300px;
        background: white;
        border-radius: 24px;
        padding: 2rem;
        box-shadow: var(--card-shadow);
        height: fit-content;
    }

    .user-brief {
        text-align: center;
        margin-bottom: 2rem;
    }

    .avatar-circle {
        width: 100px;
        height: 100px;
        background: #3d7055;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0 auto 1rem;
        box-shadow: 0 4px 10px rgba(61, 112, 85, 0.2);
    }

    .user-brief h4 {
        margin-bottom: 0.25rem;
        font-weight: 700;
        color: #2d3748;
    }

    .user-brief p {
        color: #a0aec0;
        font-size: 0.9rem;
    }

    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        border-top: 1px solid #edf2f7;
        padding-top: 1.5rem;
    }

    .nav-item {
        display: flex;
        align-items: center;
        padding: 0.85rem 1.25rem;
        border-radius: 12px;
        color: var(--sidebar-text);
        text-decoration: none;
        font-weight: 500;
        transition: all 0.2s;
        gap: 1rem;
    }

    .nav-item:hover {
        background: #f7fafc;
        color: var(--sidebar-active);
    }

    .nav-item.active {
        background: var(--sidebar-active);
        color: white;
    }

    .nav-item.logout {
        margin-top: 1rem;
        color: #e53e3e;
    }

    .nav-item.logout:hover {
        background: #fff5f5;
    }

    /* Main Content Styles */
    .profile-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .profile-section-card {
        background: white;
        border-radius: 24px;
        padding: 2rem;
        box-shadow: var(--card-shadow);
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .section-header h3 {
        font-weight: 700;
        margin: 0;
        color: #2d3748;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }

    .info-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #a0aec0;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .info-value {
        font-weight: 600;
        color: #2d3748;
    }

    .status-badge {
        background: #f0fff4;
        color: #38a169;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 700;
    }

    .snapshot-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
    }

    .snapshot-item {
        background: #f8fafc;
        padding: 1.25rem;
        border-radius: 16px;
        text-align: center;
    }

    .snapshot-label {
        font-size: 0.75rem;
        color: #718096;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .snapshot-value {
        font-weight: 700;
        color: #2d3748;
        font-size: 1.1rem;
    }

    .recent-orders, .health-progress {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    .mini-card {
        background: white;
        border-radius: 24px;
        padding: 1.5rem;
        box-shadow: var(--card-shadow);
    }

    .mini-card h5 {
        font-weight: 700;
        margin-bottom: 1rem;
    }

    .empty-state {
        color: #718096;
        font-size: 0.95rem;
    }

    .empty-state a {
        color: #38a169;
        text-decoration: none;
        font-weight: 600;
    }
</style>

<div class="profile-container">
    @if (TempData["ProfileSuccess"] != null)
    {
        <div class="position-fixed top-0 start-50 translate-middle-x mt-3" style="z-index: 9999;">
            <div class="alert alert-success alert-dismissible fade show rounded-pill shadow px-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["ProfileSuccess"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    }
    <!-- Sidebar -->
    <div class="profile-sidebar">
        <div class="user-brief">
            <div class="avatar-circle">
                @(user?.Name?.Substring(0, 1).ToUpper() ?? "U")
            </div>
            <h4>@(user?.Name ?? "User")</h4>
            <p>Member since 2026</p>
        </div>

        <nav class="sidebar-nav">
            <a href="#account" class="nav-item active">
                <i class="bi bi-person-circle"></i> Personal Info
            </a>
            <a href="/Home/MyOrders" class="nav-item">
                <i class="bi bi-bag-check"></i> My Orders
            </a>
            <a href="/CalorieTracker" class="nav-item">
                <i class="bi bi-fire"></i> Calorie Tracker
            </a>
            <a href="/HealthSurvey" class="nav-item">
                <i class="bi bi-clipboard-pulse"></i> Health Survey
            </a>
            <a href="#" class="nav-item logout" data-bs-toggle="modal" data-bs-target="#deleteProfileModal">
                <i class="bi bi-trash"></i> Delete Account
            </a>
            <a href="/Auth/Logout" class="nav-item logout">
                <i class="bi bi-box-arrow-right"></i> Logout
            </a>
        </nav>
    </div>

    <!-- Main Content -->
    <div class="profile-main">
        <!-- Account Details -->
        <div id="account" class="profile-section-card">
            <div class="section-header">
                <h3>Account Details</h3>
                <button class="btn btn-outline-secondary btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#editProfileModal">
                    Edit Profile
                </button>
            </div>
            
            <div class="info-grid">
                <div>
                    <div class="info-label">Full Name</div>
                    <div class="info-value">@(user?.Name ?? "—")</div>
                </div>
                <div>
                    <div class="info-label">Email Address</div>
                    <div class="info-value">@(user?.Email ?? "—")</div>
                </div>
                <div>
                    <div class="info-label">Phone Number</div>
                    <div class="info-value">@(string.IsNullOrEmpty(user?.Phone) || user?.Phone == "-" ? "Not provided" : user.Phone)</div>
                </div>
                <div>
                    <div class="info-label">Address</div>
                    @{
                        var sessionAddress = Context.Session.GetString("UserAddress") ?? Context.Request.Cookies["UserAddress"];
                        var displayAddress = !string.IsNullOrEmpty(sessionAddress) ? sessionAddress : (string.IsNullOrEmpty(user?.Address) ? "Not provided" : user.Address);
                    }
                    <div class="info-value">@displayAddress</div>
                </div>
                <div>
                    <div class="info-label">Account Status</div>
                    <div class="info-value"><span class="status-badge">Active</span></div>
                </div>
            </div>
        </div>

        <!-- Health Snapshot -->
        <div class="profile-section-card">
            <div class="section-header">
                <h3>Health Snapshot</h3>
                <a href="/HealthSurvey" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                    Update Survey
                </a>
            </div>

            <div class="snapshot-grid">
                <div class="snapshot-item">
                    <div class="snapshot-label"><i class="bi bi-target"></i> Goal</div>
                    <div class="snapshot-value">@(survey?.Goal ?? "—")</div>
                </div>
                <div class="snapshot-item">
                    <div class="snapshot-label"><i class="bi bi-lightning-charge"></i> Daily Target</div>
                    <div class="snapshot-value">@(survey?.RecommendedCalories ?? 2000) kcal</div>
                </div>
                <div class="snapshot-item">
                    <div class="snapshot-label"><i class="bi bi-speedometer2"></i> BMI</div>
                    <div class="snapshot-value">@(survey?.Bmi ?? 0)</div>
                </div>
                <div class="snapshot-item">
                    <div class="snapshot-label"><i class="bi bi-activity"></i> Activity</div>
                    <div class="snapshot-value">@(survey?.ActivityLevel ?? "—")</div>
                </div>
            </div>
        </div>

        <!-- Lower Grid -->
        <div class="recent-orders">
            <div class="mini-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Recent Orders</h5>
                    <a href="#fullOrderHistory" class="text-success small fw-bold text-decoration-none">View All</a>
                </div>

                @if (ViewBag.RecentOrders != null && ((IEnumerable<OrderTable>)ViewBag.RecentOrders).Any())
                {
                    <div class="order-list-mini">
                        @foreach (var order in (IEnumerable<OrderTable>)ViewBag.RecentOrders)
                        {
                            <div class="order-item-mini d-flex justify-content-between align-items-center p-2 mb-2 border rounded-3 bg-light">
                                <div>
                                    <div class="fw-bold small">Order #@order.OrderId</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">@(order.CreatedAt?.ToString("dd MMM, hh:mm tt") ?? "N/A")</div>
                                </div>
                                <div class="text-end">
                                    <div class="badge @(order.Status == "Delivered" ? "bg-success" : (order.Status == "Cancelled" ? "bg-danger" : "bg-primary"))" style="font-size: 0.7rem;">
                                        @order.Status
                                    </div>
                                    <div class="fw-bold text-success mt-1" style="font-size: 0.85rem;">₹@order.TotalAmount</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        You haven't placed any orders yet. Check out our <a href="/Menu/Categories">Daily Menu</a>.
                    </div>
                }
            </div>
            <div class="mini-card">
                <h5>Health Progress</h5>
                <div class="empty-state">
                    Your calorie tracking journey is just beginning! Keep logging your meals to see analytics here.
                    <div class="mt-3">
                        <a href="/CalorieTracker" class="btn btn-sm btn-outline-success rounded-pill">Open Tracker</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- FULL ORDER HISTORY -->
        <div id="fullOrderHistory" class="profile-section-card mt-4">
            <div class="section-header">
                <h3>Full Order History</h3>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-3">Order ID</th>
                            <th>Date & Time</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.AllOrders != null && ((IEnumerable<OrderTable>)ViewBag.AllOrders).Any())
                        {
                            var allOrders = ((IEnumerable<OrderTable>)ViewBag.AllOrders).ToList();
                            for (int i = 0; i < allOrders.Count; i++)
                            {
                                var order = allOrders[i];
                                var rowClass = i >= 5 ? "hidden-order d-none" : "";
                                <tr class="@rowClass">
                                    <td class="ps-3 fw-bold text-dark">#@order.OrderId</td>
                                    <td>@(order.CreatedAt?.ToString("dd MMM yyyy, hh:mm tt"))</td>
                                    <td class="fw-bold">₹@order.TotalAmount</td>
                                    <td>
                                        @if (order.Status == "Cancelled")
                                        {
                                            <span class="badge bg-danger">Cancelled</span>
                                        }
                                        else if (order.Status == "Delivered")
                                        {
                                            <span class="badge bg-success">Delivered</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info text-dark">@order.Status</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="/Home/TrackOrder?orderId=@order.OrderId" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            Track
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">No orders found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (ViewBag.AllOrders != null && ((IEnumerable<OrderTable>)ViewBag.AllOrders).Count() > 5)
            {
                <div class="text-center mt-3 pt-3 border-top">
                    <button id="loadMoreOrdersBtn" class="btn btn-outline-success rounded-pill px-4 fw-bold">
                        <i class="bi bi-chevron-down me-1"></i> View More
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const loadMoreBtn = document.getElementById('loadMoreOrdersBtn');
        if (loadMoreBtn) {
            loadMoreBtn.addEventListener('click', function() {
                const hiddenOrders = document.querySelectorAll('.hidden-order');
                hiddenOrders.forEach(order => {
                    order.classList.remove('d-none');
                });
                this.style.display = 'none'; // hide the button after loading all
            });
        }
    });
</script>

<!-- Delete Modal -->
<div class="modal fade" id="deleteProfileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 24px;">
            @using (Html.BeginForm("DeleteAccount", "Users", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="modal-header border-bottom-0 p-4 pb-0">
                    <h5 class="modal-title text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i> Confirm Deletion</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4 text-center">
                    <p class="mb-0 fs-5">Are you sure you want to permanently delete your account? This action will completely erase all your data and cannot be undone.</p>
                </div>
                <div class="modal-footer border-top-0 d-flex justify-content-center p-4 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4 shadow">Yes, Delete Everything</button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Edit Profile Modal -->
<div class="modal fade" id="editProfileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 24px;">
            <div class="modal-header border-bottom-0 p-4 pb-0">
                <h5 class="modal-title fw-bold">Update Profile</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 pt-3">
                <form action="/Home/EditProfile" method="post" id="editProfileForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@(user?.Id)" />
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Full Name</label>
                        <input type="text" class="form-control form-control-lg bg-light border-0 rounded-4" name="Name" value="@(user?.Name)" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Email Address</label>
                        <input type="email" class="form-control form-control-lg bg-light border-0 rounded-4" name="Email" value="@(user?.Email)" required readonly />
                        <div class="form-text px-2">Email address cannot be changed.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Phone Number</label>
                        <input type="text" class="form-control form-control-lg bg-light border-0 rounded-4" name="Phone" value="@(user?.Phone)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Address</label>
                        <input type="text" class="form-control form-control-lg bg-light border-0 rounded-4" name="Address" value="@(user?.Address)" />
                    </div>
                    <button type="submit" class="btn btn-success btn-lg w-100 rounded-pill fw-bold shadow">Save Changes</button>
                </form>
            </div>
        </div>
    </div>
</div>
