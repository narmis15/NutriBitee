@model List<NUTRIBITE.Models.Food>

@{
    ViewData["Title"] = "NutriBite — Corporate";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";

    // Helper to find food ID by name safely
    int GetFoodId(string name) => Model?.FirstOrDefault(f => f.Name.Trim().ToLower() == name.Trim().ToLower())?.Id ?? 0;
}

<link rel="stylesheet" href="~/css/corporate.css" />

<section class="students-hero container my-4" role="region" aria-label="Corporate hero">
    <div class="hero-card">
        <div class="hero-left">
            <h1>Productive Meals for Corporate Professionals</h1>
            <p class="lead">Fuel your performance without the afternoon slump.</p>
            <a class="btn explore-combos" href="#featuredCombos">Explore Combos</a>
        </div>
        <div class="hero-right" aria-hidden="true">
            <img src="~/images/categories/corporate.jpeg" alt="Corporate meals" loading="lazy" />
        </div>
    </div>
</section>

<!-- Sticky filter bar -->
<section class="filter-bar-wrap" aria-label="Student filters">
    <div class="filter-bar container" role="region" aria-label="Filters" id="studentsFilterBar">
        <div class="filter-item">
            <label for="priceRange">Budget: <span id="priceValue">₹75</span></label>
            <input id="priceRange" type="range" min="50" max="150" value="100" />
        </div>

        <div class="filter-item toggle-item">
            <label><input id="highProtein" type="checkbox" /> High Protein</label>
        </div>

        <div class="filter-item toggle-item">
            <label><input id="under500" type="checkbox" /> Under 500 kcal</label>
        </div>

        <div class="filter-item toggle-item">
            <label><input id="vegOnly" type="checkbox" /> Veg Only</label>
        </div>

        <div class="filter-item">
            <button id="resetFilters" class="btn reset-btn">Reset</button>
        </div>
    </div>
</section>

