@model List<NUTRIBITE.Models.Food>

@{
    ViewData["Title"] = "NutriBite — Corporate";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<link rel="stylesheet" href="~/css/corporate.css" />

<!-- Hero Section -->
<section class="corporate-hero container my-4" role="region" aria-label="Corporate hero">
    <div class="hero-card">
        <div class="hero-left">
            <h1>Premium Corporate Catering</h1>
            <p class="lead">Healthy, timely, and professional meal solutions for your team.</p>
            <a class="btn explore-combos" href="#corporateMeals">Explore Productivity Menu</a>
        </div>
        <div class="hero-right" aria-hidden="true">
            <img src="~/images/categories/corporate.jpeg" alt="Corporate meals" loading="lazy" />
        </div>
    </div>
</section>

<!-- Sticky filter bar -->
<section class="filter-bar-wrap" aria-label="Corporate filters">
    <div class="filter-bar container" role="region" aria-label="Filters" id="corporateFilterBar">
        <div class="filter-item">
            <label for="priceRange">Budget: <span id="priceValue">₹120</span></label>
            <input id="priceRange" type="range" min="80" max="200" value="150" />
        </div>

        <div class="filter-item toggle-item">
            <label><input id="highProtein" type="checkbox" /> High Protein</label>
        </div>

        <div class="filter-item toggle-item">
            <label><input id="under500" type="checkbox" /> Under 500 kcal</label>
        </div>

        <div class="filter-item toggle-item">
            <label><input id="vegOnly" type="checkbox" /> Veg Only</label>
        </div>

        <div class="filter-item">
            <button id="resetFilters" class="btn reset-btn">Reset</button>
        </div>
    </div>
</section>

@section Styles {
    <style>
        .verification-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: #e6f9f0;
            color: #2d6a4f;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-bottom: 10px;
            border: 1px solid #c2f0d5;
        }

        .nutrition-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 8px;
            margin: 12px 0;
            padding: 10px;
            background: #f8f9fa;
            border-radius: 8px;
            font-size: 0.8rem;
        }

        .nutrition-item {
            display: flex;
            justify-content: space-between;
            color: #666;
        }

        .nutrition-item strong {
            color: #333;
        }

        .nutritionist-info {
            font-size: 0.7rem;
            color: #888;
            font-style: italic;
            margin-top: 5px;
        }
    </style>
}

<!-- Corporate Productivity Menu -->
<section id="corporateMeals" class="container my-5" aria-labelledby="corporateHeading">
    <h2 id="corporateHeading">Corporate Specials – Productivity Menu</h2>

    <div class="combos-grid" role="list">
        @if (Model != null && Model.Any())
        {
            foreach (var food in Model)
            {
                <article class="combo-card" role="listitem"
                         data-calories="@food.Calories"
                         data-price="@food.Price"
                         data-veg="true">
                    
                    @if (food.IsVerified)
                    {
                        <div class="verification-badge">
                            <i class="bi bi-patch-check-fill"></i> Verified by Nutritionist
                        </div>
                    }

                    <div class="combo-badge">@food.Calories kcal</div>
                    <!-- LEFT SIDE (TEXT CONTENT) -->
                    <div class="combo-content">
                        <h3 class="combo-title">@food.Name</h3>

                        <div class="nutrition-grid">
                            <div class="nutrition-item"><span>Protein:</span> <strong>@(food.Protein ?? 0)g</strong></div>
                            <div class="nutrition-item"><span>Carbs:</span> <strong>@(food.Carbs ?? 0)g</strong></div>
                            <div class="nutrition-item"><span>Fat:</span> <strong>@(food.Fat ?? 0)g</strong></div>
                            <div class="nutrition-item"><span>Prep:</span> <strong>@food.PreparationTime</strong></div>
                        </div>

                        <div class="combo-price">₹<strong>@food.Price</strong></div>
                        
                        @if (food.Nutritionist != null)
                        {
                            <div class="nutritionist-info">
                                Verified by @food.Nutritionist.Name, @food.Nutritionist.Qualification
                            </div>
                        }

                        <button class="btn add-cart" data-id="@food.Id">Add to Cart</button>
                    </div>

                    <!-- RIGHT SIDE (IMAGE) -->
                    <div class="combo-image">
                        <img src="@(string.IsNullOrEmpty(food.ImagePath) ? "/images/menu items/default.png" : food.ImagePath)"
                             alt="@food.Name"
                             loading="lazy" />
                    </div>
                </article>
            }
        }
        else
        {
            <div class="alert alert-info w-100">No corporate special meals found in the database. Please run SeedData.</div>
        }
    </div>
</section>

@section Scripts {
    <script src="~/js/corporate.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const priceRange = document.getElementById("priceRange");
            const priceValue = document.getElementById("priceValue");
            const highProtein = document.getElementById("highProtein");
            const under500 = document.getElementById("under500");
            const vegOnly = document.getElementById("vegOnly");
            const resetBtn = document.getElementById("resetFilters");
            const comboCards = document.querySelectorAll(".combo-card");

            function applyFilters() {
                const maxPrice = parseInt(priceRange.value);
                priceValue.textContent = "₹" + maxPrice;

                comboCards.forEach(card => {
                    const price = parseInt(card.dataset.price);
                    const calories = parseInt(card.dataset.calories);
                    const isVeg = card.dataset.veg === "true";

                    let visible = true;

                    if (price > maxPrice) visible = false;
                    if (highProtein.checked && calories < 600) visible = false;
                    if (under500.checked && calories >= 500) visible = false;
                    if (vegOnly.checked && !isVeg) visible = false;

                    card.style.display = visible ? "flex" : "none";
                });
            }

            if(priceRange) priceRange.addEventListener("input", applyFilters);
            if(highProtein) highProtein.addEventListener("change", applyFilters);
            if(under500) under500.addEventListener("change", applyFilters);
            if(vegOnly) vegOnly.addEventListener("change", applyFilters);

            if(resetBtn) {
                resetBtn.addEventListener("click", () => {
                    priceRange.value = 120;
                    highProtein.checked = false;
                    under500.checked = false;
                    vegOnly.checked = false;
                    applyFilters();
                });
            }
        });
    </script>
}
