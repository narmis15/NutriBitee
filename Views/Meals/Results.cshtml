@model List<NUTRIBITE.Models.Food>

@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

@section Styles {
    <style>
        .verification-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: #e6f9f0;
            color: #2d6a4f;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 600;
            margin-bottom: 8px;
            border: 1px solid #c2f0d5;
        }

        .nutrition-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 5px;
            margin: 10px 0;
            padding: 8px;
            background: #f8f9fa;
            border-radius: 6px;
            font-size: 0.75rem;
        }

        .nutrition-item {
            display: flex;
            justify-content: space-between;
            color: #666;
        }

        .nutrition-item strong {
            color: #333;
        }

        .nutritionist-info {
            font-size: 0.65rem;
            color: #888;
            font-style: italic;
            margin-bottom: 10px;
        }
    </style>
}

<h2 style="margin-bottom:30px;">
    Search Results for "@ViewBag.Query"
</h2>

<div class="row">

    @foreach (var food in Model)
    {
        <div class="col-lg-4 col-md-6 mb-4">

            <div class="card h-100 shadow-sm">

                <img src="@food.ImagePath"
                     class="card-img-top"
                     style="height:220px; object-fit:cover;" />

                <div class="card-body">
                    
                    @if (food.IsVerified)
                    {
                        <div class="verification-badge">
                            <i class="bi bi-patch-check-fill"></i> Verified Expert
                        </div>
                    }

                    <h5 class="card-title">@food.Name</h5>

                    <p class="text-muted small mb-2">
                        @food.Description
                    </p>

                    <div class="nutrition-grid">
                        <div class="nutrition-item"><span>Calories:</span> <strong>@food.Calories kcal</strong></div>
                        <div class="nutrition-item"><span>Protein:</span> <strong>@(food.Protein ?? 0)g</strong></div>
                        <div class="nutrition-item"><span>Carbs:</span> <strong>@(food.Carbs ?? 0)g</strong></div>
                        <div class="nutrition-item"><span>Fat:</span> <strong>@(food.Fat ?? 0)g</strong></div>
                    </div>

                    @if (food.Nutritionist != null)
                    {
                        <div class="nutritionist-info">
                            Expert: @food.Nutritionist.Name
                        </div>
                    }

                    <h6 class="fw-bold mt-2">₹ @food.Price</h6>

                    <!-- ONLY BUTTON -->
                    <button class="btn btn-success w-100 mt-2 addToCartBtn"
                            data-id="@food.Id">
                        Add To Cart
                    </button>

                </div>

            </div>

        </div>
    }

</div>
<script>

    document.querySelectorAll(".addToCartBtn").forEach(btn => {

        btn.addEventListener("click", function () {

            const foodId = this.dataset.id;

            fetch("/Cart/AddToCart", {

                method: "POST",

                headers: {
                    "Content-Type": "application/x-www-form-urlencoded"
                },

                body: "foodId=" + foodId

            })
            .then(response => response.json())
            .then(data => {

                if (data.success) {

                    alert("Item added to cart");

                    // Update cart count
                    fetch("/Cart/GetCartCount")
                    .then(res => res.json())
                    .then(countData => {

                        if(countData.success){
                            document.getElementById("cartCount").innerText = countData.count;
                        }

                    });

                }
                else {
                    alert("Please login first");
                }

            });

        });

    });

</script>