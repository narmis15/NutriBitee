@{
    ViewData["Title"] = "Bulk — NutriBite";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<link rel="stylesheet" href="~/css/bulk.css" />

<div class="bulk-page container-fluid">
    <div class="bulk-inner container bulk-container py-4">

        <!-- HERO CAROUSEL: visual banners only (1 image per slide) -->
        <section class="bulk-hero mb-4" aria-label="Bulk hero banners">
            <div id="bulkCarousel"
                 class="carousel slide"
                 data-bs-ride="carousel"
                 data-bs-interval="5000"
                 data-bs-pause="hover"
                 data-bs-wrap="true">

                <div class="carousel-indicators">
                    @for (int i = 0; i < 6; i++)
                    {
                        <button type="button"
                                data-bs-target="#bulkCarousel"
                                data-bs-slide-to="@i"
                                class="@(i == 0 ? "active" : "")"
                                aria-current="@(i == 0 ? "true" : null)"
                                aria-label="Slide @(i + 1)"></button>
                    }
                </div>

                <div class="carousel-inner">
                    @for (int i = 1; i <= 6; i++)
                    {
                        var active = i == 1 ? "active" : "";
                        var src = Url.Content($"~/images/bulk/banner{i}.png");
                        <div class="carousel-item @active">
                            <img src="@src"
                                 alt="Bulk banner @i"
                                 class="bulk-hero-banner w-100"
                                 loading="lazy"
                                 onerror="this.onerror=null;this.src='@Url.Content("~/images/bulk/default.jpg")';" />
                        </div>
                    }
                </div>

                <button class="carousel-control-prev" type="button" data-bs-target="#bulkCarousel" data-bs-slide="prev" aria-label="Previous">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#bulkCarousel" data-bs-slide="next" aria-label="Next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                </button>
            </div>
        </section>

        <!-- CATEGORY CARDS (unchanged) -->
        <section class="bulk-categories mb-5" aria-label="Bulk categories">
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <a class="cat-card cat-meals" asp-controller="Bulk" asp-action="Meals" role="button" aria-label="Meals category">
                        <div class="cat-overlay"></div>
                        <div class="cat-text">Meals</div>
                    </a>
                </div>

                <div class="col-12 col-md-4">
                    <a class="cat-card cat-snacks" asp-controller="Bulk" asp-action="Snacks" role="button" aria-label="Snacks category">
                        <div class="cat-overlay"></div>
                        <div class="cat-text">Snacks</div>
                    </a>
                </div>

                <div class="col-12 col-md-4">
                    <a class="cat-card cat-foodbox" asp-controller="Bulk" asp-action="FoodBox" role="button" aria-label="FoodBox category">
                        <div class="cat-overlay"></div>
                        <div class="cat-text">FoodBox</div>
                    </a>
                </div>
            </div>
        </section>

    </div>
</div>

@section Scripts {
    <script>
        // create Carousel instance to ensure settings (Bootstrap 5)
        (function () {
            const el = document.getElementById('bulkCarousel');
            if (!el) return;
            // ensure an instance exists and uses provided data attributes
            bootstrap.Carousel.getOrCreateInstance(el);
        })();
    </script>
}