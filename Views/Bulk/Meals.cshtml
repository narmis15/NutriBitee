@{
    ViewData["Title"] = "Bulk Meals — NutriBite";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";

    var items = ViewBag.Items as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<link rel="stylesheet" href="~/css/bulk.css" />

<div class="bulk-page">
    <div class="bulk-container">

        <!-- Page Title -->
        <div class="mb-5">
            <h2 class="fw-bold">Bulk Meals Selection</h2>
            <p class="text-muted">High-quality, nutritious meals for your events or daily needs.</p>
        </div>


        <!-- Packaging & Filters -->
        <div class="packaging-options">
            <div class="row align-items-center">

                <div class="col-lg-8">
                    <div class="d-flex flex-column flex-md-row gap-3">
                        <label class="packaging-label">
                            <input type="radio" name="packaging" class="d-none" checked />
                            <div class="packaging-content">
                                <strong>Individual Packaging</strong>
                                <div class="text-muted small">Each meal packed separately</div>
                                <div class="small fw-bold mt-1">MOQ: 1</div>
                            </div>
                        </label>

                        <label class="packaging-label">
                            <input type="radio" name="packaging" class="d-none" />
                            <div class="packaging-content">
                                <strong>Bulk Packaging</strong>
                                <div class="text-muted small">Meals packed together</div>
                                <div class="small fw-bold mt-1">MOQ: 15</div>
                            </div>
                        </label>
                    </div>
                </div>


                <!-- Veg Filter -->
                <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">
                    <div class="d-flex gap-2 justify-content-lg-end">
                        <span class="diet-pill active" data-val="veg">
                            <span class="dot veg"></span> Veg Only
                        </span>

                        <span class="diet-pill" data-val="nonveg">
                            <span class="dot nonveg"></span> Non Veg
                        </span>
                    </div>
                </div>

            </div>
        </div>



        <!-- Meal List -->
        <div class="row">
            @foreach (var it in items)
            {
                var isVeg = (it.IsVeg ? "veg" : "nonveg");
                var img = (it.ImagePath ?? "/images/bulk/default.jpg").ToString();

                <div class="col-12 mb-4">

                    <div class="meal-card card shadow-sm p-4" data-veg="@isVeg">

                        <div class="row align-items-center">

                            <!-- LEFT CONTENT -->
                            <div class="col-md-8">

                                <div class="veg-indicator mb-2">
                                    <span class="badge @(it.IsVeg ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") border">
                                        @(it.IsVeg ? "🟢 Vegetarian" : "🔴 Non-Vegetarian")
                                    </span>
                                </div>

                                <h3 class="meal-title">@it.Name</h3>

                                <div class="meal-price-container">
                                    <div class="meal-price" data-base-price="@it.Price">
                                        ₹@it.Price <span class="text-muted small fw-normal">/ per meal</span>
                                    </div>
                                    <div class="discount-info text-success small fw-bold mt-1" style="display:none;"></div>
                                    <div class="final-price fw-bold mt-1" style="display:none; font-size: 1.1rem;"></div>
                                </div>

                                <p class="meal-desc mt-2">
                                    @(it.Description ?? "Freshly prepared meal with high-quality ingredients, balanced nutrition, and authentic taste.")
                                </p>

                            </div>


                            <!-- RIGHT CONTENT -->
                            <div class="col-md-4 text-md-end">

                                <div class="meal-img-box mb-3">
                                    <img src="@img"
                                         class="meal-img"
                                         alt="@it.Name"
                                         onerror="this.src='/images/bulk/default.jpg'" />
                                </div>

                                <div class="d-flex flex-column align-items-md-end gap-3">
                                    <div class="qty-suggest-buttons d-flex gap-2 mb-1">
                                        <button class="btn btn-xs btn-outline-secondary py-0 px-2 rounded-pill small-btn" onclick="setQty(this, 50)">50</button>
                                        <button class="btn btn-xs btn-outline-secondary py-0 px-2 rounded-pill small-btn" onclick="setQty(this, 100)">100</button>
                                        <button class="btn btn-xs btn-outline-secondary py-0 px-2 rounded-pill small-btn" onclick="setQty(this, 200)">200</button>
                                        <button class="btn btn-xs btn-outline-secondary py-0 px-2 rounded-pill small-btn" onclick="setQty(this, 500)">500</button>
                                    </div>
                                    <div class="qty-box">
                                        <button class="qty-btn qty-decrease" aria-label="Decrease quantity">−</button>
                                        <input type="number" class="qty-input" value="@(it.MOQ ?? 1)" min="@(it.MOQ ?? 1)" max="1000" data-moq="@(it.MOQ ?? 1)" />
                                        <button class="qty-btn qty-increase" aria-label="Increase quantity">+</button>
                                    </div>
                                    <div id="discountHint" class="text-primary extra-small fw-bold" style="display:none;"></div>
                                    <div class="qty-validation-msg text-danger small" style="display:none;"></div>

                                    <button class="btn btn-add-cart w-100 w-md-auto" data-id="@it.Id">
                                        Add to Cart
                                    </button>
                                </div>

                            </div>

                        </div>

                    </div>

                </div>
            }
        </div>

    </div>
</div>

@section Styles {
    <style>
        .dot { height: 8px; width: 8px; border-radius: 50%; display: inline-block; }
        .dot.veg { background-color: #28a745; }
        .dot.nonveg { background-color: #dc3545; }
    </style>
}

@section Scripts {

    <script>

        document.addEventListener("DOMContentLoaded", function(){

            /* Veg / Nonveg filter */

            document.querySelectorAll(".diet-pill").forEach(function(pill){

                pill.addEventListener("click", function(){

                    document.querySelectorAll(".diet-pill")
                        .forEach(p=>p.classList.remove("active"));

                    this.classList.add("active");

                    let val = this.dataset.val;

                    document.querySelectorAll("[data-veg]").forEach(function(card){

                        let type = card.getAttribute("data-veg");

                        card.style.display = (type === val) ? "" : "none";

                    });

                });

            });



            /* Quantity buttons and validation */
            function updatePriceAndDiscount(card, inputVal) {
                let basePriceElem = card.querySelector(".meal-price");
                let basePrice = parseFloat(basePriceElem.getAttribute("data-base-price"));
                let qty = parseInt(inputVal);
                
                let discountPercent = 0;
                let nextSlab = 0;
                let nextDiscount = 0;

                if (qty >= 500) { discountPercent = 30; }
                else if (qty >= 200) { discountPercent = 22; nextSlab = 500; nextDiscount = 30; }
                else if (qty >= 100) { discountPercent = 15; nextSlab = 200; nextDiscount = 22; }
                else if (qty >= 50) { discountPercent = 8; nextSlab = 100; nextDiscount = 15; }
                else { nextSlab = 50; nextDiscount = 8; }

                let discountInfo = card.querySelector(".discount-info");
                let finalPriceElem = card.querySelector(".final-price");
                let discountHint = card.querySelector("#discountHint");
                
                if (discountPercent > 0) {
                    let discountedPrice = basePrice * (1 - (discountPercent / 100));
                    basePriceElem.style.textDecoration = "line-through";
                    basePriceElem.style.color = "#6c757d";
                    
                    discountInfo.style.display = "block";
                    discountInfo.innerText = `🎉 ${discountPercent}% Bulk Discount Applied!`;
                    
                    finalPriceElem.style.display = "block";
                    finalPriceElem.innerText = `Final Price: ₹${discountedPrice.toFixed(2)} / meal`;
                    finalPriceElem.style.color = "#28a745";
                } else {
                    basePriceElem.style.textDecoration = "none";
                    basePriceElem.style.color = "var(--text-dark)";
                    discountInfo.style.display = "none";
                    finalPriceElem.style.display = "none";
                }

                if (nextSlab > 0) {
                    discountHint.innerText = `Add ${nextSlab - qty} more to unlock ${nextDiscount}% discount!`;
                    discountHint.style.display = "block";
                } else {
                    discountHint.style.display = "none";
                    if (discountPercent === 30) {
                        discountHint.innerText = "🔥 Best Value Reached!";
                        discountHint.style.display = "block";
                    }
                }
            }

            window.setQty = function(btn, val) {
                let card = btn.closest(".meal-card");
                let input = card.querySelector(".qty-input");
                input.value = val;
                input.dispatchEvent(new Event('input'));
            };

            document.querySelectorAll(".meal-card").forEach(function(card){

                let input = card.querySelector(".qty-input");
                let moq = parseInt(input.getAttribute("data-moq")) || 1;
                let validationMsg = card.querySelector(".qty-validation-msg");
                let addBtn = card.querySelector(".btn-add-cart");

                function validateQuantity() {
                    let val = parseInt(input.value) || 0;
                    if (val < moq) {
                        validationMsg.innerText = `Minimum order quantity is ${moq}`;
                        validationMsg.style.display = "block";
                        addBtn.disabled = true;
                    } else if (val > 1000) {
                        validationMsg.innerText = `Maximum order quantity is 1000`;
                        validationMsg.style.display = "block";
                        addBtn.disabled = true;
                    } else {
                        validationMsg.style.display = "none";
                        addBtn.disabled = false;
                        updatePriceAndDiscount(card, val);
                    }
                }

                input.addEventListener("input", validateQuantity);
                input.addEventListener("blur", function() {
                    let val = parseInt(input.value) || 0;
                    if (val < moq) {
                        input.value = moq;
                        validateQuantity();
                    } else if (val > 1000) {
                        input.value = 1000;
                        validateQuantity();
                    }
                });

                card.querySelector(".qty-decrease").addEventListener("click", function(){
                    let v = Math.max(moq, parseInt(input.value) - 1);
                    input.value = v;
                    validateQuantity();
                });

                card.querySelector(".qty-increase").addEventListener("click", function(){
                    let v = Math.min(1000, parseInt(input.value) + 1);
                    input.value = v;
                    validateQuantity();
                });

                // Initialize price/discount
                validateQuantity();
            });



            /* Add to Cart */

            document.querySelectorAll(".btn-add-cart")
            .forEach(function(btn){

                btn.addEventListener("click", function(){

                    let id = this.dataset.id;
                    let card = this.closest(".meal-card");
                    let qty = card.querySelector(".qty-input").value;

                    fetch('/Cart/AddToCart',{
                        method:'POST',
                        headers:{'Content-Type':'application/json'},
                        body: JSON.stringify({
                            productId: parseInt(id),
                            quantity: parseInt(qty),
                            isBulk: true
                        })
                    })
                    .then(r=>r.json())
                    .then(res=>{

                        if(res.success){
                            const originalText = btn.innerText;
                            btn.innerHTML = '<i class="bi bi-check2"></i> Added';
                            btn.classList.add('bg-success');
                            
                            if (window.updateCartCount) {
                                window.updateCartCount();
                            }

                            setTimeout(()=>{
                                btn.innerText = originalText;
                                btn.classList.remove('bg-success');
                            },1500);
                        }
                        else{
                            alert(res.message || "Please login first to add items to your cart.");
                            if (res.message === "Please login first") {
                                window.location.href = '/Auth/Login';
                            }
                        }

                    });

                });

            });

        });

    </script>

}
