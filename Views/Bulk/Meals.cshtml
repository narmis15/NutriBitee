@{
    ViewData["Title"] = "Bulk Meals — NutriBite";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";

    var items = ViewBag.Items as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<link rel="stylesheet" href="~/css/bulk.css" />

<div class="bulk-page">
    <div class="bulk-container">

        <!-- Page Title -->
        <div class="mb-5">
            <h2 class="fw-bold">Bulk Meals Selection</h2>
            <p class="text-muted">High-quality, nutritious meals for your events or daily needs.</p>
        </div>


        <!-- Packaging & Filters -->
        <div class="packaging-options">
            <div class="row align-items-center">

                <div class="col-lg-8">
                    <div class="d-flex flex-column flex-md-row gap-3">
                        <label class="packaging-label">
                            <input type="radio" name="packaging" class="d-none" checked />
                            <div class="packaging-content">
                                <strong>Individual Packaging</strong>
                                <div class="text-muted small">Each meal packed separately</div>
                                <div class="small fw-bold mt-1">MOQ: 1</div>
                            </div>
                        </label>

                        <label class="packaging-label">
                            <input type="radio" name="packaging" class="d-none" />
                            <div class="packaging-content">
                                <strong>Bulk Packaging</strong>
                                <div class="text-muted small">Meals packed together</div>
                                <div class="small fw-bold mt-1">MOQ: 15</div>
                            </div>
                        </label>
                    </div>
                </div>


                <!-- Veg Filter -->
                <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">
                    <div class="d-flex gap-2 justify-content-lg-end">
                        <span class="diet-pill active" data-val="veg">
                            <span class="dot veg"></span> Veg Only
                        </span>

                        <span class="diet-pill" data-val="nonveg">
                            <span class="dot nonveg"></span> Non Veg
                        </span>
                    </div>
                </div>

            </div>
        </div>



        <!-- Meal List -->
        <div class="row">
            @foreach (var it in items)
            {
                var isVeg = (it.IsVeg ? "veg" : "nonveg");
                var img = (it.ImagePath ?? "/images/bulk/default.jpg").ToString();

                <div class="col-12 mb-4">

                    <div class="meal-card card shadow-sm p-4" data-veg="@isVeg">

                        <div class="row align-items-center">

                            <!-- LEFT CONTENT -->
                            <div class="col-md-8">

                                <div class="veg-indicator mb-2">
                                    <span class="badge @(it.IsVeg ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") border">
                                        @(it.IsVeg ? "🟢 Vegetarian" : "🔴 Non-Vegetarian")
                                    </span>
                                </div>

                                <h3 class="meal-title">@it.Name</h3>

                                <div class="meal-price">
                                    ₹@it.Price <span class="text-muted small fw-normal">/ per meal</span>
                                </div>

                                <p class="meal-desc">
                                    @(it.Description ?? "Freshly prepared meal with high-quality ingredients, balanced nutrition, and authentic taste.")
                                </p>

                            </div>


                            <!-- RIGHT CONTENT -->
                            <div class="col-md-4 text-md-end">

                                <div class="meal-img-box mb-3">
                                    <img src="@img"
                                         class="meal-img"
                                         alt="@it.Name"
                                         onerror="this.src='/images/bulk/default.jpg'" />
                                </div>

                                <div class="d-flex flex-column align-items-md-end gap-3">
                                    <div class="qty-box">
                                        <button class="qty-btn qty-decrease" aria-label="Decrease quantity">−</button>
                                        <input type="text" class="qty-input" value="1" readonly />
                                        <button class="qty-btn qty-increase" aria-label="Increase quantity">+</button>
                                    </div>

                                    <button class="btn btn-add-cart w-100 w-md-auto" data-id="@it.Id">
                                        Add to Cart
                                    </button>
                                </div>

                            </div>

                        </div>

                    </div>

                </div>
            }
        </div>

    </div>
</div>

@section Styles {
    <style>
        .dot { height: 8px; width: 8px; border-radius: 50%; display: inline-block; }
        .dot.veg { background-color: #28a745; }
        .dot.nonveg { background-color: #dc3545; }
    </style>
}

@section Scripts {

    <script>

        document.addEventListener("DOMContentLoaded", function(){

            /* Veg / Nonveg filter */

            document.querySelectorAll(".diet-pill").forEach(function(pill){

                pill.addEventListener("click", function(){

                    document.querySelectorAll(".diet-pill")
                        .forEach(p=>p.classList.remove("active"));

                    this.classList.add("active");

                    let val = this.dataset.val;

                    document.querySelectorAll("[data-veg]").forEach(function(card){

                        let type = card.getAttribute("data-veg");

                        card.style.display = (type === val) ? "" : "none";

                    });

                });

            });



            /* Quantity buttons */

            document.querySelectorAll(".meal-card").forEach(function(card){

                let input = card.querySelector(".qty-input");

                card.querySelector(".qty-decrease")
                .addEventListener("click", function(){

                    let v = Math.max(1, parseInt(input.value) - 1);
                    input.value = v;

                });

                card.querySelector(".qty-increase")
                .addEventListener("click", function(){

                    let v = parseInt(input.value) + 1;
                    input.value = v;

                });

            });



            /* Add to Cart */

            document.querySelectorAll(".btn-add-cart")
            .forEach(function(btn){

                btn.addEventListener("click", function(){

                    let id = this.dataset.id;
                    let card = this.closest(".meal-card");
                    let qty = card.querySelector(".qty-input").value;

                    fetch('/Cart/AddToCart',{
                        method:'POST',
                        headers:{'Content-Type':'application/json'},
                        body:JSON.stringify({
                            productId: parseInt(id),
                            quantity: parseInt(qty)
                        })
                    })
                    .then(r=>r.json())
                    .then(res=>{

                        if(res.success){
                            const originalText = btn.innerText;
                            btn.innerHTML = '<i class="bi bi-check2"></i> Added';
                            btn.classList.add('bg-success');
                            
                            if (window.updateCartCount) {
                                window.updateCartCount();
                            }

                            setTimeout(()=>{
                                btn.innerText = originalText;
                                btn.classList.remove('bg-success');
                            },1500);
                        }
                        else{
                            alert(res.message || "Please login first to add items to your cart.");
                            if (res.message === "Please login first") {
                                window.location.href = '/Auth/Login';
                            }
                        }

                    });

                });

            });

        });

    </script>

}
