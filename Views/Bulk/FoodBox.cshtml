@{
    ViewData["Title"] = "FoodBox — NutriBite";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";

    var predefined = ViewBag.Predefined as IEnumerable<dynamic>;
    var groups = ViewBag.CustomGroups;
}

<link rel="stylesheet" href="~/css/bulk.css" />

<div class="bulk-page">
    <div class="bulk-container">

        <!-- Page Header -->
        <div class="mb-5">
            <h2 class="fw-bold">Bulk FoodBox</h2>
            <p class="text-muted">Curated meal boxes or build your own custom combination.</p>
        </div>

        <!-- PREDEFINED BOXES -->
        <section class="mb-5">
            <h3 class="fw-bold mb-4">Predefined Boxes</h3>
            <div class="row">
                @foreach (var box in predefined)
                {
                    <div class="col-12 mb-4">
                        <div class="meal-card card shadow-sm p-4">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <h4 class="meal-title">@box.Name</h4>
                                    
                                    <div class="meal-price-container">
                                        <div class="meal-price" data-base-price="@box.Price">
                                            ₹@box.Price <span class="text-muted small fw-normal">/ per box</span>
                                        </div>
                                        <div class="discount-info text-success small fw-bold mt-1" style="display:none;"></div>
                                        <div class="final-price fw-bold mt-1" style="display:none; font-size: 1.1rem;"></div>
                                    </div>
                                    
                                    <p class="meal-desc mt-2">@box.Description</p>
                                </div>
                                <div class="col-md-4 text-md-end">
                                    <div class="meal-img-box mb-3">
                                        <img src="@box.ImagePath" class="meal-img" alt="@box.Name" />
                                    </div>
                                    
                                    <div class="d-flex flex-column align-items-md-end gap-3">
                                        <div class="qty-box">
                                            <button class="qty-btn qty-decrease" aria-label="Decrease quantity">−</button>
                                            <input type="number" class="qty-input" value="@(box.MOQ > 0 ? box.MOQ : 15)" min="@(box.MOQ > 0 ? box.MOQ : 15)" max="1000" data-moq="@(box.MOQ > 0 ? box.MOQ : 15)" />
                                            <button class="qty-btn qty-increase" aria-label="Increase quantity">+</button>
                                        </div>
                                        <div class="qty-validation-msg text-danger small" style="display:none;"></div>

                                        <button class="btn btn-add-cart btn-add-predefined w-100 w-md-auto" data-id="@box.Id">
                                            Add to Cart
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>

        <hr class="my-5 opacity-10" />

        <!-- CUSTOM FOODBOX -->
        <section class="mb-5">
            <h3 class="fw-bold mb-4">Customized FoodBox</h3>
            <div class="custom-box-card card shadow-lg border-0 p-4 mb-5" style="border-radius: var(--nb-radius-lg); background: linear-gradient(135deg, #fff 0%, #f8faf9 100%);">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h4 class="fw-bold mb-3">Build Your Box</h4>
                        <div class="d-flex align-items-baseline gap-2 mb-3">
                            <span class="fs-4 fw-bold text-success">₹</span>
                            <span id="boxPrice" class="fs-2 fw-bold text-success">0</span>
                            <span class="text-muted">total per box</span>
                        </div>
                        <div id="boxItemsContainer" class="p-3 bg-white rounded border mb-4" style="min-height: 60px;">
                            <p id="boxItems" class="text-muted mb-0">No Items Selected</p>
                        </div>
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div class="qty-box" style="background: #fff; border: 1px solid #ddd;">
                                <button class="qty-btn" onclick="let q=document.getElementById('customBoxQty'); q.value=Math.max(25, parseInt(q.value)-1)">−</button>
                                <input type="number" id="customBoxQty" class="qty-input" value="25" min="25" max="1000" style="width: 50px;" />
                                <button class="qty-btn" onclick="let q=document.getElementById('customBoxQty'); q.value=Math.min(1000, parseInt(q.value)+1)">+</button>
                            </div>
                            <span class="text-muted small">Minimum 25 boxes</span>
                        </div>

                        <button id="addCustomBox" class="btn btn-add-cart px-5 py-3" style="display:none;">
                            Add Custom Box to Cart
                        </button>
                    </div>
                    <div class="col-md-4 text-center mt-4 mt-md-0">
                        <img id="boxImage" src="/images/bulk/foodbox_fitness.png" class="img-fluid rounded-4 shadow-sm" style="max-width: 250px; transition: all 0.5s ease;" alt="Build your healthy box" />
                    </div>
                </div>
            </div>

            <!-- CUSTOM ITEM CATEGORIES -->
            <div class="accordion modern-accordion" id="foodboxAccordion">
                @{ int index = 0; }
                @foreach (var group in groups)
                {
                    var heading = "heading" + index;
                    var collapse = "collapse" + index;
                    <div class="accordion-item border-0 mb-3 shadow-sm rounded-4 overflow-hidden">
                        <h2 class="accordion-header" id="@heading">
                            <button class="accordion-button collapsed fw-bold py-3" type="button" data-bs-toggle="collapse" data-bs-target="#@collapse">
                                @group.Key
                            </button>
                        </h2>
                        <div id="@collapse" class="accordion-collapse collapse" data-bs-parent="#foodboxAccordion">
                            <div class="accordion-body p-0">
                                @foreach (var item in group)
                                {
                                    <div class="foodbox-item p-4 border-bottom">
                                        <div class="row align-items-center">
                                            <div class="col-md-8">
                                                <h6 class="fw-bold mb-1">@item.Name</h6>
                                                <div class="text-success fw-bold">₹@item.Price</div>
                                            </div>
                                            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                                                <div class="d-flex align-items-center justify-content-md-end gap-3">
                                                    <img src="@item.ImagePath" class="rounded-3 shadow-sm" style="width: 60px; height: 60px; object-fit: contain; background-color: #f8faf9;" />
                                                    <button class="btn btn-outline-success btn-add-box rounded-pill px-4"
                                                            data-id="@item.Id"
                                                            data-name="@item.Name"
                                                            data-price="@item.Price"
                                                            data-moq="25">
                                                        Add
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    index++;
                }
            </div>
        </section>

    </div>
</div>

@section Styles {
    <style>
        .modern-accordion .accordion-button:not(.collapsed) {
            background-color: var(--nb-primary-light);
            color: var(--nb-primary);
        }
        .modern-accordion .accordion-button:focus {
            box-shadow: none;
            border-color: rgba(0,0,0,0.125);
        }
        .foodbox-item:last-child { border-bottom: none; }
        .foodbox-item:hover { background-color: #fbfdfc; }
        
        /* Transition for box image */
        #boxImage.active { transform: scale(1.1) rotate(5deg); }
    </style>
}

@section Scripts {
    <script>
        // Quantity and discount logic for Predefined Boxes
        function updatePriceAndDiscount(card, inputVal) {
            let basePriceElem = card.querySelector(".meal-price");
            let basePrice = parseFloat(basePriceElem.getAttribute("data-base-price"));
            let qty = parseInt(inputVal);
            
            let discountPercent = 0;
            if (qty >= 200) discountPercent = 30;
            else if (qty >= 100) discountPercent = 20;
            else if (qty >= 50) discountPercent = 10;

            let discountInfo = card.querySelector(".discount-info");
            let finalPriceElem = card.querySelector(".final-price");
            
            if (discountPercent > 0) {
                let discountedPrice = basePrice * (1 - (discountPercent / 100));
                basePriceElem.style.textDecoration = "line-through";
                basePriceElem.style.color = "#6c757d";
                
                discountInfo.style.display = "block";
                discountInfo.innerText = `🔥 ${discountPercent}% Bulk Discount Applied!`;
                
                finalPriceElem.style.display = "block";
                finalPriceElem.innerText = `Final Price: ₹${discountedPrice.toFixed(2)} / box`;
                finalPriceElem.style.color = "#28a745";
            } else {
                basePriceElem.style.textDecoration = "none";
                basePriceElem.style.color = "var(--text-dark)";
                discountInfo.style.display = "none";
                finalPriceElem.style.display = "none";
            }
        }

        document.querySelectorAll(".meal-card").forEach(function(card){
            let input = card.querySelector(".qty-input");
            if (!input) return; // custom box might not have it
            
            let moq = parseInt(input.getAttribute("data-moq")) || 1;
            let validationMsg = card.querySelector(".qty-validation-msg");
            let addBtn = card.querySelector(".btn-add-predefined");

            function validateQuantity() {
                let val = parseInt(input.value) || 0;
                if (val < moq) {
                    validationMsg.innerText = `Minimum order quantity is ${moq}`;
                    validationMsg.style.display = "block";
                    if (addBtn) addBtn.disabled = true;
                } else if (val > 1000) {
                    validationMsg.innerText = `Maximum order quantity is 1000`;
                    validationMsg.style.display = "block";
                    if (addBtn) addBtn.disabled = true;
                } else {
                    validationMsg.style.display = "none";
                    if (addBtn) addBtn.disabled = false;
                    updatePriceAndDiscount(card, val);
                }
            }

            input.addEventListener("input", validateQuantity);
            input.addEventListener("blur", function() {
                let val = parseInt(input.value) || 0;
                if (val < moq) {
                    input.value = moq;
                    validateQuantity();
                } else if (val > 1000) {
                    input.value = 1000;
                    validateQuantity();
                }
            });

            card.querySelector(".qty-decrease").addEventListener("click", function(){
                let v = Math.max(moq, parseInt(input.value) - 1);
                input.value = v;
                validateQuantity();
            });

            card.querySelector(".qty-increase").addEventListener("click", function(){
                let v = Math.min(1000, parseInt(input.value) + 1);
                input.value = v;
                validateQuantity();
            });

            // Initialize price/discount
            validateQuantity();
        });

        let selectedItems = {};
        let totalPrice = 0;

        document.addEventListener("click", function(e){
            // Predefined Box Add
            if(e.target.classList.contains("btn-add-predefined")){
                let btn = e.target;
                let card = btn.closest(".meal-card");
                let qty = card.querySelector(".qty-input").value;
                let id = btn.dataset.id;
                
                fetch('/Cart/AddToCart', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        productId: parseInt(id),
                        quantity: parseInt(qty),
                        isBulk: true
                    })
                })
                .then(r => r.json())
                .then(res => {
                    if (res.success) {
                        const originalText = btn.innerText;
                        btn.innerHTML = '<i class="bi bi-check2"></i> Added';
                        btn.classList.add('bg-success');
                        
                        if (window.updateCartCount) window.updateCartCount();

                        setTimeout(()=>{
                            btn.innerText = originalText;
                            btn.classList.remove('bg-success');
                        }, 1500);
                    } else {
                        alert(res.message || "Failed to add to cart.");
                        if (res.message === "Please login first") window.location.href = '/Auth/Login';
                    }
                });
            }

            // Custom Item Add
            if(e.target.classList.contains("btn-add-box")){
                let btn = e.target;
                let name = btn.dataset.name;
                let price = parseInt(btn.dataset.price);
                selectedItems[name] = { price: price, qty: 1 };
                updateTotal();
                btn.outerHTML = `
                <div class="qty-box custom-item d-inline-flex" data-name="${name}" data-price="${price}" data-min="1">
                    <button class="qty-btn minus">−</button>
                    <span class="qty-input px-2">1</span>
                    <button class="qty-btn plus">+</button>
                </div>`;
            }

            // Final Custom Box Add
            if(e.target.id === "addCustomBox"){
                const itemNames = Object.keys(selectedItems).map(name => `${name} x ${selectedItems[name].qty}`).join(', ');
                const customQty = parseInt(document.getElementById('customBoxQty').value) || 25;

                const requestData = {
                    productId: 0, // 0 indicates we need to create it
                    quantity: customQty,
                    isBulk: true,
                    itemName: "Custom FoodBox: " + itemNames.substring(0, 30) + (itemNames.length > 30 ? "..." : ""),
                    price: totalPrice,
                    category: "Custom FoodBox",
                    description: "Custom box containing: " + itemNames
                };

                fetch('/Cart/AddToCart', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(requestData)
                })
                .then(r => r.json())
                .then(res => {
                    if (res.success) {
                        alert('Custom Box added to cart!');
                        location.reload();
                    } else {
                        alert(res.message || "Failed to add to cart.");
                        if (res.message === "Please login first") window.location.href = '/Auth/Login';
                    }
                });
            }

            // Plus Button
            if(e.target.classList.contains("plus")){
                let parent = e.target.parentElement;
                let qtyElement = parent.querySelector(".qty-input");
                let qty = parseInt(qtyElement.innerText) + 1;
                qtyElement.innerText = qty;
                if(parent.dataset.name){
                    let name = parent.dataset.name;
                    selectedItems[name].qty = qty;
                    updateTotal();
                }
            }

            // Minus Button
            if(e.target.classList.contains("minus")){
                let parent = e.target.parentElement;
                let min = parseInt(parent.dataset.min);
                let qtyElement = parent.querySelector(".qty-input");
                let qty = parseInt(qtyElement.innerText);

                if(qty > min){
                    qtyElement.innerText = qty - 1;
                    if(parent.dataset.name){
                        let name = parent.dataset.name;
                        selectedItems[name].qty = qty - 1;
                        updateTotal();
                    }
                } else {
                    if(parent.dataset.name){
                        let name = parent.dataset.name;
                        delete selectedItems[name];
                        updateTotal();
                    }
                    let addBtn = document.createElement("button");
                    if(parent.classList.contains("predefined")){
                        addBtn.className = "btn btn-add-cart btn-add-predefined mt-2";
                        addBtn.dataset.id = parent.dataset.id;
                        addBtn.innerText = "Add to Cart";
                    } else {
                        addBtn.className = "btn btn-outline-success btn-add-box rounded-pill px-4";
                        addBtn.dataset.name = parent.dataset.name;
                        addBtn.dataset.price = parent.dataset.price;
                        addBtn.innerText = "Add";
                    }
                    parent.replaceWith(addBtn);
                }
            }
        });

        function updateTotal(){
            totalPrice = 0;
            let items = [];
            for(let key in selectedItems){
                let item = selectedItems[key];
                totalPrice += item.price * item.qty;
                items.push(`<span class="badge bg-light text-dark border me-1 mb-1">${key} x ${item.qty}</span>`);
            }
            document.getElementById("boxPrice").innerText = totalPrice;
            document.getElementById("boxItems").innerHTML = items.length ? items.join("") : "No Items Selected";

            const boxImg = document.getElementById("boxImage");
            if(items.length === 0){
                boxImg.src = "/images/bulk/customize foodbox.png";
                boxImg.classList.remove("active");
                document.getElementById("addCustomBox").style.display = "none";
            } else {
                boxImg.src = "/images/bulk/boxFilled.png";
                boxImg.classList.add("active");
                document.getElementById("addCustomBox").style.display = "inline-block";
            }
        }
    </script>
}
