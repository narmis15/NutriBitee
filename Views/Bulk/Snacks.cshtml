@{
    ViewData["Title"] = "Bulk Snacks — NutriBite";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";

    var items = ViewBag.Items as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<link rel="stylesheet" href="~/css/bulk.css" />

<div class="bulk-category container bulk-container py-4">
    <div class="page-header">
        <h2 class="page-title">Snacks</h2>
    </div>

    <section class="mb-4">
        <div class="row g-3">
            <div class="col-12 col-md-8">
                <div class="pkg-selector">
                    <label class="pkg-option">
                        <div class="title"><input type="radio" name="packaging" value="individual" checked /> Individual Packaging</div>
                        <div class="helper">Each snack packed separately</div>
                        <div class="moq">MOQ: 1</div>
                    </label>

                    <label class="pkg-option">
                        <div class="title"><input type="radio" name="packaging" value="bulk" /> Bulk Packaging</div>
                        <div class="helper">Snacks packed together for large orders</div>
                        <div class="moq">MOQ: 30</div>
                    </label>
                </div>
            </div>

            <div class="col-12 col-md-4">
                <div class="diet-pills">
                    <div class="pill pill-veg active" data-val="veg" role="button" tabindex="0"><span class="dot"></span> Veg</div>
                    <div class="pill pill-nonveg" data-val="nonveg" role="button" tabindex="0"><span class="dot"></span> Non Veg</div>
                </div>
            </div>
        </div>
    </section>

    <section>
        <div class="row g-3">
            @foreach (var it in items)
            {
                var isVeg = (it.IsVeg ? "veg" : "nonveg");
                var img = (it.ImagePath ?? "/images/bulk/default.jpg").ToString();
            <div class="col-12">
                <div class="meal-card" data-veg="@isVeg">
                    <div class="row gx-3">
                        <div class="col-12 col-md-9">
                            <h3 class="title">@it.Name</h3>
                            <div class="price">₹@it.Price</div>
                            <div class="desc">@((it.ShortDesc ?? it.ShortDescription) ?? "")</div>
                            <a href="@Url.Action("Details", "Menu", new { id = it.Id })" class="details-link">View Details →</a>
                        </div>

                        <div class="col-12 col-md-3 text-end">
                            <div class="meal-image">
                                <img src="@img" alt="@it.Name" onerror="this.onerror=null;this.src='/images/bulk/default.jpg';" />
                            </div>

                            <div class="qty-add mt-2">
                                <div class="qty" data-id="@it.Id">
                                    <button class="qty-decrease" type="button">−</button>
                                    <input type="text" class="qty-input" value="1" />
                                    <button class="qty-increase" type="button">+</button>
                                </div>

                                <button class="btn-add-cart" data-id="@it.Id">Add to Cart</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            }
        </div>
    </section>
</div>

@section Scripts {
<script>
(function(){
    // reuse same behavior as Meals page
    const pills = document.querySelectorAll('.pill');
    function setActivePill(val) {
        pills.forEach(p => p.classList.toggle('active', p.dataset.val === val));
        document.querySelectorAll('[data-veg]').forEach(el => {
            const veg = el.getAttribute('data-veg');
            el.style.display = (val === 'veg' && veg !== 'veg') || (val === 'nonveg' && veg !== 'nonveg') ? 'none' : '';
        });
    }
    pills.forEach(p => {
        p.addEventListener('click', () => setActivePill(p.dataset.val));
        p.addEventListener('keypress', (e) => { if(e.key === 'Enter') setActivePill(p.dataset.val); });
    });

    document.querySelectorAll('.meal-card .qty').forEach(function(container){
        const input = container.querySelector('.qty-input');
        container.querySelector('.qty-decrease').addEventListener('click', function(){ 
            let v = Math.max(1, parseInt(input.value || '1') - 1); input.value = v;
        });
        container.querySelector('.qty-increase').addEventListener('click', function(){ 
            let v = Math.max(1, parseInt(input.value || '1') + 1); input.value = v;
        });
        input.addEventListener('input', function(){ if(!/^\d+$/.test(this.value)) this.value = '1'; });
    });

    document.querySelectorAll('.btn-add-cart').forEach(function(btn){
        btn.addEventListener('click', function(){
            const id = parseInt(this.dataset.id);
            const container = this.closest('.meal-card');
            const qtyInput = container.querySelector('.qty-input');
            const qty = Math.max(1, parseInt(qtyInput.value || '1'));

            fetch('/Cart/AddToCart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId: id, quantity: qty })
            })
            .then(r => r.json())
            .then(res => {
                if(res && res.success) {
                    this.innerText = 'Added ✓';
                    setTimeout(()=> this.innerText = 'Add to Cart', 1200);
                } else {
                    alert(res?.message || 'Please login or try again');
                }
            }).catch(()=> alert('Server error'));
        });
    });

})();
</script>
}   