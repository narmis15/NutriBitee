@model NUTRIBITE.Models.Food
@{
    ViewData["Title"] = Model.Name + " - Recipe";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    var recipe = Model.Recipe;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Header Section -->
            <div class="card border-0 shadow-sm overflow-hidden mb-4">
                <div class="row g-0">
                    <div class="col-md-5">
                        <img src="@(string.IsNullOrEmpty(recipe?.ImagePath) ? Model.ImagePath : recipe.ImagePath)" 
                             class="img-fluid h-100 w-100" style="object-fit: cover; min-height: 300px;" alt="@Model.Name">
                    </div>
                    <div class="col-md-7">
                        <div class="card-body p-4 p-lg-5">
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb mb-3">
                                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-success">Home</a></li>
                                    <li class="breadcrumb-item active">Recipe</li>
                                </ol>
                            </nav>
                            
                            @if (Model.IsVerified)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle mb-3 px-3 py-2">
                                    <i class="bi bi-patch-check-fill me-1"></i> Nutritionist Verified
                                </span>
                            }

                            <h1 class="display-5 fw-bold mb-3">@Model.Name</h1>
                            <p class="text-muted lead mb-4">@Model.Description</p>

                            <div class="d-flex flex-wrap gap-4 mb-4">
                                <div class="text-center">
                                    <div class="h4 fw-bold mb-0">@Model.Calories</div>
                                    <div class="extra-small text-muted text-uppercase">Calories</div>
                                </div>
                                <div class="text-center">
                                    <div class="h4 fw-bold mb-0">@(Model.Protein ?? 0)g</div>
                                    <div class="extra-small text-muted text-uppercase">Protein</div>
                                </div>
                                <div class="text-center">
                                    <div class="h4 fw-bold mb-0">@(Model.Carbs ?? 0)g</div>
                                    <div class="extra-small text-muted text-uppercase">Carbs</div>
                                </div>
                                <div class="text-center">
                                    <div class="h4 fw-bold mb-0">@(Model.Fat ?? 0)g</div>
                                    <div class="extra-small text-muted text-uppercase">Fat</div>
                                </div>
                            </div>

                            <div class="d-flex align-items-center gap-3">
                                <div class="h2 fw-bold text-success mb-0">₹@Model.Price</div>
                                <button class="btn btn-success px-4 py-2 fw-bold rounded-pill add-to-cart-btn" data-id="@Model.Id">
                                    <i class="bi bi-cart-plus me-2"></i> Add to Cart
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recipe Content -->
            <div class="row g-4 justify-content-center">
                <!-- Ingredients -->
                <div class="col-md-8">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white py-3">
                            <h5 class="mb-0 fw-bold text-center"><i class="bi bi-basket2-fill text-success me-2"></i>Ingredients & Preparation</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                @if (!string.IsNullOrEmpty(recipe?.Ingredients))
                                {
                                    var ingredientList = recipe.Ingredients.Split(new[] { '\n', ',', ';' }, StringSplitOptions.RemoveEmptyEntries);
                                    foreach (var ingredient in ingredientList)
                                    {
                                        <div class="col-md-6 mb-3">
                                            <div class="d-flex align-items-center p-3 border rounded-pill bg-light">
                                                <i class="bi bi-check2-circle text-success me-3 fs-5"></i>
                                                <span class="fw-medium">@ingredient.Trim()</span>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    var generatedIngredients = GetPlausibleIngredients(Model.Name);
                                    foreach (var ingredient in generatedIngredients)
                                    {
                                        <div class="col-md-6 mb-3">
                                            <div class="d-flex align-items-center p-3 border rounded-pill bg-light">
                                                <i class="bi bi-magic text-warning me-3 fs-5" title="Auto-generated ingredient"></i>
                                                <span class="fw-medium">@ingredient.Trim()</span>
                                            </div>
                                        </div>
                                    }
                                    <div class="col-12 mt-3 text-center">
                                        <p class="extra-small text-muted fst-italic"><i class="bi bi-info-circle"></i> These ingredients are estimated based on the dish name and may vary slightly per chef.</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.Nutritionist != null)
            {
                <div class="card border-0 shadow-sm mt-4 bg-light">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle bg-white p-3 me-3">
                                <i class="bi bi-person-workspace text-success fs-2"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">Nutritionist's Note</h6>
                                <p class="small text-muted mb-0">
                                    Verified by <strong>@Model.Nutritionist.Name</strong>. 
                                    @Model.Nutritionist.Qualification with @Model.Nutritionist.Experience years of experience.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .step-number {
        width: 32px;
        height: 32px;
        background: #22c55e;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        flex-shrink: 0;
    }
    .extra-small { font-size: 0.7rem; }
    .bg-success-subtle { background-color: #e6f9f0 !important; }
</style>

@functions {
    public List<string> GetPlausibleIngredients(string foodName) {
        var baseIngredients = new List<string>();
        if (string.IsNullOrEmpty(foodName)) return baseIngredients;
        
        var nameLower = foodName.ToLower();
        
        // Base structure based on category keyword
        if (nameLower.Contains("dal") || nameLower.Contains("lentil")) {
             baseIngredients.AddRange(new[] { "1 cup Lentils (Dal)", "1 chopped Onion", "1 chopped Tomato", "1 tsp Turmeric", "Cumin Seeds", "Pinch of Asafoetida (Hing)" });
        }
        else if (nameLower.Contains("paneer")) {
             baseIngredients.AddRange(new[] { "200g Fresh Paneer", "Onion-Tomato Gravy Base", "Garam Masala", "Ginger Garlic Paste", "Fresh Cream" });
        }
        else if (nameLower.Contains("chicken")) {
             baseIngredients.AddRange(new[] { "High-Quality Chicken", "Marinade Spices", "Ginger Garlic Paste", "Onions & Tomatoes", "Fresh Coriander" });
        }
        else if (nameLower.Contains("rice") || nameLower.Contains("pulao") || nameLower.Contains("biryani")) {
             baseIngredients.AddRange(new[] { "1 cup Premium Basmati Rice", "Whole Spices (Cardamom, Cloves)", "Ghee or Refined Oil", "Mixed Vegetables/Protein" });
        }
        else if (nameLower.Contains("roti") || nameLower.Contains("bread") || nameLower.Contains("paratha") || nameLower.Contains("chilla")) {
             baseIngredients.AddRange(new[] { "Whole Wheat Flour / Batter", "Water", "Pinch of Salt", "Light Ghee/Oil for roasting" });
        }
        else if (nameLower.Contains("salad") || nameLower.Contains("bowl")) {
             baseIngredients.AddRange(new[] { "Mixed Greens (Lettuce, Spinach)", "Cherry Tomatoes", "Cucumber", "House Special Dressing" });
        }
        else if (nameLower.Contains("idli") || nameLower.Contains("dosa") || nameLower.Contains("upma") || nameLower.Contains("poha")) {
             baseIngredients.AddRange(new[] { "Fermented Batter / Semolina / Poha", "Curry Leaves", "Mustard Seeds", "Peanuts (optional)" });
        }
        else {
             baseIngredients.AddRange(new[] { "Fresh Local Farm Produce", "Chef's Secret Spice Blend", "Onions & Tomatoes", "Fresh Herb Garnish" });
        }
        
        // Add specific common sub-ingredients if mentioned
        if (nameLower.Contains("gobi") || nameLower.Contains("cauliflower")) baseIngredients.Add("Fresh Cauliflower Florets");
        if (nameLower.Contains("matar") || nameLower.Contains("peas")) baseIngredients.Add("Green Peas");
        if (nameLower.Contains("aloo") || nameLower.Contains("potato")) baseIngredients.Add("Boiled Potatoes");
        if (nameLower.Contains("spinach") || nameLower.Contains("palak")) baseIngredients.Add("Fresh Spinach Puree");
        if (nameLower.Contains("methi")) baseIngredients.Add("Fenugreek (Methi) Leaves");
        if (nameLower.Contains("soya") || nameLower.Contains("tofu")) baseIngredients.Add("Protein-rich Soya/Tofu Chunks");
        
        baseIngredients.Add("Salt to taste");
        baseIngredients.Add("Cooking Oil / Ghee");

        return baseIngredients;
    }
}
