@{
    ViewData["Title"] = "Forgot Password - NutriBite";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" />
}

<div class="forgot-wrapper">
    <div class="forgot-container">

        <!-- LEFT SIDE -->
        <div class="forgot-left">
            <h2>Reset Your Password 🔐</h2>
            <p>
                Don’t worry! It happens.
                Enter your registered email address
                and we’ll send you instructions to reset your password.
            </p>
        </div>

        <!-- RIGHT SIDE -->
        <div class="forgot-right">

            <h4 class="brand">NutriBite</h4>
            <h5 class="mb-4">Forgot Password</h5>

            <div id="forgotError" class="alert alert-danger small" style="display:none;"></div>
            <div id="forgotSuccess" class="alert alert-success small" style="display:none;"></div>

            <form id="forgotForm" method="post" action="javascript:void(0);">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label for="email" class="form-label small">Email Address</label>
                    <input id="email" name="email" type="email" class="form-control custom-input" required />
                </div>

                <div class="d-grid">
                    <button id="forgotBtn" class="btn btn-success custom-btn">
                        Send Reset Instructions
                    </button>
                </div>

                <div class="mt-3 small text-center">
                    Remembered your password?
                    <a href="/login" class="link-success">Login here</a>
                </div>

            </form>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        (function () {

            $('#forgotForm').on('submit', function (e) {
                e.preventDefault();
                $('#forgotError').hide();
                $('#forgotSuccess').hide();

                var email = $('#email').val().trim();
                if (!email) {
                    $('#forgotError').text('Please enter your email.').show();
                    return;
                }

                var token = $('input[name="__RequestVerificationToken"]').first().val() || '';

                $.post('/Auth/Forgot', { email: email, __RequestVerificationToken: token })
                    .done(function (res) {
                        if (res && res.success) {
                            $('#forgotSuccess').text(res.message || 'If an account exists, instructions were sent.').show();
                        } else {
                            $('#forgotError').text(res && res.message ? res.message : 'Unable to process request.').show();
                        }
                    })
                    .fail(function () {
                        $('#forgotError').text('Unable to reach server. Please try again.').show();
                    });

            });

        })();
    </script>
}
