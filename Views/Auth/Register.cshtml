@{
    ViewData["Title"] = "Sign Up - NutriBite";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" />
}


<div class="register-wrapper">
    <div class="register-container">

        <!-- LEFT PANEL -->
        <div class="register-left">
            <h2>Join NutriBite 🥗</h2>
            <p>
                Create your account and start discovering healthy
                homemade meals prepared with love.
                Your journey to better nutrition starts here.
            </p>
        </div>

        <!-- RIGHT PANEL -->
        <div class="register-right">

            <h4 class="brand">NutriBite</h4>
            <h5 class="mb-4">Create Account</h5>

            @if (TempData["LoginError"] != null)
            {
                <div class="alert alert-danger small">@TempData["LoginError"]</div>
            }

            <div id="signupError" class="alert alert-danger small" style="display:none;"></div>
            <div id="signupSuccess" class="alert alert-success small" style="display:none;"></div>

            <form asp-controller="Auth" asp-action="Register" method="post" id="signupForm">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label for="name" class="form-label small">Full Name</label>
                    <input id="name" name="name" type="text" class="form-control custom-input" required />
                </div>

                <div class="mb-3">
                    <label for="email" class="form-label small">Email</label>
                    <input id="email" name="email" type="email" class="form-control custom-input" required />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label small">Password</label>
                    <div class="input-group">
                        <input id="password" name="password" type="password" class="form-control custom-input" required />
                        <button id="togglePasswordReg" class="btn btn-outline-secondary" type="button">Show</button>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="confirmPassword" class="form-label small">Confirm Password</label>
                    <div class="input-group">
                        <input id="confirmPassword" name="confirmPassword" type="password" class="form-control custom-input" required />
                        <button id="toggleConfirmReg" class="btn btn-outline-secondary" type="button">Show</button>
                    </div>
                </div>

                <div class="d-grid">
                    <button id="signupBtn" class="btn btn-success custom-btn">Sign Up</button>
                </div>

                <div class="mt-3 small text-center">
                    Already have an account?
                    <a href="/login" class="link-success">Login here</a>
                </div>

                <div class="auth-divider">or join with</div>

                <div class="social-login">
                    <a href="/Auth/GoogleLogin" class="social-btn" id="googleSignupBtn">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/5/53/Google_%22G%22_Logo.svg" alt="Google Logo" />
                        <span>Sign up with Google</span>
                    </a>
                    <div id="demoHintReg" class="mt-2 text-center small text-muted" style="display:none;">
                        <i class="bi bi-info-circle"></i> <span id="demoMsgReg"></span>
                    </div>
                </div>

            </form>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        (function () {

            // If already signed in (session-based endpoint) redirect to account
            $.getJSON('/Auth/IsAuthenticated').done(function (res) {
                if (res && res.authenticated) {
                    window.location.href = '/Users/Account';
                }
            });

            $('#togglePasswordReg').on('click', function () {
                const $pwd = $('#password');
                const type = $pwd.attr('type') === 'password' ? 'text' : 'password';
                $pwd.attr('type', type);
                $(this).text(type === 'password' ? 'Show' : 'Hide');
            });

            $('#toggleConfirmReg').on('click', function () {
                const $pwd = $('#confirmPassword');
                const type = $pwd.attr('type') === 'password' ? 'text' : 'password';
                $pwd.attr('type', type);
                $(this).text(type === 'password' ? 'Show' : 'Hide');
            });

            // Use explicit AJAX with antiforgery header and improved error handling.
            $('#signupForm').on('submit', function (e) {
                e.preventDefault();
                $('#signupError').hide().text('');
                $('#signupSuccess').hide().text('');

                var name = $('#name').val().trim();
                var email = $('#email').val().trim();
                var password = $('#password').val();
                var confirm = $('#confirmPassword').val();

                if (!name || !email || !password || !confirm) {
                    $('#signupError').text('All fields are required.').show();
                    return;
                }

                if (password !== confirm) {
                    $('#signupError').text('Passwords do not match.').show();
                    return;
                }

                // read antiforgery token value from rendered hidden input
                var token = $('input[name="__RequestVerificationToken"]').first().val() || '';

                $.post('/Auth/Register', { name: name, email: email, password: password, __RequestVerificationToken: token })
                    .done(function (res) {
                        if (res && res.success) {
                            $('#signupSuccess').text('Account created successfully! Redirecting...').show();
                            setTimeout(function () {
                                window.location.href = res.redirect || '/HealthSurvey';
                            }, 1500);
                        } else {
                            $('#signupError').text(res && res.message ? res.message : 'Registration failed.').show();
                        }
                    }).fail(function () {
                        $('#signupError').text('Unable to reach server.').show();
                    });
            });

            // ⭐ DEMO USER FORM POPULATION (SIGNUP)
            $('#googleSignupBtn').on('click', function (e) {
                const url = $(this).attr('href');
                if (url.includes('GoogleLogin')) {
                    $.get('/Auth/GetDemoProfile').done(function(res) {
                        if (res.success) {
                            // Populate form fields
                            $('#name').val(res.name);
                            $('#email').val(res.email);
                            
                            // Highlight changes
                            $('#name, #email').addClass('is-valid');
                            $('#demoMsgReg').text(`Detected actual user: ${res.name}. Form fields populated.`);
                            $('#demoHintReg').fadeIn();
                        }
                    });
                    e.preventDefault();
                }
            });

        })();
    </script>
}
