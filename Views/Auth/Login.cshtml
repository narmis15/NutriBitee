@{
    ViewData["Title"] = "Login - NutriBite";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" />
}

<div class="login-wrapper">
    <div class="login-container">

        <!-- LEFT SIDE -->
        <div class="login-left">
            <h2>Welcome to NutriBite</h2>
            <div class="leaf-icon">🍃</div>
            <p>
                Healthy homemade meals crafted with care.
                Log in to explore nutritious food options
                and track your meals effortlessly.
            </p>
        </div>

        <!-- RIGHT SIDE -->
        <div class="login-right">

            <h4 class="brand">NutriBite</h4>
            <h5 class="mb-4">Welcome Back 👋</h5>

            @if (TempData["LoginError"] != null)
            {
                <div class="alert alert-danger small">@TempData["LoginError"]</div>
            }
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success small">@TempData["Success"]</div>
            }

            <div id="loginError" class="alert alert-danger small" style="display:none;"></div>

            <form id="loginForm" method="post" action="javascript:void(0);">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label for="email" class="form-label small">Email</label>
                    <input id="email" name="email" type="email" class="form-control custom-input" required />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label small">Password</label>
                    <div class="input-group">
                        <input id="password" name="password" type="password" class="form-control custom-input" required />
                        <button id="togglePassword" class="btn btn-outline-secondary" type="button">Show</button>
                    </div>
                </div>

                <div class="d-grid">
                    <button id="loginBtn" class="btn btn-success custom-btn">Login</button>
                </div>

                <div class="mt-3 d-flex justify-content-between small">
                    <div>Don't have an account? <a href="/signup" class="link-success">Sign up</a></div>
                    <div><a href="/Auth/Forgot">Forgot password?</a></div>
                </div>

                <div class="auth-divider">or continue with</div>

                <div class="social-login">
                    <a href="/Auth/GoogleLogin" class="social-btn" id="googleLoginBtn">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/5/53/Google_%22G%22_Logo.svg" alt="Google Logo" />
                        <span>Continue with Google</span>
                    </a>
                    <div id="demoHint" class="mt-2 text-center small text-muted" style="display:none;">
                        <i class="bi bi-info-circle"></i> <span id="demoMsg"></span>
                    </div>
                </div>

            </form>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script>
        (function () {

            // Update UI only; do NOT auto-redirect to /Users/Account
            // Prevents client-driven loops when server session is intermittent.
            $.getJSON('/Auth/IsAuthenticated').done(function (res) {
                if (res && res.authenticated) {
                    // Update UI (no navigation)
                    $('#loginError').hide();
                }
            });

            $('#togglePassword').on('click', function () {
                const $pwd = $('#password');
                const type = $pwd.attr('type') === 'password' ? 'text' : 'password';
                $pwd.attr('type', type);
                $(this).text(type === 'password' ? 'Show' : 'Hide');
            });

            $('#loginForm').on('submit', function (e) {
                e.preventDefault();
                $('#loginError').hide();

                var email = $('#email').val().trim();
                var password = $('#password').val();

                if (!email || !password) {
                    $('#loginError').text('Please enter email and password.').show();
                    return;
                }

                var token = $('input[name="__RequestVerificationToken"]').first().val() || '';

                $.post('/Auth/Login', { email: email, password: password, __RequestVerificationToken: token })
                    .done(function (res) {
                        if (res && res.success) {
                            if (res.isAdmin) {
                                window.location.href = '/Admin/Dashboard';
                            } else if (res.isVendor) {
                                window.location.href = '/Vendor/Dashboard';
                            } else {
                                // server decides where to go after login
                                if (res.requiresSurvey) {
                                    window.location.href = '/HealthSurvey';
                                } else {
                                    window.location.href = '/Home/Index';
                                }
                            }
                        } else {
                            if (res && res.isPendingVendor) {
                                // Specific vendor pending alert
                                alert(res.message);
                            }
                            $('#loginError').text(res && res.message ? res.message : 'Invalid login credentials.').show();
                        }
                    }).fail(function () {
                        $('#loginError').text('Unable to reach server. Please try again.').show();
                    });
            });

            // ⭐ DEMO USER FORM POPULATION
            $('#googleLoginBtn').on('click', function (e) {
                // If it's a demo link, we fetch data and fill the form
                const url = $(this).attr('href');
                if (url.includes('GoogleLogin')) {
                    // Check if we should intercept (in case of demo mode)
                    $.get('/Auth/GetDemoProfile').done(function(res) {
                        if (res.success) {
                            // Populate form fields
                            $('#email').val(res.email);
                            // Highlight the change
                            $('#email').addClass('is-valid');
                            $('#demoMsg').text(`Detected actual user: ${res.name}. Form fields populated. Click Login to continue.`);
                            $('#demoHint').fadeIn();
                            
                            // Optional: If we want to fully bypass and just login, we could do:
                            // window.location.href = '/Auth/GoogleCallback?code=demo_code_123';
                            // But the user specifically asked to "populate the form fields".
                        }
                    });
                    
                    // Prevent immediate redirect so user sees the population
                    e.preventDefault();
                }
            });

        })();
    </script>
}
