@{
    ViewData["Title"] = "Login - NutriBite";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" />
}

<div class="login-wrapper">
    <div class="login-container">

        <!-- LEFT SIDE -->
        <div class="login-left">
            <h2>Welcome to NutriBite</h2>
            <div class="leaf-icon">🍃</div>
            <p>
                Healthy homemade meals crafted with care.
                Log in to explore nutritious food options
                and track your meals effortlessly.
            </p>
        </div>

        <!-- RIGHT SIDE -->
        <div class="login-right">

            <h4 class="brand">NutriBite</h4>
            <h5 class="mb-4">Welcome Back 👋</h5>

            <div id="loginError" class="alert alert-danger small" style="display:none;"></div>

            <form id="loginForm" method="post" action="javascript:void(0);">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label for="email" class="form-label small">Email</label>
                    <input id="email" name="email" type="email" class="form-control custom-input" required />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label small">Password</label>
                    <div class="input-group">
                        <input id="password" name="password" type="password" class="form-control custom-input" required />
                        <button id="togglePassword" class="btn btn-outline-secondary" type="button">Show</button>
                    </div>
                </div>

                <div class="d-grid">
                    <button id="loginBtn" class="btn btn-success custom-btn">Login</button>
                </div>

                <div class="mt-3 d-flex justify-content-between small">
                    <div>Don't have an account? <a href="/signup" class="link-success">Sign up</a></div>
                    <div><a href="/Auth/Forgot">Forgot password?</a></div>
                </div>

            </form>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        (function () {

            $.getJSON('/Auth/IsAuthenticated').done(function (res) {
                if (res && res.authenticated) {
                    window.location.href = '/Users/Account';
                }
            });

            $('#togglePassword').on('click', function () {
                const $pwd = $('#password');
                const type = $pwd.attr('type') === 'password' ? 'text' : 'password';
                $pwd.attr('type', type);
                $(this).text(type === 'password' ? 'Show' : 'Hide');
            });

            $('#loginForm').on('submit', function (e) {
                e.preventDefault();
                $('#loginError').hide();

                var email = $('#email').val().trim();
                var password = $('#password').val();

                if (!email || !password) {
                    $('#loginError').text('Please enter email and password.').show();
                    return;
                }

                var token = $('input[name="__RequestVerificationToken"]').first().val() || '';

                $.post('/Auth/Login', { email: email, password: password, __RequestVerificationToken: token })
                    .done(function (res) {
                        if (res && res.success) {
                            window.location.href = '/Users/Account';
                        } else {
                            $('#loginError').text(res && res.message ? res.message : 'Invalid login credentials.').show();
                        }
                    }).fail(function () {
                        $('#loginError').text('Unable to reach server. Please try again.').show();
                    });
            });

        })();
    </script>
}
