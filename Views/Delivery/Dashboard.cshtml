@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Delivery Dashboard";
    bool isAdmin = !string.IsNullOrEmpty(Context.Session.GetString("Admin"));
    Layout = isAdmin ? "~/Views/Shared/_Layout.cshtml" : "~/Views/Shared/_PublicLayout.cshtml";
}

<style>
    .delivery-card {
        border-radius: 15px;
        border: none;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        background: white;
    }
    .delivery-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    }
    .status-badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.85rem;
    }
    .btn-update {
        border-radius: 10px;
        font-weight: 600;
        padding: 10px;
        transition: all 0.3s;
    }
    .page-title {
        color: #2d6a4f;
        font-weight: 700;
        letter-spacing: -0.5px;
    }
    .card-glass {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }
</style>

<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title mb-1">🚚 Delivery Dashboard</h2>
            <p class="text-muted">@(isAdmin ? "Admin View - Monitoring all deliveries" : "Manage your assigned deliveries and update their status.")</p>
        </div>
        <div class="text-end">
            <span class="badge bg-success-soft text-success p-2 px-3 rounded-pill">
                <i class="bi bi-circle-fill me-1 small"></i> Active Session
            </span>
        </div>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var delivery in Model)
            {
                <div class="col-md-6 col-lg-4 col-xl-3">
                    <div class="card h-100 delivery-card">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="fw-bold mb-0">Order #@delivery.OrderId</h5>
                                    <small class="text-muted">@(delivery.CreatedAt?.ToString("dd MMM, hh:mm tt"))</small>
                                </div>
                                <span class="badge bg-info-soft text-info status-badge">@delivery.DeliveryStatus</span>
                            </div>
                            
                            <div class="mb-3">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-light rounded-circle p-2 me-2">
                                        <i class="bi bi-person text-primary"></i>
                                    </div>
                                    <div>
                                        <div class="small text-muted">Customer</div>
                                        <div class="fw-bold">@delivery.CustomerName</div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-light rounded-circle p-2 me-2">
                                        <i class="bi bi-telephone text-success"></i>
                                    </div>
                                    <div>
                                        <div class="small text-muted">Phone</div>
                                        <a href="tel:@delivery.CustomerPhone" class="text-decoration-none fw-bold">@delivery.CustomerPhone</a>
                                    </div>
                                </div>
                                <div class="d-flex align-items-start mb-2">
                                    <div class="bg-light rounded-circle p-2 me-2">
                                        <i class="bi bi-geo-alt text-danger"></i>
                                    </div>
                                    <div>
                                        <div class="small text-muted">Address</div>
                                        <div class="small fw-semibold">@delivery.DeliveryAddress</div>
                                    </div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(delivery.DeliveryNotes))
                            {
                                <div class="alert alert-warning border-0 small p-2 mb-3">
                                    <i class="bi bi-info-circle me-1"></i> <strong>Note:</strong> @delivery.DeliveryNotes
                                </div>
                            }

                            @if (!isAdmin)
                            {
                                <div class="d-grid gap-2 mt-auto">
                                    @if (delivery.DeliveryStatus == "Assigned")
                                    {
                                        <button class="btn btn-warning btn-update update-status-btn shadow-sm" 
                                                data-id="@delivery.OrderId" 
                                                data-status="Out for Delivery">
                                            <i class="bi bi-truck me-1"></i> Mark Out for Delivery
                                        </button>
                                    }
                                    else if (delivery.DeliveryStatus == "Out for Delivery")
                                    {
                                        <button class="btn btn-success btn-update update-status-btn shadow-sm" 
                                                data-id="@delivery.OrderId" 
                                                data-status="Delivered">
                                            <i class="bi bi-check2-circle me-1"></i> Mark as Delivered
                                        </button>
                                    }
                                    else if (delivery.DeliveryStatus == "Delivered")
                                    {
                                        <button class="btn btn-outline-secondary btn-update" disabled>
                                            <i class="bi bi-check-all me-1"></i> Delivered
                                        </button>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="mt-auto border-top pt-3 text-center">
                                    <a href="/Admin/OrderDetails?orderId=@delivery.OrderId" class="btn btn-sm btn-outline-primary rounded-pill">
                                        View Order Details
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="display-1 text-muted mb-3 opacity-25">
                    <i class="bi bi-mailbox"></i>
                </div>
                <h4 class="text-muted">No active deliveries found.</h4>
                <p class="text-muted small">New orders will appear here once assigned.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.update-status-btn', function() {
            const btn = $(this);
            const id = btn.data('id');
            const status = btn.data('status');
            
            if (!confirm(`Are you sure you want to mark this order as ${status}?`)) return;

            btn.prop('disabled', true).text('Updating...');

            $.ajax({
                url: '/Admin/UpdateDeliveryStatus',
                type: 'POST',
                data: { 
                    orderId: id, 
                    status: status,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() 
                },
                success: function(res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert('Failed to update status');
                        btn.prop('disabled', false).text('Try Again');
                    }
                },
                error: function() {
                    alert('Server error');
                    btn.prop('disabled', false).text('Try Again');
                }
            });
        });
    </script>
}

@Html.AntiForgeryToken()
