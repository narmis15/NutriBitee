@model NUTRIBITE.Models.HealthSurvey

@{
    ViewData["Title"] = "Health Result";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    var foods = ViewBag.FoodSuggestions as List<NUTRIBITE.Models.Food>;
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h3>Your Health Summary</h3>

        <a href="/HealthSurvey/Edit" class="btn btn-outline-dark">
            ✏ Edit Health Survey
        </a>

    </div>


    <!-- SUMMARY CARDS -->
    <div class="row text-center mb-4">

        <div class="col-md-4">
            <div class="card shadow-sm p-3">
                <h6>BMI</h6>
                <h4>@Model.Bmi</h4>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm p-3">
                <h6>BMR</h6>
                <h4>@Model.Bmr</h4>
                <small>kcal/day</small>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm p-3">
                <h6>Recommended Calories</h6>
                <h4>@Model.RecommendedCalories</h4>
                <small>kcal/day</small>
            </div>
        </div>

    </div>


    <!-- PROFILE -->
    <div class="card p-4 shadow-sm mb-4">

        <h5>Profile</h5>

        <div class="row">

            <div class="col-md-6">
                <p><strong>Age:</strong> @Model.Age</p>
                <p><strong>Height:</strong> @Model.HeightCm cm</p>
                <p><strong>Weight:</strong> @Model.WeightKg kg</p>
            </div>

            <div class="col-md-6">
                <p><strong>Gender:</strong> @Model.Gender</p>
                <p><strong>Diet:</strong> @Model.DietaryPreference</p>
                <p><strong>Activity:</strong> @Model.ActivityLevel</p>
            </div>

        </div>

        <hr />

        <h6>Health Notes</h6>

        <p><strong>Chronic Conditions:</strong> @Model.ChronicDiseases</p>
        <p><strong>Food Allergies:</strong> @Model.FoodAllergies</p>
        <p><strong>Smoking:</strong> @(Model.Smoking ? "Yes" : "No")</p>
        <p><strong>Alcohol:</strong> @(Model.Alcohol ? "Yes" : "No")</p>

    </div>


    <!-- MACROS -->
    <div class="card p-4 shadow-sm mb-4">

        <h5>Macro Distribution</h5>

        <div class="bg-light p-3 rounded">

            <p><strong>Carbs:</strong> 50%</p>
            <p><strong>Protein:</strong> 20%</p>
            <p><strong>Fats:</strong> 30%</p>

        </div>

    </div>


    <!-- FOOD RECOMMENDATIONS -->
    <div class="card p-4 shadow-sm mb-4">

        <h5>Recommended Meals</h5>

        @if (foods != null && foods.Any())
        {
            <div class="row">

                @foreach (var food in foods)
                {
                    <div class="col-md-4 mb-4">

                        <div class="card shadow-sm h-100">

                            <img src="@food.ImagePath"
                                 class="card-img-top"
                                 style="height:200px;object-fit:cover;" />

                            <div class="card-body">

                                <h6 class="card-title">@food.Name</h6>

                                <p class="text-muted small">
                                    @food.Description
                                </p>

                                <p class="text-muted small">
                                    🔥 @food.Calories kcal
                                </p>

                                <!-- CALORIE BADGES -->
                                @if (food.Calories <= 400)
                                {
                                    <span class="badge bg-success mb-2">Low Calorie</span>
                                }
                                else if (food.Calories >= 700)
                                {
                                    <span class="badge bg-danger mb-2">High Calorie</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark mb-2">Balanced Meal</span>
                                }

                                <p class="fw-bold mt-2">
                                    ₹@food.Price
                                </p>

                                <button class="btn btn-success addToCartBtn"
                                        data-id="@food.Id">
                                    Add to Cart
                                </button>

                            </div>

                        </div>

                    </div>
                }

            </div>
        }
        else
        {
            <p>No recommended meals available.</p>
        }

    </div>


    <!-- DISCLAIMER -->
    <div class="text-muted small">

        These recommendations are generated based on the information provided and are intended for general guidance only.
        Please consult a qualified healthcare professional before making significant dietary or lifestyle changes.

    </div>

</div>


<script>

    document.querySelectorAll(".addToCartBtn").forEach(btn => {

        btn.addEventListener("click", function () {

            var productId = this.getAttribute("data-id");

            fetch("/Cart/AddToCart", {

                method: "POST",

                headers: {
                    "Content-Type": "application/json"
                },

                body: JSON.stringify({
                    productId: parseInt(productId)
                })

            })
            .then(res => res.json())
            .then(data => {

                if (data.success) {
                    alert("Item added to cart!");
                }
                else {
                    alert("Failed to add item.");
                }

            });

        });

    });

</script>