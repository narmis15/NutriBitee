@using Microsoft.AspNetCore.Http
@{
    var userId = Context.Session.GetInt32("UserId");
    var userName = Context.Session.GetString("UserName");
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - NutriBite</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/vendor-dashboard.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)

    <style>
        /* Global Back Button for vendor pages */
        .global-back-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 8px 14px;
            border-radius: 10px;
            background: #2d6a4f;
            color: #fff;
            border: none;
            font-weight: 600;
            box-shadow: 0 8px 20px rgba(45,106,79,0.18);
            cursor: pointer;
            text-decoration: none;
            transition: transform .08s ease, box-shadow .12s ease;
        }
        .global-back-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(45,106,79,0.22); }
        .global-back-btn .icon { width:18px; height:18px; display:inline-flex; align-items:center; justify-content:center; font-size:14px; }
        .back-wrapper { padding: 16px; }
    </style>
</head>
<body>

    <!-- NAVBAR: same simple public navbar (text logo) -->
    

    <!-- ===== VENDOR WRAPPER (sidebar + content) ===== -->
    <div class="vendor-wrapper">
        <div class="vendor-sidebar" id="vendorSidebar">
           
            <button class="sidebar-toggle" onclick="toggleSidebar()">&#9776;</button>
            <
            <a href="/Vendor/Dashboard"><span class="nav-icon">📊</span><span class="nav-label">Dashboard</span></a>
            <a href="/Vendor/MyFood"><span class="nav-icon">🍽️</span><span class="nav-label">My Foods</span></a>
            <a href="/Vendor/AddFood"><span class="nav-icon">➕</span><span class="nav-label">Add Food</span></a>
            <a href="/Vendor/Order"><span class="nav-icon">📦</span><span class="nav-label">Orders</span></a>

            <div class="sidebar-divider"></div>

            <a href="/Vendor/Profile"><span class="nav-icon">👤</span><span class="nav-label">Profile</span></a>
            <a href="/Vendor/Logout" class="logout-link"><span class="nav-icon">🚪</span><span class="nav-label">Logout</span></a>
        </div>

        <div class="vendor-main" id="vendorMain">
            @* Back button for vendor pages (internal) *@
            <div class="back-wrapper">
                <button type="button" class="global-back-btn" id="globalBackBtnVendor" title="Go back">
                    <span class="icon">←</span>
                    <span>Back</span>
                </button>
            </div>

            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await Html.PartialAsync("_AuthModal")
    @RenderSection("Scripts", required: false)

    <script>
        function toggleSidebar() {
            document.getElementById('vendorSidebar').classList.toggle('collapsed');
            document.getElementById('vendorMain').classList.toggle('collapsed');
        }

        (function () {
            var b = document.getElementById('globalBackBtnVendor');
            if (!b) return;
            b.addEventListener('click', function (e) {
                e.preventDefault();
                if (window.history.length > 1) { window.history.back(); return; }
                window.location.href = '/Vendor/Dashboard';
            });
        })();
    </script>

</body>
</html>