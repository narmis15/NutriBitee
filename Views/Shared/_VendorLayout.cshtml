@using Microsoft.AspNetCore.Http
@{
    var userId = Context.Session.GetInt32("UserId");
    var userName = Context.Session.GetString("UserName");
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - NutriBite</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/vendor-portal.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)

    <style>
        /* Global Back Button (Small Circle Arrow Design) */
        .global-back-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #fff;
            color: #6c757d;
            border: 1px solid #dee2e6;
            font-size: 1.1rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s ease;
        }
        .global-back-btn:hover {
            background: #f8f9fa;
            color: #212529;
            border-color: #adb5bd;
            transform: scale(1.05);
        }
        .back-wrapper { padding: 16px; }
    </style>
</head>
<body>

    <!-- NAVBAR: same simple public navbar (text logo)<a href="/Vendor/Dashboard">
                                       <img src="/images/hero/Nutribitelogo.png" alt="NutriBite Logo" />

                </a> -->
    

    <div class="vendor-wrapper">
        <div class="vendor-sidebar" id="vendorSidebar">
            <div class="sidebar-header">
                
            </div>
            <button class="sidebar-toggle" onclick="toggleSidebar()">
                <i class="bi bi-list"></i>
            </button>
            
            <a href="/Vendor/Dashboard" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="bi bi-speedometer2 nav-icon"></i>
                <span class="nav-label">Dashboard</span>
            </a>
            <a href="/Vendor/MyFood" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "MyFood" ? "active" : "")">
                <i class="bi bi-egg-fried nav-icon"></i>
                <span class="nav-label">My Foods</span>
            </a>
            <a href="/Vendor/AddFood" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "AddFood" ? "active" : "")">
                <i class="bi bi-plus-circle nav-icon"></i>
                <span class="nav-label">Add Food</span>
            </a>
            <a href="/Vendor/Order" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Order" ? "active" : "")">
                <i class="bi bi-box-seam nav-icon"></i>
                <span class="nav-label">Orders</span>
            </a>
            <a href="/Vendor/Earnings" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Earnings" ? "active" : "")">
                <i class="bi bi-wallet2 nav-icon"></i>
                <span class="nav-label">Earnings</span>
            </a>

            <div class="sidebar-divider my-3 mx-4" style="border-top: 1px solid rgba(255,255,255,0.1);"></div>

            <a href="/Vendor/Profile" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : "")">
                <i class="bi bi-person-circle nav-icon"></i>
                <span class="nav-label">Profile</span>
            </a>
            <a href="/Vendor/Logout" class="logout-link">
                <i class="bi bi-box-arrow-right nav-icon"></i>
                <span class="nav-label">Logout</span>
            </a>
        </div>

        <div class="vendor-main" id="vendorMain">
            @* Back button for vendor pages (internal) *@
            <div class="back-wrapper">
                <button type="button" class="global-back-btn" id="globalBackBtnVendor" title="Go back">
                    <i class="bi bi-arrow-left"></i>
                </button>
            </div>

            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await Html.PartialAsync("_AuthModal")
    @RenderSection("Scripts", required: false)

    <script>
        function toggleSidebar() {
            document.getElementById('vendorSidebar').classList.toggle('collapsed');
            document.getElementById('vendorMain').classList.toggle('collapsed');
        }

        (function () {
            var b = document.getElementById('globalBackBtnVendor');
            if (!b) return;
            b.addEventListener('click', function (e) {
                e.preventDefault();
                if (window.history.length > 1) { window.history.back(); return; }
                window.location.href = '/Vendor/Dashboard';
            });
        })();
    </script>

</body>
</html>