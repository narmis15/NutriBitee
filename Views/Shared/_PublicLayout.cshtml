@using Microsoft.AspNetCore.Http
@{
    var userId = Context.Session.GetInt32("UserId");
    var userName = Context.Session.GetString("UserName");

    // current route for conditional Back button (do not show on Home/Index and Public/Index)
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    // Show Bulk nav on Home and Bulk pages (not landing)
    bool isLanding = string.Equals(currentController, "Public", System.StringComparison.OrdinalIgnoreCase)
                     && string.Equals(currentAction, "Index", System.StringComparison.OrdinalIgnoreCase);
    bool showBulkNav = !isLanding && (string.Equals(currentController, "Home", System.StringComparison.OrdinalIgnoreCase)
                                      || string.Equals(currentController, "Bulk", System.StringComparison.OrdinalIgnoreCase));
    bool showBackButton = !(string.Equals(currentController, "Home", System.StringComparison.OrdinalIgnoreCase)
                            && string.Equals(currentAction, "Index", System.StringComparison.OrdinalIgnoreCase))
                          && !(string.Equals(currentController, "Public", System.StringComparison.OrdinalIgnoreCase)
                            && string.Equals(currentAction, "Index", System.StringComparison.OrdinalIgnoreCase));
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - NutriBite</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

    @RenderSection("Styles", required: false)

    <style>

        body {
            font-family: 'Poppins',sans-serif;
            background: linear-gradient(135deg,#d9f3e8,#c3eadb,#b1e3cf);
            margin: 0;
        }

        .page-wrapper {
            width: 92%;
            max-width: 1300px;
            margin: 50px auto;
            background: #f6fff9;
            border-radius: 30px;
            box-shadow: 0 25px 60px rgba(0,0,0,0.15);
            overflow: hidden;
        }



        .public-navbar {
            display: grid;
            grid-template-columns: auto 1fr auto;
            align-items: center;
            padding: 16px 40px;
            background: white;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            position: sticky;
            top: 0;
            z-index: 1000;
        }
        .logo-img {
            height: 55px;
        }

        .nav-center {
            display: flex;
            justify-content: center;
            gap: 50px;
            align-items: center;
        }

            .nav-center a {
                text-decoration: none;
                font-weight: 600;
                color: #1b4332;
                transition: .3s;
            }

                .nav-center a:hover {
                    color: #40916c;
                }

                .nav-center a.active {
                    color: #1b4332;
                    background: rgba(45,106,79,0.08);
                    padding: 6px 10px;
                    border-radius: 8px;
                }

                .nav-center a:hover {
                    border-bottom: 2px solid #40916c;
                    padding-bottom: 4px;
                }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 20px;
            justify-content: flex-end;
        }
        .vendor-btn {
            padding: 10px 18px;
            border-radius: 25px;
            border: 2px solid #52b788;
            color: #1b4332;
            text-decoration: none;
            font-weight: 600;
            transition: .3s;
        }

            .vendor-btn:hover {
                background: #52b788;
                color: white;
            }

        .login-btn {
            padding: 10px 20px;
            border-radius: 25px;
            background: #2d6a4f;
            color: white;
            text-decoration: none;
            font-weight: 600;
        }

        .signup-btn {
            padding: 10px 20px;
            border-radius: 25px;
            border: 2px solid #2d6a4f;
            color: #2d6a4f;
            text-decoration: none;
            font-weight: 600;
        }

            .signup-btn:hover {
                background: #2d6a4f;
                color: white;
            }

        .cart-icon {
            font-size: 22px;
            position: relative;
            text-decoration: none;
        }

        .cart-count {
            position: absolute;
            top: -8px;
            right: -10px;
            background: #ff4d4d;
            color: white;
            font-size: 11px;
            padding: 2px 6px;
            border-radius: 50%;
            font-weight: 600;
        }

        .profile-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: #1b9e52;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 8px 20px rgba(27,158,82,0.4);
        }

        .nav-search {
            position: relative;
        }

            .nav-search input {
                width: 260px;
                padding: 10px 16px;
                border-radius: 25px;
                border: 1px solid #e0e0e0;
                font-size: 14px;
                transition: 0.3s;
            }

                .nav-search input:focus {
                    outline: none;
                    border-color: #52b788;
                    box-shadow: 0 0 0 3px rgba(82,183,136,0.2);
                }

        #searchResults {
            position: absolute;
            top: 38px;
            width: 100%;
            background: white;
            border-radius: 12px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.12);
            z-index: 999;
        }

        .search-item {
            display: flex;
            gap: 10px;
            padding: 10px;
            align-items: center;
            cursor: pointer;
            text-decoration: none;
            color: #1b4332;
        }

            .search-item:hover {
                background: #f4f7f5;
            }

            .search-item img {
                width: 40px;
                height: 40px;
                border-radius: 8px;
                object-fit: cover;
            }

        main {
            padding: 40px;
        }

        /* Global Back Button - NutriBite style */
        .global-back-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 8px 14px;
            border-radius: 10px;
            background: #2d6a4f;
            color: #fff;
            border: none;
            font-weight: 600;
            box-shadow: 0 8px 20px rgba(45,106,79,0.18);
            cursor: pointer;
            text-decoration: none;
            transition: transform .08s ease, box-shadow .12s ease;
            margin-bottom: 18px;
        }
        .global-back-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(45,106,79,0.22); }
        .global-back-btn .icon {
            display:inline-flex;
            width:18px;
            height:18px;
            align-items:center;
            justify-content:center;
            font-size:14px;
        }
        /* keep button left-aligned and under navbar */
        .back-wrapper {
            display:flex;
            justify-content:flex-start;
        }

        .cart-icon {
            font-size: 22px;
            position: relative;
            text-decoration: none;
            background: #eef7f2;
            padding: 8px 12px;
            border-radius: 12px;
            transition: 0.3s;
        }

            .cart-icon:hover {
                background: #dff3ea;
            }

        .hero-btn {
            background: #2d6a4f;
            color: white;
            padding: 14px 28px;
            border-radius: 30px;
            font-weight: 600;
            border: none;
            transition: 0.3s;
        }

            .hero-btn:hover {
                background: #40916c;
                transform: translateY(-2px);
            }

        #locationDisplay {
            max-width: 220px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            background: #eef7f2;
            padding: 8px 14px;
            border-radius: 20px;
            font-weight: 600;
            cursor: pointer;
        }
        /* ===============================
           PROFILE DROPDOWN UI
        ================================ */

        .dropdown-menu {
            border-radius: 14px;
            border: none;
            padding: 10px 0;
            min-width: 200px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.12);
            animation: dropdownFade .2s ease;
        }

        /* dropdown animation */
        keyframes dropdownFade {
            from

        {
            opacity: 0;
            transform: translateY(-8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        /* dropdown items */
        .dropdown-item {
            padding: 10px 18px;
            font-size: 14px;
            font-weight: 500;
            color: #1b4332;
            transition: all .2s ease;
        }

            /* hover effect */
            .dropdown-item:hover {
                background: #f4f9f6;
                color: #2d6a4f;
                padding-left: 22px;
            }

        /* divider */
        .dropdown-divider {
            margin: 8px 0;
        }

        /* logout styling */
        .dropdown-item.text-danger {
            font-weight: 600;
        }

            .dropdown-item.text-danger:hover {
                background: #fff3f3;
                color: #ff4d4d;
            }

        /* avatar improvement */
        .profile-avatar {
            transition: transform .2s ease, box-shadow .2s ease;
        }

            .profile-avatar:hover {
                transform: scale(1.08);
                box-shadow: 0 10px 25px rgba(27,158,82,0.45);
            }

    </style>
</head>

<body>

    <div class="page-wrapper">

        <!-- NAVBAR -->
        <div class="public-navbar">

            <div style="display:flex;align-items:center;gap:15px;">

                <a asp-controller="Home" asp-action="Index">
                    <img src="~/images/hero/Nutribitelogo.png" class="logo-img" />
                </a>

                @if (userId != null)
                {
                    <div id="locationDisplay"
                         style="font-weight:600;cursor:pointer;background:#eef7f2;padding:6px 12px;border-radius:20px;"
                         data-bs-toggle="modal"
                         data-bs-target="#locationModal">

                        📍 Detecting location...

                    </div>
                }

            </div>

            <div class="nav-center">
                <a asp-controller="Home" asp-action="Index" class="nav-link">Home</a>
                <a asp-controller="Home" asp-action="About" class="nav-link">About</a>

                @* Bulk nav link: appear on Home and Bulk pages, not on the public landing page. Uses Tag Helpers. *@
                @if (showBulkNav)
                {
                    <a asp-controller="Bulk" asp-action="Index" class="nav-link" id="navBulk">Bulk</a>
                }
            </div>

            <div class="nav-actions">

                

                @if (userId == null)
                {
                    <a class="vendor-btn" asp-controller="Vendor" asp-action="Register">Join as Vendor</a>
                    <a class="login-btn" asp-controller="Auth" asp-action="Login">Login</a>
                    <a class="signup-btn" asp-controller="Auth" asp-action="Register">Sign Up</a>
                }
                else
                {

                    <div class="nav-search">
                        <input type="text" id="foodSearch" placeholder="Search meals..." autocomplete="off" />
                        <div id="searchResults"></div>
                    </div>

                    <!-- CART ICON -->
                    <a asp-controller="Cart" asp-action="Index" class="cart-icon">

                        🛒

                        <span id="cartCount" class="cart-count">
                            00
                        </span>

                    </a>

                    <div class="dropdown">
                        <div class="profile-avatar dropdown-toggle" data-bs-toggle="dropdown">
                            @userName?.Substring(0, 1).ToUpper()
                        </div>

                        <ul class="dropdown-menu dropdown-menu-end">

                            <li>
                                <a class="dropdown-item" asp-controller="Home" asp-action="MyProfile">
                                    My Profile
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-controller="HealthSurvey" asp-action="Index">
                                    Health Survey
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-controller="CalorieTracker" asp-action="Index">
                                    Calorie Tracking
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-controller="Home" asp-action="MyOrders">
                                    My Orders
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">
                                    Logout
                                </a>
                            </li>

                        </ul>
                    </div>

               }
              

            </div>
        </div>

        @* Include the Location Selector modal partial *@
        @await Html.PartialAsync("~/Views/Shared/_LocationSelector.cshtml")

        <main>
            @* Back button (shared) - rendered on most internal pages (not Home or Landing) *@
            @if (showBackButton)
            {
                <div class="back-wrapper" aria-hidden="false">
                    <button type="button" class="global-back-btn" id="globalBackBtn" title="Go back">
                        <span class="icon">←</span>
                        <span>Back</span>
                    </button>
                </div>
            }

            @RenderBody()
        </main>

    </div>

    @RenderSection("Scripts", required: false)

    <!-- Ensure Bootstrap 5 JS is available. Try CDN first, fallback to local copy. -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>if(typeof bootstrap === 'undefined'){document.write('<script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"><\/script>')}</script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>

        const searchInput=document.getElementById("foodSearch");
        const resultsBox=document.getElementById("searchResults");

        if(searchInput){

        searchInput.addEventListener("keyup",function(){

        const query=this.value;

        if(query.length<2){
        resultsBox.innerHTML="";
        return;
        }

        fetch(`/Meals/Search?q=${query}`)
        .then(res=>res.json())
        .then(data=>{

        let html="";

        data.forEach(food=>{

        html+=`
        <a href="/Meals/Results?q=${encodeURIComponent(food.name)}" class="search-item">

        <img src="${food.image}" />

        <div>
        <strong>${food.name}</strong>
        <br>
        <small>${food.calories} kcal</small>
        </div>

        </a>`;

        });

        resultsBox.innerHTML=html;

        });

        });

        searchInput.addEventListener("keypress",function(e){

        if(e.key==="Enter"){

        window.location.href="/Meals/Results?q="+searchInput.value;

        }

        });

        }

    </script>

    <script>

        function loadCartCount(){

        fetch('/Cart/GetCartCount')
        .then(res=>res.json())
        .then(data=>{

        if(data.success){

        let count=data.count.toString().padStart(2,'0');

        document.getElementById("cartCount").innerText=count;

        }

        });

        }

        loadCartCount();

    </script>

    <script>
        // Global Back button behavior
        (function () {
            const btn = document.getElementById('globalBackBtn');
            if (!btn) return;
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                if (window.history.length > 1) { window.history.back(); return; }
                window.location.href = '/';
            });
        })();
    </script>

    <script>
        // Navbar active highlighting for Bulk link (applies on any page where the Bulk nav exists)
        (function () {
            try {
                var path = (location.pathname || "").toLowerCase();
                var bulkLink = document.getElementById('navBulk');
                if (!bulkLink) return;
                // Mark active when on any /bulk route
                if (path.startsWith('/bulk')) {
                    bulkLink.classList.add('active');
                }
                // Also mark active when on /bulk/... (meals/snacks/foodbox)
            } catch (e) {
                // silent
            }
        })();
    </script>

    <!-- Location script (initialize after DOM) -->
    <script src="~/js/location.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.NutriBiteLocation && typeof window.NutriBiteLocation.init === 'function') {
                window.NutriBiteLocation.init({ displayId: 'locationDisplay' });
            }
        });
    </script>
</body>
</html>