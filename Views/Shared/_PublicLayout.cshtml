@using Microsoft.AspNetCore.Http
@{
    var userId = Context.Session.GetInt32("UserId");
    var userName = Context.Session.GetString("UserName");
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - NutriBite</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

    @RenderSection("Styles", required: false)

    <style>

        body {
            font-family: 'Poppins',sans-serif;
            background: linear-gradient(135deg,#d9f3e8,#c3eadb,#b1e3cf);
            margin: 0;
        }

        .page-wrapper {
            width: 92%;
            max-width: 1300px;
            margin: 50px auto;
            background: #f6fff9;
            border-radius: 30px;
            box-shadow: 0 25px 60px rgba(0,0,0,0.15);
            overflow: hidden;
        }

        .public-navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 50px;
            background: white;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .logo-img {
            height: 55px;
        }

        .nav-center {
            display: flex;
            gap: 40px;
            align-items: center;
        }

            .nav-center a {
                text-decoration: none;
                font-weight: 600;
                color: #1b4332;
                transition: .3s;
            }

                .nav-center a:hover {
                    color: #40916c;
                }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 25px;
        }

        .vendor-btn {
            padding: 10px 18px;
            border-radius: 25px;
            border: 2px solid #52b788;
            color: #1b4332;
            text-decoration: none;
            font-weight: 600;
            transition: .3s;
        }

            .vendor-btn:hover {
                background: #52b788;
                color: white;
            }

        .login-btn {
            padding: 10px 20px;
            border-radius: 25px;
            background: #2d6a4f;
            color: white;
            text-decoration: none;
            font-weight: 600;
        }

        .signup-btn {
            padding: 10px 20px;
            border-radius: 25px;
            border: 2px solid #2d6a4f;
            color: #2d6a4f;
            text-decoration: none;
            font-weight: 600;
        }

            .signup-btn:hover {
                background: #2d6a4f;
                color: white;
            }

        .cart-icon {
            font-size: 22px;
            position: relative;
            text-decoration: none;
        }

        .cart-count {
            position: absolute;
            top: -8px;
            right: -10px;
            background: #ff4d4d;
            color: white;
            font-size: 11px;
            padding: 2px 6px;
            border-radius: 50%;
            font-weight: 600;
        }

        .profile-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: #1b9e52;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 8px 20px rgba(27,158,82,0.4);
        }

        .nav-search {
            position: relative;
        }

            .nav-search input {
                width: 240px;
                padding: 8px 14px 8px 34px;
                border-radius: 25px;
                border: 1px solid #e0e0e0;
                background: url('/images/search-icon.png') no-repeat 10px center;
                background-size: 14px;
                font-size: 14px;
            }

        #searchResults {
            position: absolute;
            top: 38px;
            width: 100%;
            background: white;
            border-radius: 12px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.12);
            z-index: 999;
        }

        .search-item {
            display: flex;
            gap: 10px;
            padding: 10px;
            align-items: center;
            cursor: pointer;
            text-decoration: none;
            color: #1b4332;
        }

            .search-item:hover {
                background: #f4f7f5;
            }

            .search-item img {
                width: 40px;
                height: 40px;
                border-radius: 8px;
                object-fit: cover;
            }

        main {
            padding: 40px;
        }

    </style>
</head>

<body>

    <div class="page-wrapper">

        <!-- NAVBAR -->
        <div class="public-navbar">

            <a asp-controller="Home" asp-action="Index">
                <img src="~/images/hero/Nutribitelogo.png" class="logo-img" />
            </a>

            <div class="nav-center">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="Location" asp-action="Index">Location</a>
                <a asp-controller="Home" asp-action="About">About</a>
            </div>

            <div class="nav-actions">

                @if (userId == null)
                {
                    <a class="vendor-btn" asp-controller="Vendor" asp-action="Register">Join as Vendor</a>
                    <a class="login-btn" asp-controller="Auth" asp-action="Login">Login</a>
                    <a class="signup-btn" asp-controller="Auth" asp-action="Register">Sign Up</a>
                }
                else
                {

                    <div class="nav-search">
                        <input type="text" id="foodSearch" placeholder="Search meals..." autocomplete="off" />
                        <div id="searchResults"></div>
                    </div>

                    <!-- CART ICON -->
                    <a asp-controller="Cart" asp-action="Index" class="cart-icon">

                        🛒

                        <span id="cartCount" class="cart-count">
                            00
                        </span>

                    </a>

                    <div class="dropdown">
                        <div class="profile-avatar dropdown-toggle" data-bs-toggle="dropdown">
                            @userName?.Substring(0, 1).ToUpper()
                        </div>

                        <ul class="dropdown-menu dropdown-menu-end">

                            <li>
                                <a class="dropdown-item" asp-controller="Home" asp-action="MyProfile">
                                    My Profile
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-controller="HealthSurvey" asp-action="Index">
                                    Health Survey
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-controller="CalorieTracker" asp-action="Index">
                                    Calorie Tracking
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-controller="Home" asp-action="MyOrders">
                                    My Orders
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">
                                    Logout
                                </a>
                            </li>

                        </ul>
                    </div>

                }

            </div>
        </div>

        <main>
            @RenderBody()
        </main>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

    <script>

        const searchInput=document.getElementById("foodSearch");
        const resultsBox=document.getElementById("searchResults");

        if(searchInput){

        searchInput.addEventListener("keyup",function(){

        const query=this.value;

        if(query.length<2){
        resultsBox.innerHTML="";
        return;
        }

        fetch(`/Meals/Search?q=${query}`)
        .then(res=>res.json())
        .then(data=>{

        let html="";

        data.forEach(food=>{

        html+=`
        <a href="/Meals/Results?q=${encodeURIComponent(food.name)}" class="search-item">

        <img src="${food.image}" />

        <div>
        <strong>${food.name}</strong>
        <br>
        <small>${food.calories} kcal</small>
        </div>

        </a>`;

        });

        resultsBox.innerHTML=html;

        });

        });

        searchInput.addEventListener("keypress",function(e){

        if(e.key==="Enter"){

        window.location.href="/Meals/Results?q="+searchInput.value;

        }

        });

        }

    </script>

    <script>

        function loadCartCount(){

        fetch('/Cart/GetCartCount')
        .then(res=>res.json())
        .then(data=>{

        if(data.success){

        let count=data.count.toString().padStart(2,'0');

        document.getElementById("cartCount").innerText=count;

        }

        });

        }

        loadCartCount();

    </script>

</body>
</html>