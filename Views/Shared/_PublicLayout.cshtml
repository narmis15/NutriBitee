@using Microsoft.AspNetCore.Http
@{
    var userId = Context.Session.GetInt32("UserId");
    var userName = Context.Session.GetString("UserName");

    // current route for conditional Back button (do not show on Home/Index and Public/Index)
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    // Show Bulk nav on all pages
    bool isLanding = string.Equals(currentController, "Public", System.StringComparison.OrdinalIgnoreCase)
                     && string.Equals(currentAction, "Index", System.StringComparison.OrdinalIgnoreCase);
    bool showBulkNav = true;
    bool showBackButton = !(string.Equals(currentController, "Home", System.StringComparison.OrdinalIgnoreCase)
                            && string.Equals(currentAction, "Index", System.StringComparison.OrdinalIgnoreCase))
                          && !(string.Equals(currentController, "Public", System.StringComparison.OrdinalIgnoreCase)
                            && string.Equals(currentAction, "Index", System.StringComparison.OrdinalIgnoreCase));

    bool isFullWidthPage = isLanding 
                           || (string.Equals(currentController, "Home", System.StringComparison.OrdinalIgnoreCase) && string.Equals(currentAction, "Index", System.StringComparison.OrdinalIgnoreCase))
                           || string.Equals(currentController, "Bulk", System.StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - NutriBite</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

    @RenderSection("Styles", required: false)

    <style>
        :root {
            --brand-green: #2d6a4f;
            --brand-green-hover: #1b4332;
            --brand-light: #f0fdf4;
            --text-dark: #1f2937;
            --text-muted: #6b7280;
            --glass-bg: rgba(255, 255, 255, 0.85);
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: #fdfdfd;
            margin: 0;
            color: var(--text-dark);
            -webkit-font-smoothing: antialiased;
        }

        .main-container {
            width: 100%;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .content-container {
            width: 92%;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* NAVBAR - Enhanced Glassmorphism */
        .public-navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 5%;
            background: rgba(255, 255, 255, 0.65); /* More transparent to absorb background */
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border-bottom: 1px solid rgba(45, 106, 79, 0.12);
            position: sticky;
            top: 0;
            z-index: 1050;
            transition: all 0.3s ease;
        }

        .logo-img {
            height: 48px;
            transition: transform 0.3s ease;
        }
        .logo-img:hover {
            transform: scale(1.02);
        }

        .nav-center {
            display: flex;
            gap: 40px;
            align-items: center;
        }

        .nav-center a {
            text-decoration: none;
            font-weight: 500;
            font-size: 1.05rem;
            color: var(--text-muted);
            transition: all 0.3s ease;
            position: relative;
        }

        .nav-center a:hover {
            color: var(--brand-green);
        }

        .nav-center a.active {
            color: var(--text-dark);
            font-weight: 600;
        }

        .nav-center a.active::after {
            content: '';
            position: absolute;
            bottom: -6px;
            left: 50%;
            transform: translateX(-50%);
            width: 20px;
            height: 3px;
            background-color: var(--brand-green);
            border-radius: 3px;
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .btn-rounded {
            padding: 10px 24px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.95rem;
            text-decoration: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .vendor-btn {
            background: transparent;
            color: var(--text-dark);
            border: 1.5px solid #e5e7eb;
        }
        .vendor-btn:hover {
            border-color: var(--brand-green);
            color: var(--brand-green);
        }

        .login-btn {
            background: transparent;
            color: var(--brand-green);
            border: 1.5px solid var(--brand-green);
        }
        .login-btn:hover {
            background: var(--brand-light);
        }

        .signup-btn {
            background: var(--brand-green);
            color: white;
            box-shadow: 0 4px 12px rgba(45, 106, 79, 0.2);
            border: 1.5px solid var(--brand-green);
        }
        .signup-btn:hover {
            background: var(--brand-green-hover);
            color: white;
            box-shadow: 0 6px 16px rgba(45, 106, 79, 0.3);
            transform: translateY(-1px);
        }

        .nav-search {
            position: relative;
        }

        .nav-search input {
            width: 280px;
            padding: 10px 20px;
            border-radius: 50px;
            border: 1px solid #e5e7eb;
            background: #f9fafb;
            font-size: 0.95rem;
            transition: all 0.3s ease;
        }

        .nav-search input:focus {
            outline: none;
            background: #fff;
            border-color: var(--brand-green);
            box-shadow: 0 0 0 4px var(--brand-light);
        }

        #searchResults {
            position: absolute;
            top: 48px;
            width: 100%;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            z-index: 1060;
            overflow: hidden;
            border: 1px solid #f3f4f6;
        }

        .search-item {
            display: flex;
            gap: 12px;
            padding: 12px 16px;
            align-items: center;
            cursor: pointer;
            text-decoration: none;
            color: var(--text-dark);
            border-bottom: 1px solid #f9fafb;
        }

        .search-item:hover {
            background: #f9fafb;
        }

        .search-item img {
            width: 48px;
            height: 48px;
            border-radius: 8px;
            object-fit: cover;
        }

        .cart-icon {
            font-size: 1.25rem;
            position: relative;
            text-decoration: none;
            color: var(--text-dark);
            background: #f3f4f6;
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: all 0.3s ease;
        }

        .cart-icon:hover {
            background: #e5e7eb;
            color: var(--brand-green);
        }

        .cart-count {
            position: absolute;
            top: -4px;
            right: -6px;
            background: #ef4444;
            color: white;
            font-size: 0.7rem;
            padding: 2px 6px;
            border-radius: 50px;
            font-weight: 700;
            border: 2px solid white;
        }

        .profile-avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--brand-green), #40916c);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 1.1rem;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(45,106,79,0.3);
            transition: all 0.3s ease;
        }

        .profile-avatar:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(45,106,79,0.4);
        }

        #locationDisplay {
            max-width: 200px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            background: transparent;
            color: var(--text-muted);
            padding: 8px;
            font-weight: 500;
            font-size: 0.95rem;
            cursor: pointer;
            transition: color 0.3s ease;
        }
        #locationDisplay:hover {
            color: var(--brand-green);
        }

        /* DROPDOWN UI */
        .dropdown-menu {
            border-radius: 16px;
            border: 1px solid rgba(0,0,0,0.05);
            padding: 12px 0;
            min-width: 220px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.08);
            animation: dropdownFade 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            margin-top: 10px;
        }

        @@keyframes dropdownFade {
            from { opacity: 0; transform: translateY(-10px) scale(0.98); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .dropdown-item {
            padding: 10px 20px;
            font-size: 0.95rem;
            font-weight: 500;
            color: var(--text-dark);
            transition: all 0.2s ease;
        }

        .dropdown-item:hover {
            background: var(--brand-light);
            color: var(--brand-green);
            padding-left: 24px;
        }

        .dropdown-divider {
            margin: 8px 0;
            border-color: #f3f4f6;
        }

        .dropdown-item.text-danger {
            color: #ef4444 !important;
            font-weight: 600;
        }

        .dropdown-item.text-danger:hover {
            background: #fef2f2;
            color: #dc2626 !important;
        }

        /* Global Back Button */
        .global-back-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: #fff;
            color: var(--text-muted);
            border: 1px solid #e5e7eb;
            font-size: 1.2rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s ease;
            margin-bottom: 24px;
        }
        .global-back-btn:hover {
            background: #f9fafb;
            color: var(--text-dark);
            transform: translateX(-2px);
        }
        
        .back-wrapper {
            display: flex;
            justify-content: flex-start;
            padding-top: 30px;
        }

        main {
            padding: 0;
            margin: 0;
            width: 100%;
        }

        /* RESPONSIVE NAVBAR */
        @@media (max-width: 1024px) {
            .nav-center { display: none; }
            .mobile-menu-btn { display: flex !important; }
            .nav-search input { width: 200px; }
        }

        .mobile-menu-btn {
            display: none;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 8px;
            background: #f3f4f6;
            color: var(--text-dark);
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
        }

        .mobile-nav-offcanvas {
            position: fixed;
            top: 0;
            left: -100%;
            width: 280px;
            height: 100vh;
            background: #fff;
            z-index: 2000;
            transition: all 0.3s ease;
            box-shadow: 15px 0 40px rgba(0,0,0,0.1);
            padding: 30px 20px;
        }

        .mobile-nav-offcanvas.active {
            left: 0;
        }

        .mobile-nav-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 1999;
            display: none;
        }

        .mobile-nav-overlay.active {
            display: block;
        }

        .mobile-nav-links {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .mobile-nav-links a {
            text-decoration: none;
            font-size: 1.1rem;
            font-weight: 500;
            color: var(--text-dark);
            padding: 10px 15px;
            border-radius: 10px;
            transition: all 0.2s ease;
        }

        .mobile-nav-links a:hover, .mobile-nav-links a.active {
            background: var(--brand-light);
            color: var(--brand-green);
        }

        @@media (max-width: 768px) {
            .public-navbar { padding: 12px 5%; }
            .logo-img { height: 40px; }
            #locationDisplay { display: none; }
            .vendor-btn { display: none; }
            .nav-search input { width: 150px; font-size: 0.85rem; }
            .btn-rounded { padding: 8px 16px; font-size: 0.85rem; }
        }

        @@media (max-width: 480px) {
            .nav-search { display: none; }
            .public-navbar { padding: 12px 4%; }
        }
    </style>
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        window.nativeAlert = window.alert;
        window.alert = function (message) {
            if (!message) return;
            
            let iconHtml = 'info';
            let titleHtml = 'Notification';
            
            if (message.includes("WARNING:")) {
                iconHtml = 'error';
                titleHtml = 'Warning!';
            } else if (message.toLowerCase().includes("failed") || message.toLowerCase().includes("error")) {
                iconHtml = 'error';
                titleHtml = 'Oops...';
            } else if (message.toLowerCase().includes("success") || message.toLowerCase().includes("added to cart")) {
                iconHtml = 'success';
                titleHtml = 'Success!';
            }

            Swal.fire({
                icon: iconHtml,
                title: titleHtml,
                text: message.replace("WARNING: ", ""),
                confirmButtonColor: '#16a34a',
                confirmButtonText: 'Okay'
            });
        };
    </script>
</head>

<body>

    <div class="main-container">

        <!-- MOBILE NAV -->
        <div class="mobile-nav-overlay" id="mobileOverlay" onclick="toggleMobileNav()"></div>
        <div class="mobile-nav-offcanvas" id="mobileNav">
            <div class="d-flex justify-content-between align-items-center mb-5">
                <img src="~/images/hero/Nutribitelogo.png" height="40" />
                <button class="btn-close" onclick="toggleMobileNav()"></button>
            </div>
            <div class="mobile-nav-links">
                @if (userId == null)
                {
                    <a asp-controller="Public" asp-action="Index" class="@(currentController == "Public" && currentAction == "Index" ? "active" : "")">Home</a>
                }
                else
                {
                    <a asp-controller="Home" asp-action="Index" class="@(currentController == "Home" && currentAction == "Index" ? "active" : "")">Home</a>
                }
                <a asp-controller="Home" asp-action="About" class="@(currentController == "Home" && currentAction == "About" ? "active" : "")">About</a>

                
                @if (showBulkNav)
                {
                    <a asp-controller="Bulk" asp-action="Index" class="@(currentController == "Bulk" ? "active" : "")">Bulk Ordering</a>
                }

                <hr />
                @if (userId == null)
                {
                    <a asp-controller="Auth" asp-action="Login">Login</a>
                    <a asp-controller="Auth" asp-action="Register">Sign Up</a>
                    <a asp-controller="Vendor" asp-action="Register">Join as Vendor</a>
                }
                else
                {
                    <a asp-controller="Home" asp-action="MyProfile">My Profile</a>
                    <a asp-controller="Cart" asp-action="Index">My Cart</a>
                    <a asp-controller="Auth" asp-action="Logout" class="text-danger">Logout</a>
                }
            </div>
        </div>

        <!-- NAVBAR -->
        <div class="public-navbar">

            <div style="display:flex;align-items:center;gap:15px;">

                @if (userId == null)
                {
                    <a asp-controller="Public" asp-action="Index">
                        <img src="~/images/hero/Nutribitelogo.png" class="logo-img" />
                    </a>
                }
                else
                {
                    <a asp-controller="Home" asp-action="Index">
                        <img src="~/images/hero/Nutribitelogo.png" class="logo-img" />
                    </a>
                }

                @if (userId != null)
                {
                    <div id="locationDisplay"
                         style="font-weight:600;cursor:pointer;background:#eef7f2;padding:6px 12px;border-radius:20px;"
                         data-bs-toggle="modal"
                         data-bs-target="#locationModal">

                        📍 Detecting location...

                    </div>
                }

            </div>

            <div class="nav-center">
                @if (userId == null)
                {
                    <a asp-controller="Public" asp-action="Index" class="nav-link @(currentController == "Public" && currentAction == "Index" ? "active" : "")">Home</a>
                }
                else
                {
                    <a asp-controller="Home" asp-action="Index" class="nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")">Home</a>
                }
                <a asp-controller="Home" asp-action="About" class="nav-link @(currentController == "Home" && currentAction == "About" ? "active" : "")">About</a>


                @* Bulk nav link: appear on Home and Bulk pages, not on the public landing page. Uses Tag Helpers. *@
                @if (showBulkNav)
                {
                    <a asp-controller="Bulk" asp-action="Index" class="nav-link @(currentController == "Bulk" ? "active" : "")" id="navBulk">Bulk</a>
                }
            </div>

            <div class="nav-actions">
                <button class="mobile-menu-btn" onclick="toggleMobileNav()">
                    <i class="bi bi-list"></i>
                </button>


                

                @if (userId == null)
                {
                    <a class="btn-rounded vendor-btn" asp-controller="Vendor" asp-action="Register">Join as Vendor</a>
                    <a class="btn-rounded login-btn" asp-controller="Auth" asp-action="Login">Login</a>
                    <a class="btn-rounded signup-btn" asp-controller="Auth" asp-action="Register">Sign Up</a>
                }
                else
                {

                    <div class="nav-search">
                        <input type="text" id="foodSearch" placeholder="Search meals..." autocomplete="off" />
                        <div id="searchResults"></div>
                    </div>

                    <!-- CART ICON -->
                    <a asp-controller="Cart" asp-action="Index" class="cart-icon">

                        🛒

                        <span id="cartCount" class="cart-count">
                            00
                        </span>

                    </a>

                    <div class="dropdown">
                        <div class="profile-avatar dropdown-toggle" data-bs-toggle="dropdown">
                            @userName?.Substring(0, 1).ToUpper()
                        </div>

                        <ul class="dropdown-menu dropdown-menu-end">

                            <li>
                                <a class="dropdown-item" asp-controller="Home" asp-action="MyProfile">
                                    My Profile
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-controller="HealthSurvey" asp-action="Index">
                                    Health Survey
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-controller="CalorieTracker" asp-action="Index">
                                    Calorie Tracking
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-controller="Home" asp-action="MyOrders">
                                    My Orders
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-controller="Subscription" asp-action="Index">
                                    My Subscriptions
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">
                                    Logout
                                </a>
                            </li>

                        </ul>
                    </div>

               }
              

            </div>
        </div>

        @* Include the Location Selector modal partial *@
        @await Html.PartialAsync("~/Views/Shared/_LocationSelector.cshtml")

        <main class="@(isFullWidthPage ? "" : "content-container")">
            @* Back button (shared) - rendered on most internal pages (not Home or Landing) *@
            @if (showBackButton)
            {
                <div class="back-wrapper content-container" aria-hidden="false">
                    <button type="button" class="global-back-btn" id="globalBackBtn" title="Go back">
                        <i class="bi bi-arrow-left"></i>
                    </button>
                </div>
            }

            @RenderBody()
        </main>

    </div>

    @RenderSection("Scripts", required: false)

    <!-- Ensure Bootstrap 5 JS is available. Try CDN first, fallback to local copy. -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>if(typeof bootstrap === 'undefined'){document.write('<script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"><\/script>')}</script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        function toggleMobileNav() {
            const nav = document.getElementById('mobileNav');
            const overlay = document.getElementById('mobileOverlay');
            nav.classList.toggle('active');
            overlay.classList.toggle('active');
        }
    </script>

    <script>

        const searchInput=document.getElementById("foodSearch");
        const resultsBox=document.getElementById("searchResults");

        if(searchInput){

        searchInput.addEventListener("keyup",function(){

        const query=this.value;

        if(query.length<2){
        resultsBox.innerHTML="";
        return;
        }

        fetch(`/Meals/Search?q=${query}`)
        .then(res=>res.json())
        .then(data=>{

        let html="";

        data.forEach(food=>{

        html+=`
        <a href="/Meals/Results?q=${encodeURIComponent(food.name)}" class="search-item">

        <img src="${food.image}" />

        <div>
        <strong>${food.name}</strong>
        <br>
        <small>${food.calories} kcal</small>
        </div>

        </a>`;

        });

        resultsBox.innerHTML=html;

        });

        });

        searchInput.addEventListener("keypress",function(e){

        if(e.key==="Enter"){

        window.location.href="/Meals/Results?q="+searchInput.value;

        }

        });

        }

    </script>

    <script>

        function updateCartCount(){

            fetch('/Cart/GetCartCount')
            .then(res=>res.json())
            .then(data=>{

                if(data.success){

                    let count=data.count.toString().padStart(2,'0');

                    document.getElementById("cartCount").innerText=count;

                }

            });

        }

        // Alias for compatibility
        window.loadCartCount = updateCartCount;
        window.updateCartCount = updateCartCount;

        updateCartCount();

    </script>

    <script>
        // Global Back button behavior
        (function () {
            const btn = document.getElementById('globalBackBtn');
            if (!btn) return;
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                let ref = document.referrer;
                if (ref && ref.indexOf(window.location.hostname) > -1) { 
                    window.history.back(); 
                } else {
                    window.location.href = '/';
                }
            });
        })();
    </script>

    <script>
        // Navbar active highlighting for Bulk link (applies on any page where the Bulk nav exists)
        (function () {
            try {
                var path = (location.pathname || "").toLowerCase();
                var bulkLink = document.getElementById('navBulk');
                if (!bulkLink) return;
                // Mark active when on any /bulk route
                if (path.startsWith('/bulk')) {
                    bulkLink.classList.add('active');
                }
                // Also mark active when on /bulk/... (meals/snacks/foodbox)
            } catch (e) {
                // silent
            }
        })();
    </script>

    <!-- Scroll Reveal Animation Logic -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const observerOptions = {
                root: null,
                rootMargin: '0px',
                threshold: 0.15
            };

            const observer = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('is-visible');
                        observer.unobserve(entry.target);
                    }
                });
            }, observerOptions);

            document.querySelectorAll('.reveal-up').forEach(el => observer.observe(el));
        });
    </script>

    <!-- Location script (initialize after DOM) -->
    <script src="~/js/location.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.NutriBiteLocation && typeof window.NutriBiteLocation.init === 'function') {
                window.NutriBiteLocation.init({ displayId: 'locationDisplay' });
            }
        });
    </script>
</body>
</html>