@using Microsoft.AspNetCore.Http
@{
    var userId = Context.Session.GetInt32("UserId");
    var userName = Context.Session.GetString("UserName");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - NutriBite</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

    @RenderSection("Styles", required: false)

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #e6f7f0, #c8f1df, #a8e6cf);
            margin: 0;
        }

        /* ===== PAGE WRAPPER (Landing Style Card) ===== */
        .page-wrapper {
            width: 92%;
            max-width: 1300px;
            margin: 50px auto;
            background: #f6fff9;
            border-radius: 25px;
            box-shadow: 0 25px 60px rgba(0,0,0,0.15);
            overflow: hidden;
        }

        /* ===== NAVBAR ===== */
        .public-navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 18px 40px;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .logo-img {
            height: 55px;
        }

        .nav-center {
            display: flex;
            gap: 30px;
        }

            .nav-center a {
                text-decoration: none;
                font-weight: 600;
                color: #1b4332;
                transition: 0.3s;
            }

                .nav-center a:hover {
                    color: #40916c;
                }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 18px;
        }

        /* Cart */
        .cart-icon {
            position: relative;
            text-decoration: none;
            font-size: 22px;
        }

        .cart-badge {
            position: absolute;
            top: -6px;
            right: -10px;
            background: #2d6a4f;
            color: white;
            font-size: 10px;
            padding: 3px 6px;
            border-radius: 50%;
        }

        /* Buttons */
        .login-btn {
            padding: 8px 20px;
            border-radius: 25px;
            background: #2d6a4f;
            color: white;
            text-decoration: none;
            font-weight: 600;
        }

        .signup-btn {
            padding: 8px 20px;
            border-radius: 25px;
            border: 2px solid #2d6a4f;
            color: #2d6a4f;
            text-decoration: none;
            font-weight: 600;
        }

            .signup-btn:hover {
                background: #2d6a4f;
                color: white;
            }

        /* Profile */
        .profile-avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: #2d6a4f;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            cursor: pointer;
        }

        /* ===== FOOTER ===== */
        .nb-footer {
            background: #ffffff;
            padding: 50px 40px;
            border-top: 1px solid rgba(0,0,0,0.05);
        }

        .nb-footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 40px;
        }

        .nb-heading {
            font-weight: 700;
            margin-bottom: 15px;
        }

        .nb-links {
            list-style: none;
            padding: 0;
        }

            .nb-links li {
                margin-bottom: 8px;
            }

            .nb-links a {
                text-decoration: none;
                color: #1b4332;
            }

                .nb-links a:hover {
                    color: #40916c;
                }

        .nb-desc {
            font-size: 14px;
            color: #4a5568;
            line-height: 1.6;
        }

        .nb-logo {
            font-weight: 800;
            font-size: 22px;
            text-decoration: none;
            color: #1b4332;
        }
    </style>
</head>

<body>

    <div class="page-wrapper">

        <!-- NAVBAR -->
        <div class="public-navbar">

            <div>
                <a asp-controller="Users" asp-action="Index">
                    <img src="~/images/hero/Nutribitelogo.png"
                         class="logo-img"
                         alt="NutriBite Logo" />
                </a>
            </div>

            <div class="nav-center">
                <a asp-controller="Users" asp-action="Index">Home</a>
                <a asp-controller="Users" asp-action="Location">Location</a>
                <a asp-controller="Users" asp-action="About">About</a>
                <a asp-controller="Users" asp-action="MyProfile">My Profile</a>
            </div>

            <div class="nav-actions">

                <a asp-controller="Cart" asp-action="Index" class="cart-icon">
                    🛒
                    <span class="cart-badge">0</span>
                </a>

                @if (userId != null)
                {
                    <div class="profile-avatar">
                        @userName?.Substring(0, 1).ToUpper()
                    </div>
                }
                else
                {
                    <a class="login-btn" href="/Auth/Login">Login</a>
                    <a class="signup-btn" href="/Auth/Register">Sign Up</a>
                }

            </div>

        </div>

        <!-- MAIN CONTENT -->
        <main>
            @RenderBody()
        </main>

        <!-- FOOTER -->
        <footer class="nb-footer">
            <div class="nb-footer-grid">

                <div>
                    <a class="nb-logo" href="/">NutriBite</a>
                    <p class="nb-desc">
                        Smart nutrition technology helping you eat better every day.
                    </p>
                </div>

                <div>
                    <h4 class="nb-heading">Company</h4>
                    <ul class="nb-links">
                        <li><a href="/Users/About">About</a></li>
                        <li><a href="#">Careers</a></li>
                    </ul>
                </div>

                <div>
                    <h4 class="nb-heading">Information</h4>
                    <ul class="nb-links">
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Terms</a></li>
                    </ul>
                </div>

                <div>
                    <h4 class="nb-heading">Contact</h4>
                    <p class="nb-desc">help@nutribite.com</p>
                </div>

            </div>
        </footer>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>