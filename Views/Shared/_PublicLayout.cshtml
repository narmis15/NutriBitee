@using Microsoft.AspNetCore.Http
@{
    var userId = Context.Session.GetInt32("UserId");
    var userName = Context.Session.GetString("UserName");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - NutriBite</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/students.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/elderly.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/corporate.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/students.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/elderly.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/corporate.css" asp-append-version="true" />

    @RenderSection("HeadExtras", required: false)
    @RenderSection("Styles", required: false)

    <link rel="preconnect" href="https://your-cdn.example.com" crossorigin />
    <link rel="preload" href="~/images/hero/hero-food.png" as="image" />
    <link rel="preload" href="~/images/hero/slide 1.png" as="image" />
    <link rel="preload" href="~/images/hero/slide 2.png" as="image" />

    <style>
        /* ============================= */
        /* PROFESSIONAL FIXED NAVBAR */
        /* ============================= */

        .navbar {
            height: 72px;
            padding: 0;
            background: #ffffff !important;
            border-bottom: 1px solid #e8f0e9;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            position: fixed;
            width: 100%;
            left: 0;
            top: 0;
            z-index: 1000;
            transition: box-shadow 0.3s ease;
        }

        main {
            margin-top: 72px;
        }

        .navbar.scrolled {
            box-shadow: 0 6px 22px rgba(0,0,0,0.1);
        }

        /* ============================= */
        /* BRAND */
        /* ============================= */

        .navbar-brand {
            font-size: 22px;
            font-weight: 800;
            color: #1b5e20 !important;
            letter-spacing: -0.5px;
            text-decoration: none;
        }

            .navbar-brand span {
                color: #43a047;
            }

        /* ============================= */
        /* NAV LINKS */
        /* ============================= */

        .navbar-nav .nav-link {
            font-size: 14px;
            font-weight: 500;
            color: #4a5568 !important;
            padding: 6px 14px !important;
            border-radius: 8px;
            transition: all 0.2s;
        }

            .navbar-nav .nav-link:hover {
                background: #f0f4f1;
                color: #1b5e20 !important;
            }

            .navbar-nav .nav-link.active {
                color: #1b5e20 !important;
                font-weight: 600;
            }

        /* ============================= */
        /* PREMIUM EXPANDING SEARCH */
        /* ============================= */

        /* ===== RIGHT SIDE SEARCH POSITION ===== */

        .nav-search-wrapper {
            display: flex;
            align-items: center;
            margin-right: 15px;
        }

        

            

        .premium-search {
            position: relative;
            display: flex;
            align-items: center;
            width: 240px;
            transition: all 0.4s cubic-bezier(.4,0,.2,1);
            background: #f5f8f6;
            border-radius: 50px;
            overflow: hidden;
            border: 1px solid #e0e8e2;
        }

            .premium-search input {
                border: none;
                outline: none;
                background: transparent;
                padding: 10px 18px;
                width: 100%;
                font-size: 14px;
                color: #374151;
            }

                .premium-search input::placeholder {
                    color: #9ca3af;
                }

            .premium-search button {
                border: none;
                background: linear-gradient(135deg, #1b5e20, #43a047);
                color: white;
                padding: 8px 18px;
                border-radius: 50px;
                cursor: pointer;
                transition: 0.3s ease;
            }

                .premium-search button:hover {
                    transform: scale(1.05);
                }

            /* EXPAND ON HOVER OR FOCUS */
            .premium-search:hover,
            .premium-search:focus-within {
                width: 420px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.12);
            }

        /* ============================= */
        /* JOIN BUTTON */
        /* ============================= */

        .btn-join {
            background: none;
            border: 1.5px solid #1b5e20;
            color: #1b5e20 !important;
            font-size: 13px;
            font-weight: 600;
            padding: 7px 18px;
            border-radius: 20px;
            text-decoration: none;
            transition: all 0.2s;
        }

            .btn-join:hover {
                background: #1b5e20;
                color: white !important;
            }

        /* ============================= */
        /* CART */
        /* ============================= */

        .cart-icon {
            font-size: 20px;
            text-decoration: none;
            padding: 6px 10px;
            border-radius: 8px;
            transition: background 0.2s;
        }

            .cart-icon:hover {
                background: #f0f4f1;
            }

        /* ============================= */
        /* PROFILE */
        /* ============================= */

        .profile-btn {
            background: none;
            border: none;
            padding: 0;
            cursor: pointer;
        }

        /* NAVBAR PROFILE AVATAR (SMALL) */
        .navbar .profile-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, #1b5e20, #43a047);
            color: white;
            font-size: 14px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .profile-avatar:hover {
                box-shadow: 0 0 0 3px #c8e6c9;
            }

        /* ============================= */
        /* DROPDOWN */
        /* ============================= */

        .premium-dropdown {
            border: 1px solid #e8f0e9;
            border-radius: 12px;
            padding: 8px;
            min-width: 200px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.1) !important;
        }

            .premium-dropdown .dropdown-item {
                border-radius: 8px;
                font-size: 14px;
                font-weight: 500;
                padding: 9px 14px;
                color: #2d3748;
                transition: background 0.2s;
            }

                .premium-dropdown .dropdown-item:hover {
                    background: #f0f4f1;
                    color: #1b5e20;
                }

                .premium-dropdown .dropdown-item.text-danger:hover {
                    background: #fff5f5;
                    color: #e53e3e !important;
                }

        /* ============================= */
        /* LOGIN & SIGNUP */
        /* ============================= */

        .btn-login {
            background: none;
            border: 1.5px solid #e2e8f0;
            color: #4a5568;
            font-size: 13px;
            font-weight: 600;
            padding: 7px 18px;
            border-radius: 8px;
            text-decoration: none;
            transition: all 0.2s;
        }

            .btn-login:hover {
                border-color: #1b5e20;
                color: #1b5e20;
            }

        .btn-signup {
            background: #1b5e20;
            color: white !important;
            font-size: 13px;
            font-weight: 600;
            padding: 7px 18px;
            border-radius: 8px;
            text-decoration: none;
            border: none;
            transition: all 0.2s;
        }

            .btn-signup:hover {
                background: #2e7d32;
                transform: translateY(-1px);
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg">
            <div class="container-fluid px-4">

                <!-- Logo -> goes to Users/Index (user home) -->
                <a class="navbar-brand d-flex align-items-center" asp-controller="Users" asp-action="Index">
                    Nutri<span>Bite</span>
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#publicNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="publicNav">

                    <!-- Left Links: use Users controller routes -->
                    <ul class="navbar-nav me-auto align-items-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Users" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Users" asp-action="About">About</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Users" asp-action="Location">Location</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Users" asp-action="MyProfile">My Profile</a>
                        </li>
                    </ul>

                    <!-- Right side (search / auth) remain unchanged -->
                    @if (userId != null)
                    {
                        <div class="nav-search-wrapper d-none d-lg-flex">
                            <form class="premium-search" asp-controller="Home" asp-action="Search" method="get">
                                <input type="text" name="query" placeholder="Search healthy meals..." />
                                <button type="submit">🔍</button>
                            </form>
                        </div>
                    }

                    <div class="d-flex align-items-center gap-3">
                        <a class="btn-join" asp-controller="Vendor" asp-action="Register">Join Us</a>

                        @if (userId != null)
                        {
                            <a asp-controller="Cart" asp-action="Index" class="cart-icon">🛒</a>

                            <div class="dropdown">
                                <button class="profile-btn" type="button" data-bs-toggle="dropdown">
                                    <div class="profile-avatar">@userName?.Substring(0,1).ToUpper()</div>
                                </button>

                                <ul class="dropdown-menu dropdown-menu-end premium-dropdown shadow">
                                    <li>
                                        <!-- Make sure this points to Users/MyProfile (not admin) -->
                                        <a class="dropdown-item" asp-controller="Users" asp-action="MyProfile" id="navMyProfile">
                                            👤 My Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Users" asp-action="MyOrders">📦 My Orders</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Users" asp-action="Settings">⚙ Settings</a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>

                                    <li>
                                        <a class="dropdown-item text-danger" href="/Auth/Logout">🚪 Logout</a>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn-login" href="/Auth/Login">Login</a>
                            <a class="btn-signup" href="/Auth/Register">Sign Up</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="page-container">
        <main role="main">
            <div class="container-fluid px-0">
                @RenderBody()
            </div>
        </main>

        <footer class="nb-footer">
            <div class="container">
                <div class="nb-footer-grid">
                    <div class="nb-col nb-col-1">
                        <a class="nb-logo" href="/">NutriBite</a>
                        <p class="nb-desc">We at NutriBite use smart nutrition technology to help you eat better every day.
Our calorie-focused meals are thoughtfully crafted to match your health goals—without compromising on taste or flexibility.</p>
                        <div class="nb-social">
                            <a href="#" class="nb-social-link" aria-label="Facebook">f</a>
                            <a href="#" class="nb-social-link" aria-label="Instagram">i</a>
                            <a href="#" class="nb-social-link" aria-label="YouTube">y</a>
                            <a href="#" class="nb-social-link" aria-label="LinkedIn">in</a>
                        </div>
                    </div>

                    <div class="nb-col">
                        <h4 class="nb-heading">Company</h4>
                        <ul class="nb-links">
                            <li><a href="/Home/About">About Us</a></li>
                            <li><a href="/Home/WhyUs">Why Us</a></li>
                            <li><a href="/Home/Careers">Careers</a></li>
                            <li><a href="/Home/Contact">Contact Us</a></li>
                        </ul>
                    </div>

                    <div class="nb-col">
                        <h4 class="nb-heading">Information</h4>
                        <ul class="nb-links">
                            <li><a href="/Home/Privacy">Privacy Policy</a></li>
                            <li><a href="/Home/Terms">Terms &amp; Conditions</a></li>
                            <li><a href="/Home/Refund">Cancellation &amp; Refunds</a></li>
                            <li><a href="/Home/Blog">Blogs</a></li>
                        </ul>
                    </div>

                    <div class="nb-col">
                        <h4 class="nb-heading">Contact us</h4>
                        <p class="nb-contact"><a href="tel:9026775653">Phone: 9026775653</a></p>
                        <p class="nb-contact"><a href="mailto:help@nutribite.com">Email: help@nutribite.com</a></p>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await Html.PartialAsync("_AuthModal")

    @RenderSection("Scripts", required: false)
</body>
</html>