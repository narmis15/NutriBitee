@using Microsoft.AspNetCore.Http
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    // Orders active state
    var ordersActions = new[] { "OrderManagement", "OrderDetails", "CancelledOrders", "Subscriptions" };
    var ordersOpen = currentController == "Admin" && ordersActions.Contains(currentAction);

    // Vendor active state
    var vendorActions = new[] { "NewVendorRequest", "ManageVendor", "Payouts" };
    var vendorOpen = currentController == "Admin" && vendorActions.Contains(currentAction);

    // Food active state
    var foodActions = new[] { "AddFoodCategory", "ViewCategory", "ViewMealCategory", "PendingFoods" };
    var foodOpen = currentController == "Admin" && foodActions.Contains(currentAction);

    // Reports active state
    var reportsActions = new[] { "Dashboard", "OrderReports", "SalesAnalytics", "VendorPerformance", "LocationAnalytics", "PaymentReports", "SystemLogs" };
    var reportsOpen = currentController == "Reports" && reportsActions.Contains(currentAction);

    // Users active state
    var usersActions = new[] { "Index", "BlockedUsers", "Users", "UserDetails" };
    var usersOpen = (currentController == "Users" || currentController == "Admin") && usersActions.Contains(currentAction);

    // Delivery active state
    var deliveryActions = new[] { "DeliveryDashboard", "DeliveryOptimization" };
    var deliveryOpen = currentController == "Admin" && deliveryActions.Contains(currentAction);
}

<div class="sidebar">
    <a asp-controller="Admin" asp-action="Dashboard" class="@(currentController == "Admin" && currentAction == "Dashboard" ? "active" : "")">
        <i class="bi bi-grid-1x2-fill"></i>
        <span class="menu-text">Admin Home</span>
    </a>

    <!-- Orders -->
    <div class="menu-item has-submenu @(ordersOpen ? "open" : "")">
        <div class="menu-link">
            <i class="bi bi-cart-fill"></i>
            <span class="menu-text">Orders</span>
            <i class="bi bi-chevron-down menu-arrow"></i>
        </div>
        <div class="submenu">
            <a asp-controller="Admin" asp-action="OrderManagement" class="@(currentController == "Admin" && (currentAction == "OrderManagement" || currentAction == "OrderDetails") ? "active" : "")">Management</a>
            <a asp-controller="Admin" asp-action="CancelledOrders" class="@(currentController == "Admin" && currentAction == "CancelledOrders" ? "active" : "")">Cancelled</a>
            <a asp-controller="Admin" asp-action="Subscriptions" class="@(currentController == "Admin" && currentAction == "Subscriptions" ? "active" : "")">Subscriptions</a>
        </div>
    </div>

    <!-- Vendors -->
    <div class="menu-item has-submenu @(vendorOpen ? "open" : "")">
        <div class="menu-link">
            <i class="bi bi-shop"></i>
            <span class="menu-text">Vendors</span>
            <i class="bi bi-chevron-down menu-arrow"></i>
        </div>
        <div class="submenu">
            <a asp-controller="Admin" asp-action="NewVendorRequest" class="@(currentController == "Admin" && currentAction == "NewVendorRequest" ? "active" : "")">New Requests</a>
            <a asp-controller="Admin" asp-action="ManageVendor" class="@(currentController == "Admin" && currentAction == "ManageVendor" ? "active" : "")">Manage All</a>
            <a asp-controller="Admin" asp-action="Payouts" class="@(currentController == "Admin" && currentAction == "Payouts" ? "active" : "")">Payouts</a>
            <a asp-controller="Admin" asp-action="Reviews" class="@(currentController == "Admin" && currentAction == "Reviews" ? "active" : "")">Reviews</a>
        </div>
    </div>

    <!-- Food Category -->
    <div class="menu-item has-submenu @(foodOpen ? "open" : "")">
        <div class="menu-link">
            <i class="bi bi-tags-fill"></i>
            <span class="menu-text">Inventory</span>
            <i class="bi bi-chevron-down menu-arrow"></i>
        </div>
        <div class="submenu">
            <a asp-controller="Admin" asp-action="PendingFoods" class="@(currentController == "Admin" && currentAction == "PendingFoods" ? "active" : "")">Pending Approvals</a>
            <a asp-controller="Admin" asp-action="AddFoodCategory" class="@(currentController == "Admin" && currentAction == "AddFoodCategory" ? "active" : "")">Add Category</a>
            <a asp-controller="Admin" asp-action="ViewMealCategory" class="@(currentController == "Admin" && (currentAction == "ViewMealCategory" || currentAction == "EditMealCategory") ? "active" : "")">Meal Categories</a>
        </div>
    </div>

    <!-- Reports -->
    <div class="menu-item has-submenu @(reportsOpen ? "open" : "")">
        <div class="menu-link">
            <i class="bi bi-bar-chart-line-fill"></i>
            <span class="menu-text">Reports</span>
            <i class="bi bi-chevron-down menu-arrow"></i>
        </div>
        <div class="submenu">
            <a asp-controller="Reports" asp-action="SalesAnalytics" class="@(currentController == "Reports" && currentAction == "SalesAnalytics" ? "active" : "")">Sales Analytics</a>
            <a asp-controller="Reports" asp-action="PaymentReports" class="@(currentController == "Reports" && currentAction == "PaymentReports" ? "active" : "")">Payment History</a>
            <a asp-controller="Reports" asp-action="SystemLogs" class="@(currentController == "Reports" && currentAction == "SystemLogs" ? "active" : "")">System Logs</a>
        </div>
    </div>

    <!-- Users -->
    <div class="menu-item has-submenu @(usersOpen ? "open" : "")">
        <div class="menu-link">
            <i class="bi bi-people-fill"></i>
            <span class="menu-text">Customers</span>
            <i class="bi bi-chevron-down menu-arrow"></i>
        </div>
        <div class="submenu">
            <a asp-controller="Admin" asp-action="Users" class="@(currentController == "Admin" && (currentAction == "Users" || currentAction == "UserDetails") ? "active" : "")">Directory</a>
            <a asp-controller="Users" asp-action="BlockedUsers" class="@(currentController == "Users" && currentAction == "BlockedUsers" ? "active" : "")">Blocked</a>
        </div>
    </div>

    <!-- Delivery -->
    <div class="menu-item has-submenu @(deliveryOpen ? "open" : "")">
        <div class="menu-link">
            <i class="bi bi-truck"></i>
            <span class="menu-text">Delivery</span>
            <i class="bi bi-chevron-down menu-arrow"></i>
        </div>
        <div class="submenu">
            <a asp-controller="Admin" asp-action="DeliveryDashboard" class="@(currentController == "Admin" && currentAction == "DeliveryDashboard" ? "active" : "")">Status & Reports</a>
        </div>
    </div>

    <div style="margin-top: auto; border-top: 1px solid #1e293b; padding-top: 1rem;">
        <a asp-controller="Admin" asp-action="Logout" class="text-danger">
            <i class="bi bi-box-arrow-right"></i>
            <span class="menu-text">Logout</span>
        </a>
    </div>
</div>

<script>
    // Submenu Toggle logic
    document.querySelectorAll('.menu-link').forEach(item => {
        item.addEventListener('click', function () {
            const parent = this.parentElement;
            const isOpen = parent.classList.contains('open');
            
            // Close other open menus
            document.querySelectorAll('.menu-item.has-submenu').forEach(other => {
                if (other !== parent) other.classList.remove('open');
            });

            parent.classList.toggle('open');
        });
    });
</script>
