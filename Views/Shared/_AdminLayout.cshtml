<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - NUTRIBITE Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)

    <style>
        /* Global Back Button used in admin layout (matches public style) */
        .global-back-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 8px 14px;
            border-radius: 10px;
            background: #2d6a4f;
            color: #fff;
            border: none;
            font-weight: 600;
            box-shadow: 0 8px 20px rgba(45,106,79,0.18);
            cursor: pointer;
            text-decoration: none;
            transition: transform .08s ease, box-shadow .12s ease;
        }
        .global-back-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(45,106,79,0.22); }
        .global-back-btn .icon { width:18px; height:18px; display:inline-flex; align-items:center; justify-content:center; font-size:14px; }
        .back-wrapper { padding: 18px 24px; }
    </style>
</head>

