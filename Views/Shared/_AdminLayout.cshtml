<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - NUTRIBITE Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    <!-- Toastify for notifications -->
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">

    @RenderSection("Styles", required: false)

    <style>
        /* Global Back Button (Small Circle Arrow Design) */
        .global-back-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #fff;
            color: #6c757d;
            border: 1px solid #dee2e6;
            font-size: 1.1rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s ease;
            line-height: 1;
        }
        .global-back-btn i {
            margin: 0;
            padding: 0;
            line-height: 1;
        }
        .global-back-btn:hover {
            background: #f8f9fa;
            color: #212529;
            border-color: #adb5bd;
            transform: scale(1.05);
        }
        .back-wrapper { padding: 18px 24px; }
    </style>
</head>

<body>

<div class="admin-wrapper">

    <!-- SIDEBAR -->
    @await Html.PartialAsync("_AdminSidebar")

    <!-- CONTENT -->
    <div class="content">
        <div class="topbar"></div>

        @* Back button for admin pages (always show — admin pages are internal) *@
        <div class="back-wrapper">
            <button type="button" class="global-back-btn" id="globalBackBtnAdmin" title="Go back">
                <i class="bi bi-arrow-left"></i>
            </button>
        </div>

        @RenderBody()
    </div>
</div>

<script>
    (function () {
        var b = document.getElementById('globalBackBtnAdmin');
        if (!b) return;
        b.addEventListener('click', function (e) {
            e.preventDefault();
            if (window.history.length > 1) { window.history.back(); return; }
            window.location.href = '/Admin/Dashboard';
        });
    })();
</script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Global utility for notifications
        window.notify = {
            success: function(msg) {
                Toastify({
                    text: msg,
                    duration: 3000,
                    gravity: "top",
                    position: "right",
                    style: { background: "#22c55e" }
                }).showToast();
            },
            error: function(msg) {
                Toastify({
                    text: msg,
                    duration: 5000,
                    gravity: "top",
                    position: "right",
                    style: { background: "#ef4444" }
                }).showToast();
            },
            info: function(msg) {
                Toastify({
                    text: msg,
                    duration: 3000,
                    gravity: "top",
                    position: "right",
                    style: { background: "#3b82f6" }
                }).showToast();
            }
        };

        // Show TempData messages if any
        @if (TempData["Success"] != null) { <text>notify.success("@TempData["Success"]");</text> }
        @if (TempData["Error"] != null) { <text>notify.error("@TempData["Error"]");</text> }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>