<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - NUTRIBITE Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>

<body>

<div class="admin-wrapper">

    <!-- SIDEBAR -->
    <div class="sidebar">
            <button class="toggle-btn" onclick="toggleSidebar()">☰</button>

        <a asp-controller="Admin" asp-action="Dashboard">Admin Home</a>

        <!-- Orders -->
        <div class="menu-item">
            <div class="menu-link">
                <span class="menu-text">Orders</span>
                <span class="menu-arrow">&#9662;</span>
            </div>
            <div class="submenu">
                <a asp-controller="Admin" asp-action="OrderManagement">Order Management</a>
                <a asp-controller="Admin" asp-action="OrderDetails">Order Details</a>
                <a asp-controller="Admin" asp-action="FlaggedOrders">Flagged Orders</a>
                <a asp-controller="Admin" asp-action="PickupSlots">Pickup Slots</a>
                <a asp-controller="Admin" asp-action="CancelledOrders">Cancelled Orders</a>
            </div>
        </div>

        <!-- Vendors -->
        <div class="menu-item">
            <div class="menu-link">
                <span class="menu-text">Manage Vendors</span>
                <span class="menu-arrow">&#9662;</span>
            </div>
            <div class="submenu">
                <a asp-controller="Admin" asp-action="NewVendorRequest">New Vendor Requests</a>
                <a asp-controller="Admin" asp-action="ManageVendor">Manage Vendors</a>
            </div>
        </div>

        <!-- Food Category -->
        <div class="menu-item">
            <div class="menu-link">
                <span class="menu-text">Food Category</span>
                <span class="menu-arrow">&#9662;</span>
            </div>
            <div class="submenu">
                <a asp-controller="Admin" asp-action="AddFoodCategory">Add Category</a>
                <a asp-controller="Admin" asp-action="ViewCategory">View Category</a>
                <a asp-controller="Admin" asp-action="ViewMealCategory">View Meal Category</a>
            </div>
        </div>

        <!-- Coupons -->
        <div class="menu-item">
            <div class="menu-link">
                <span>Coupons</span>
                <span class="menu-arrow">&#9662;</span>
            </div>
            <div class="submenu">
                <a asp-controller="Admin" asp-action="AddCoupon">Add Coupon</a>
            </div>
        </div>

        <!-- Reports -->
        <div class="menu-item">
            <div class="menu-link">
                <span>Reports & Analytics</span>
                <span class="menu-arrow">&#9662;</span>
            </div>
            <div class="submenu">
                <a asp-controller="Reports" asp-action="Dashboard">Dashboard</a>
                <a asp-controller="Reports" asp-action="OrderReports">Order Reports</a>
                <a asp-controller="Reports" asp-action="SalesAnalytics">Sales Analytics</a>
            </div>
        </div>

        <!-- Users -->
        <div class="menu-item">
            <div class="menu-link">
                <span>Users & Customers</span>
                <span class="menu-arrow">&#9662;</span>
            </div>
            <div class="submenu">
                <a asp-controller="Users" asp-action="Index">All Users</a>
                <a asp-controller="Users" asp-action="BlockedUsers">Blocked Users</a>
            </div>
        </div>

        <a asp-controller="Admin" asp-action="Logout">Logout</a>
    </div>

    <!-- CONTENT -->
    <div class="content">
        <div class="topbar"></div>

        @RenderBody()
    </div>

</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

<script>
    document.querySelectorAll('.menu-link').forEach(item => {
        item.addEventListener('click', function () {
            this.parentElement.classList.toggle('open');
        });
    });

    function toggleSidebar(){
        document.querySelector('.sidebar').classList.toggle('collapsed');
    }
</script>

@RenderSection("Scripts", required: false)

</body>
</html>