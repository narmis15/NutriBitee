@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "NutriBite";
}

@section Styles {
    <link rel="stylesheet" href="~/css/land.css" />
}

<!-- HERO SECTION -->
<div class="hero-section">

    <div class="hero-top">

        <div class="hero-left">
            <div class="eyebrow">Eat Fresh, Live Healthy</div>

            <h1>Track Calories On Your Plate</h1>

            <p>
                Discover calorie-based meal selection and nutrition insights tailored to your goals.
                Choose meals by calorie, protein, fats and carbs and get them picked up or delivered fresh.
            </p>

            <a class="cta-btn" asp-controller="Auth" asp-action="Login">
                Explore Meals
            </a>
        </div>

        <div class="hero-right">
            <div class="food-circle">
                <img src="~/images/bowl1.jpeg" alt="Healthy Food" />
            </div>
        </div>

    </div>

    <!-- FEATURES -->
    <div class="features">
        <div class="feature-card">
            <h4>🔥 Smart Calorie Tracking</h4>
            <p>Track protein, carbs and fats instantly.</p>
        </div>

        <div class="feature-card">
            <h4>🥗 Healthy Meal Options</h4>
            <p>Curated meals based on your fitness goals.</p>
        </div>

        <div class="feature-card">
            <h4>🚚 Fast Delivery</h4>
            <p>Fresh meals delivered to your doorstep.</p>
        </div>
    </div>

</div>
<!-- ===============================
       NUTRIBITE INFO SECTION
================================= -->

<section class="nutribite-info">

    <div class="container">

        <div class="row">

            <!-- LEFT SIDE -->

            <div class="col-md-4">

                <div class="brand-block">

                    <img src="~/images/hero/Nutribitelogo.png"
                         class="footer-logo" />

                    <p>
                        NutriBite connects people with healthy homemade meals prepared by trusted home chefs, making nutritious and calorie-counted food
                    </p>

                </div>

            </div>


            <!-- COMPANY -->

            <div class="col-md-3">

                <h5>Company</h5>

                <ul class="footer-links">

                    <li>
                        <a asp-controller="Home" asp-action="About">
                            About Us
                        </a>
                    </li>

                    <li>
                        <a href="#">
                            Why NutriBite
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Vendor" asp-action="Register">
                            Join as Vendor
                        </a>
                    </li>

                    <li>
                        <a href="#">
                            Careers
                        </a>
                    </li>

                </ul>

            </div>


            <!-- INFORMATION -->

            <div class="col-md-3">

                <h5>Information</h5>

                <ul class="footer-links">

                    <li>
                        <a href="#">Privacy Policy</a>
                    </li>

                    <li>
                        <a href="#">Terms & Conditions</a>
                    </li>

                    <li>
                        <a href="#">Cancellation & Refunds</a>
                    </li>

                </ul>

            </div>


            <!-- CONTACT -->

            <div class="col-md-2">

                <h5>Contact Us</h5>

                <p class="contact-item">
                    <span class="icon">📞</span>
                    <span>+91 9876543210</span>
                </p>

                <p class="contact-item">
                    <span class="icon">✉</span>
                    <span>support@nutribite.com</span>
                </p>

            </div>

        </div>

    </div>

</section>