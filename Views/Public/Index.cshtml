@{
    Layout = null;
    ViewData["Title"] = "NutriBite";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/land.css" />
</head>
<body>

    <div class="page-wrapper">

        <!-- NAVBAR -->
        <div class="public-navbar">
            <div class="brand">
                <a href="/">
                    <img src="~/images/hero/Nutribitelogo.png"
                         class="logo-img"
                         alt="NutriBite Logo" />
                </a>
            </div>

            <div class="nav-actions">
                <a class="vendor-btn" href="/Vendor/Register">Join as Vendor</a>
                <a class="login-btn" href="/Account/Login">Login</a>
                <a class="signup-btn" href="/Account/Register">Sign Up</a>
            </div>
        </div>

        <!-- HERO SECTION -->
        <div class="hero-section">

            <!-- TOP PART -->
            <div class="hero-top">

                <div class="hero-left">
                    <div class="eyebrow">Eat Fresh, Live Healthy</div>

                    <h1>Track Calories On Your Plate</h1>

                    <p>
                        Discover calorie-based meal selection and nutrition insights tailored to your goals.
                        Choose meals by calorie, protein, fats and carbs and get them picked up or delivered fresh.
                    </p>

                    <a class="cta-btn" href="/Account/Login">Explore Meals</a>
                </div>

                <div class="hero-right">
                    <div class="food-circle">
                        <img src="~/images/bowl1.jpeg" alt="Healthy Food" />
                    </div>
                </div>

            </div>

            <!-- FEATURE CARDS (INSIDE WHITE FORM) -->
            <div class="features">
                <div class="feature-card">
                    <h4>🔥 Smart Calorie Tracking</h4>
                    <p>Track protein, carbs and fats instantly.</p>
                </div>

                <div class="feature-card">
                    <h4>🥗 Healthy Meal Options</h4>
                    <p>Curated meals based on your fitness goals.</p>
                </div>

                <div class="feature-card">
                    <h4>🚚 Fast Delivery</h4>
                    <p>Fresh meals delivered to your doorstep.</p>
                </div>
            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>