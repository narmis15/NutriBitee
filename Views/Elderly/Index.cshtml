@model List<NUTRIBITE.Models.Food>

@{
    ViewData["Title"] = "NutriBite — Elderly";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<link rel="stylesheet" href="~/css/elderly.css" />

<section class="elderly-hero container my-4" role="region" aria-label="Elderly hero">
    <div class="hero-card">
        <div class="hero-left">
            <h1>Healthy Meals for Happy Seniors</h1>
            <p class="lead">Gentle on the stomach, rich in nutrition.</p>
            <a class="btn explore-combos" href="#elderlyMeals">Explore Combos</a>
        </div>
        <div class="hero-right" aria-hidden="true">
            <img src="~/images/categories/elderly.jpeg" alt="Elderly meals" loading="lazy" />
        </div>
    </div>
</section>

@* Filter bar removed as requested *@

@section Styles {
    <style>
        .verification-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: #e6f9f0;
            color: #2d6a4f;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-bottom: 10px;
            border: 1px solid #c2f0d5;
        }

        .nutrition-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 8px;
            margin: 12px 0;
            padding: 10px;
            background: #f8f9fa;
            border-radius: 8px;
            font-size: 0.8rem;
        }

        .nutrition-item {
            display: flex;
            justify-content: space-between;
            color: #666;
        }

        .nutrition-item strong {
            color: #333;
        }

        .nutritionist-info {
            font-size: 0.7rem;
            color: #888;
            font-style: italic;
            margin-top: 5px;
        }
    </style>
}

<!-- Elderly Specials Menu -->
<section id="elderlyMeals" class="container my-5" aria-labelledby="elderlyHeading">
    <h2 id="elderlyHeading">Elderly Specials – Sukoon Meals</h2>

    <div class="combos-grid" role="list">
        @if (Model != null && Model.Any())
        {
            foreach (var food in Model)
            {
                <article class="combo-card" role="listitem"
                         data-calories="@food.Calories"
                         data-price="@food.Price"
                         data-veg="true">
                    
                    @if (food.IsVerified)
                    {
                        <div class="verification-badge">
                            <i class="bi bi-patch-check-fill"></i> Verified by Nutritionist
                        </div>
                    }

                    <div class="combo-badge">@food.Calories kcal</div>
                    <!-- LEFT SIDE (TEXT CONTENT) -->
                    <div class="combo-content">
                        <h3 class="combo-title">@food.Name</h3>

                        <div class="combo-price">₹<strong>@food.Price</strong></div>
                        
                        @if (food.Nutritionist != null)
                        {
                            <div class="nutritionist-info">
                                Certified by @food.Nutritionist.Name (@food.Nutritionist.Qualification)
                            </div>
                        }

                        <button class="btn btn-success add-to-cart-btn" data-id="@food.Id">
                            <i class="bi bi-cart-plus"></i> Add to Cart
                        </button>
                    </div>

                    <!-- RIGHT SIDE (IMAGE) -->
                    <div class="combo-image">
                        <img src="@(string.IsNullOrEmpty(food.ImagePath) ? "/images/menu items/default.png" : food.ImagePath)"
                             alt="@food.Name"
                             loading="lazy" />
                    </div>
                </article>
            }
        }
        else
        {
            <div class="alert alert-info w-100">No elderly special meals found in the database. Please run SeedData.</div>
        }
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const highProtein = document.getElementById("highProtein");
            const under500 = document.getElementById("under500");
            const vegOnly = document.getElementById("vegOnly");
            const resetBtn = document.getElementById("resetFilters");
            const comboCards = document.querySelectorAll(".combo-card");

            function applyFilters() {
                comboCards.forEach(card => {
                    const price = parseInt(card.dataset.price);
                    const calories = parseInt(card.dataset.calories);
                    const isVeg = card.dataset.veg === "true";

                    let visible = true;

                    if (highProtein.checked && calories < 600) visible = false;
                    if (under500.checked && calories >= 500) visible = false;
                    if (vegOnly.checked && !isVeg) visible = false;

                    card.style.display = visible ? "flex" : "none";
                });
            }

            if(highProtein) highProtein.addEventListener("change", applyFilters);
            if(under500) under500.addEventListener("change", applyFilters);
            if(vegOnly) vegOnly.addEventListener("change", applyFilters);

            if(resetBtn) {
                resetBtn.addEventListener("click", () => {
                    highProtein.checked = false;
                    under500.checked = false;
                    vegOnly.checked = false;
                    applyFilters();
                });
            }
        });
    </script>
}
