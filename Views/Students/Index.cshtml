@model List<NUTRIBITE.Models.Food>

@{
    ViewData["Title"] = "NutriBite — Students";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<link rel="stylesheet" href="~/css/students.css" />

<section class="students-hero container my-4" role="region" aria-label="Students hero">
    <div class="hero-card">
        <div class="hero-left">
            <h1>Fuel Your Hustle, Student!</h1>
            <p class="lead">Affordable, high-protein, and brain-boosting meals for your busy life.</p>
            <a class="btn explore-combos" href="#studentMeals">Explore Student Specials</a>
        </div>
        <div class="hero-right" aria-hidden="true">
            <img src="~/images/categories/student.jpeg" alt="Student meals" loading="lazy" />
        </div>
    </div>
</section>

@section Styles {
    <style>
        .verification-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: #e6f9f0;
            color: #2d6a4f;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-bottom: 10px;
            border: 1px solid #c2f0d5;
        }

        .nutritionist-info {
            font-size: 0.7rem;
            color: #888;
            font-style: italic;
            margin-top: 5px;
        }
    </style>
}

<!-- All Student Meals Combined -->
<section id="studentMeals" class="container my-5" aria-labelledby="studentMealsHeading">
    <h2 id="studentMealsHeading">Student Specials Menu</h2>

    <div class="combos-grid" role="list">
        @if (Model != null && Model.Any())
        {
            foreach (var food in Model)
            {
                <article class="combo-card" role="listitem"
                         data-calories="@food.Calories"
                         data-price="@food.Price"
                         data-veg="true">
                    
                    @if (food.IsVerified)
                    {
                        <div class="verification-badge">
                            <i class="bi bi-patch-check-fill"></i> Verified by Nutritionist
                        </div>
                    }

                    <div class="combo-badge">@food.Calories kcal</div>
                    <!-- LEFT SIDE (TEXT CONTENT) -->
                    <div class="combo-content">
                        <h3 class="combo-title">@food.Name</h3>

                        <div class="combo-price">₹<strong>@food.Price</strong></div>
                        
                        @if (food.Nutritionist != null)
                        {
                            <div class="nutritionist-info">
                                Certified Expert: @food.Nutritionist.Name
                            </div>
                        }

                        <button class="btn btn-success add-to-cart-btn" data-id="@food.Id">
                            <i class="bi bi-cart-plus"></i> Add to Cart
                        </button>
                    </div>

                    <!-- RIGHT SIDE (IMAGE) -->
                    <div class="combo-image">
                        <img src="@(string.IsNullOrEmpty(food.ImagePath) ? "/images/menu items/default.png" : food.ImagePath)"
                             alt="@food.Name"
                             loading="lazy" />
                    </div>
                </article>
            }
        }
        else
        {
            <div class="alert alert-info w-100">No student special meals found in the database. Please run SeedData.</div>
        }
    </div>
</section>

