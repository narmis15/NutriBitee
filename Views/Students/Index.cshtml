@{
    ViewData["Title"] = "NutriBite — Students";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<link rel="stylesheet" href="~/css/students.css" />

<section class="students-hero container my-4" role="region" aria-label="Students hero">
    <div class="hero-card">
        <div class="hero-left">
            <h1>Smart Meals for Smart Students</h1>
            <p class="lead">Fuel your brain without emptying your wallet.</p>
            <a class="btn explore-combos" href="#featuredCombos">Explore Combos</a>
        </div>
        <div class="hero-right" aria-hidden="true">
            <img src="~/images/categories/student.jpeg" alt="Students meals" loading="lazy" />
        </div>
    </div>
</section>

<!-- Sticky filter bar -->
<section class="filter-bar-wrap" aria-label="Student filters">
    <div class="filter-bar container" role="region" aria-label="Filters" id="studentsFilterBar">
        <div class="filter-item">
            <label for="priceRange">Budget: <span id="priceValue">₹75</span></label>
            <input id="priceRange" type="range" min="50" max="150" value="100" />
        </div>

        <div class="filter-item toggle-item">
            <label><input id="highProtein" type="checkbox" /> High Protein</label>
        </div>

        <div class="filter-item toggle-item">
            <label><input id="under500" type="checkbox" /> Under 500 kcal</label>
        </div>

        <div class="filter-item toggle-item">
            <label><input id="vegOnly" type="checkbox" /> Veg Only</label>
        </div>

        <div class="filter-item">
            <button id="resetFilters" class="btn reset-btn">Reset</button>
        </div>
    </div>
</section>

