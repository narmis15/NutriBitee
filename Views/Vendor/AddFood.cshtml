@{
    ViewData["Title"] = "Add Food";
    Layout = "~/Views/Shared/_VendorLayout.cshtml";
}

<div class="vendor-card">
    <div class="form-header">
        <h2>Add New Food Item</h2>
        <p>Fill in the details to list a new homemade meal.</p>
    </div>

    <form method="post"
          asp-action="AddFood"
          enctype="multipart/form-data"
          class="add-food-form">

        <div class="row g-4">

            <!-- LEFT SIDE -->
            <div class="col-lg-7">

                <div class="form-group">
                    <label>Name</label>
                    <input name="Name" type="text" class="form-control" required />
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <textarea name="Description"
                              class="form-control"
                              rows="4"
                              required></textarea>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Price (₹)</label>
                            <input name="Price"
                                   type="number"
                                   step="0.01"
                                   class="form-control"
                                   required />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Category</label>
                            <select name="CategoryId" class="form-control" required>

                                <option value="">Select Category</option>

                                @foreach (var category in ViewBag.Categories)
                                {
                                    <option value="@category.Cid">
                                        @category.MealCategory
                                    </option>
                                }

                            </select>

                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Audience Type (FoodType)</label>
                            <select name="FoodType" class="form-control">
                                <option value="">General</option>
                                <option value="Student">Student</option>
                                <option value="Elderly">Elderly</option>
                                <option value="Corporate">Corporate</option>
                            </select>
                        </div>
                    </div>

                </div>

                <div class="row g-3 mt-1">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Calories</label>
                            <input name="Calories"
                                   type="number"
                                   class="form-control"
                                   required />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Preparation Time</label>
                            <input name="PreparationTime"
                                   type="text"
                                   class="form-control"
                                   required />
                        </div>
                    </div>
                </div>

            </div>

            <!-- RIGHT SIDE -->
            <div class="col-lg-5">

                <div class="image-upload-card">
                    <label>Upload Food Image</label>
                    <input type="file"
                           name="ImageFile"
                           id="ImageFile"
                           class="form-control"
                           accept="image/*" />
                </div>

                <div class="preview-card mt-4">
                    <h6>Preview</h6>

                    <div style="background:#f8f8f8;
                padding:15px;
                border-radius:16px;
                text-align:center;">

                        <img id="imagePreview"
                             style="width:100%;
                    max-height:450px;
                    object-fit:contain;
                    border-radius:12px;
                    display:none;" />

                    </div>
                </div>

            </div>

        </div>

        <div class="form-actions mt-4">
            <button type="submit" class="btn-vendor-primary">
                Save Food Item
            </button>
        </div>

    </form>
</div>

<script>
    const imageInput = document.getElementById("ImageFile");
    const preview = document.getElementById("imagePreview");

    imageInput.addEventListener("change", function () {
        const file = this.files[0];

        if (file) {
            const reader = new FileReader();

            reader.onload = function (e) {
                preview.src = e.target.result;
                preview.style.display = "block";
            };

            reader.readAsDataURL(file);
        }
    });
</script>