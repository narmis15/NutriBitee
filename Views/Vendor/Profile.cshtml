@{
    ViewData["Title"] = "Vendor Profile";
    Layout = "~/Views/Shared/_VendorLayout.cshtml";
}

<div class="row g-4">

    <!-- LEFT PROFILE SUMMARY -->
    <div class="col-md-4">
        <div class="vendor-card profile-summary text-center">
            <div class="profile-avatar">
                V
            </div>
            <h5 class="mt-3 mb-1">Vendor Name</h5>
            <p class="text-muted mb-2">vendor@test.com</p>
            <span class="profile-status">Active</span>
        </div>
    </div>

    <!-- RIGHT EDIT FORM -->
    <div class="col-md-8">
        <div class="vendor-card">
            <h5 class="fw-bold mb-4">Store Information</h5>

            <form>

                <div class="mb-3">
                    <label class="form-label">Store Name</label>
                    <input type="text" class="form-control" placeholder="NutriBite Kitchen">
                </div>

                <div class="mb-3">
                    <label class="form-label">Phone</label>
                    <input type="text" class="form-control" placeholder="+91 9876543210">
                </div>

                <div class="mb-3">
                    <label class="form-label">Address</label>
                    <textarea class="form-control" rows="3" placeholder="Enter your store address"></textarea>
                </div>

                <div class="text-end">
                    <button type="submit" class="btn-vendor-primary">
                        Save Changes
                    </button>
                </div>

            </form>
        </div>
    </div>

</div>