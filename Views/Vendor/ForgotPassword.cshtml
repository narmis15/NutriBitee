@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";

}
@section Styles {
    <link rel="stylesheet" href="~/css/Vendor.css" asp-append-version="true" />
}

<div class="vendor-auth-wrapper">
    <div class="vendor-auth-card">

        <div class="vendor-left">
            <h2>Password Recovery</h2>
            <p>
                Enter your registered email address.
                We will allow you to reset your password.
            </p>
        </div>

        <div class="vendor-right">
            <h3 class="brand">NutriBite</h3>
            <h5 class="mb-3">Forgot Password</h5>

            <form method="post" asp-action="ForgotPassword">

                <div class="mb-3">
                    <label>Email Address</label>
                    <input type="email" name="Email" class="form-control" required />
                </div>

                <button type="submit" class="btn btn-success w-100 mt-2">
                    Continue
                </button>

                <div class="auth-links">
                    <a href="/Vendor/Login">Back to Login</a>
                </div>

            </form>
        </div>

    </div>
</div>
