@model List<NUTRIBITE.Models.Food>

@{
    ViewData["Title"] = "My Foods";
    Layout = "~/Views/Shared/_VendorLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/vendor-myfoods.css" asp-append-version="true" />
}

<div class="page-wrapper">

    <div class="page-header">
        <h2>My Foods</h2>
        <a asp-action="AddFood" class="add-btn">+ Add New Food</a>
    </div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Delete Food?',
                text: `Are you sure you want to remove "${name}"?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/Vendor/DeleteFood/${id}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire('Deleted!', 'Food item has been removed.', 'success')
                            .then(() => location.reload());
                        } else {
                            Swal.fire('Error!', data.message || 'Could not delete item.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}

    <div class="food-grid">

        @if (Model == null || Model.Count == 0)
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-egg-fried text-muted" style="font-size: 3rem;"></i>
                <p class="text-muted mt-3">No food items added yet.</p>
            </div>
        }
        else
        {
            @foreach (var food in Model)
            {
                <div class="food-card">

                    @{
                        // Precise image mapping based on food name keywords
                        string lowerName = food.Name.ToLower();
                        string finalImg = "/images/hero/premium_healthy_bowl.png"; // Default

                        if (lowerName.Contains("dal") || lowerName.Contains("khichdi")) 
                            finalImg = "/images/menu items/Dal khichdi.png";
                        else if (lowerName.Contains("bharta")) 
                            finalImg = "/images/menu items/baigan bharta.png";
                        else if (lowerName.Contains("kofta") || lowerName.Contains("lauki")) 
                            finalImg = "/images/menu items/chaana and lauki dal with phulka.png";
                        else if (lowerName.Contains("chicken") || lowerName.Contains("mughlai")) 
                            finalImg = "/images/Meals/Special_Thali.jpeg";
                        else if (lowerName.Contains("pulao") || lowerName.Contains("rice") || lowerName.Contains("tehri")) 
                            finalImg = "/images/menu items/tawa pulao.png";
                        else if (lowerName.Contains("salad") || lowerName.Contains("sprouts")) 
                            finalImg = "/images/menu items/mixed sprouts.png";
                        else if (lowerName.Contains("oats") || lowerName.Contains("daliya") || lowerName.Contains("smoothie")) 
                            finalImg = "/images/menu items/vegetable daliya.png";
                        else if (lowerName.Contains("paneer")) 
                            finalImg = "/images/menu items/paneer bhurji with 3 phulkas.png";
                        else if (lowerName.Contains("thali"))
                            finalImg = "/images/Meals/Standard_Thali.jpeg";
                        
                        // If vendor has uploaded a specific image, use it
                        if (!string.IsNullOrEmpty(food.ImagePath) && food.ImagePath.Contains("Vendorfooduploads"))
                            finalImg = food.ImagePath;
                    }

                    <img class="food-image"
                         src="@finalImg"
                         onerror="this.onerror=null;this.src='/images/hero/premium_healthy_bowl.png';"
                         alt="Food">

                    <div class="food-body">
                        @if (food.Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark mb-2" style="font-size: 0.75rem;">
                                <i class="bi bi-hourglass-split"></i> Pending Approval
                            </span>
                        }
                        else if (food.Status == "Active")
                        {
                            <span class="badge bg-success-subtle text-success border border-success-subtle mb-2" style="font-size: 0.75rem;">
                                <i class="bi bi-check-circle-fill"></i> Live
                            </span>
                        }
                        else if (food.Status == "Rejected")
                        {
                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle mb-2" style="font-size: 0.75rem;">
                                <i class="bi bi-x-circle-fill"></i> Rejected
                            </span>
                        }

                        <h4 class="mb-1">@food.Name</h4>

                        <div class="food-meta text-success fw-bold">
                            ₹@food.Price <span class="text-muted small fw-normal ms-1">(@food.Calories kcal)</span>
                        </div>



                        @if (!string.IsNullOrEmpty(food.FoodType) && food.FoodType != "NA")
                        {
                            <div class="tag mb-3">
                                <i class="bi bi-tag-fill me-1"></i> @food.FoodType
                            </div>
                        }

                        <div class="d-flex justify-content-end mt-3 border-top pt-3">
                            <button class="btn btn-sm btn-outline-danger" onclick="confirmDelete(@food.Id, '@food.Name.Replace("'", "\\'")')">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </div>
                    </div>

                </div>
            }
        }

    </div>
</div>