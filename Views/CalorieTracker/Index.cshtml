@{
    ViewData["Title"] = "My Calorie Dashboard";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<style>

    /* ===============================
       CALORIE DASHBOARD UI
    ================================ */

    .card {
        border: none;
        border-radius: 16px;
        transition: all .25s ease;
    }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 18px 40px rgba(0,0,0,0.08);
        }

    /* Stat Cards */

    .dashboard-card {
        text-align: center;
        padding: 24px;
        background: white;
    }

        .dashboard-card small {
            font-size: 13px;
            color: #6c757d;
        }

    .dashboard-value {
        font-size: 30px;
        font-weight: 700;
        margin-top: 6px;
    }

    /* Gradient stat cards */

    .stat1 {
        background: linear-gradient(135deg,#e6f9f0,#ffffff);
    }

    .stat2 {
        background: linear-gradient(135deg,#e9f2ff,#ffffff);
    }

    .stat3 {
        background: linear-gradient(135deg,#fff6e5,#ffffff);
    }

    .stat4 {
        background: linear-gradient(135deg,#ffeaea,#ffffff);
    }

    /* Progress bar */

    .progress {
        border-radius: 30px;
        background: #f2f4f6;
        height: 18px;
    }

    .progress-bar {
        border-radius: 30px;
        font-weight: 600;
        transition: width .8s ease;
    }

    /* headings */

    h2 {
        font-weight: 700;
        color: #2c3e50;
    }

    h5 {
        font-weight: 600;
    }

    /* chart card */

    canvas {
        background: white;
        border-radius: 12px;
    }

    /* summary */

    #trendList li {
        padding: 8px 0;
        border-bottom: 1px solid #f1f1f1;
    }

    /* inputs */

    input[type="date"] {
        border-radius: 10px;
        border: 1px solid #e0e0e0;
    }

    /* refresh button */

    #refreshBtn {
        border-radius: 10px;
        padding: 6px 16px;
        font-weight: 600;
    }

    /* progress percentage */

    #progressPercent {
        font-size: 12px;
    }

    /* responsive */

    media(max - width:768px) {
        .dashboard-value

    {
        font-size: 24px;
    }

    .container {
        padding-left: 15px;
        padding-right: 15px;
    }

    }
</style>


<div class="container py-5">

    <div class="d-flex align-items-center justify-content-between mb-4">

        <div>
            <h2 class="mb-1">My Calorie Dashboard</h2>
            <small class="text-muted" id="userLabel">Loading…</small>
        </div>

        <div class="d-flex gap-2 align-items-center">

            <label class="text-muted">From</label>
            <input type="date" id="fromDate" class="form-control form-control-sm" />

            <label class="text-muted ms-3">To</label>
            <input type="date" id="toDate" class="form-control form-control-sm" />

            <button id="refreshBtn" class="btn btn-success btn-sm ms-3">
                Refresh
            </button>

        </div>
    </div>


    <!-- STAT CARDS -->

    <div class="row g-4 mb-4">

        <div class="col-md-3">
            <div class="card shadow-sm dashboard-card stat1">
                <small>🔥 Average / Day</small>
                <div class="dashboard-value text-success" id="avgDaily">— kcal</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm dashboard-card stat2">
                <small>📈 Peak Day</small>
                <div class="dashboard-value text-primary" id="peakDaily">— kcal</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm dashboard-card stat3">
                <small>🎯 Recommended</small>
                <div class="dashboard-value text-warning" id="recommendedDaily">— kcal</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm dashboard-card stat4">
                <small>⚖ Comparison</small>
                <div class="dashboard-value text-danger" id="comparisonPct">— %</div>
            </div>
        </div>

    </div>


    <!-- PROGRESS -->

    <div class="row mb-4">

        <div class="col-md-4">

            <div class="card shadow-sm p-4">

                <h6 class="mb-3">🔥 Today's Progress</h6>

                <div class="progress">
                    <div id="todayProgress" class="progress-bar bg-success" style="width:0%"></div>
                </div>

                <div class="small mt-2 text-muted">
                    <span id="todayCalories">0</span> /
                    <span id="recommendedCalories">0</span> kcal
                </div>

                <div class="text-end text-muted" id="progressPercent"></div>

            </div>

        </div>

    </div>


    <!-- CHART + SUMMARY -->

    <div class="row">

        <div class="col-lg-8">

            <div class="card shadow-sm p-4 mb-3">

                <canvas id="calorieChart" height="220"></canvas>

            </div>

            <div id="alertsContainer"></div>

        </div>


        <div class="col-lg-4">

            <div class="card shadow-sm p-4">

                <h5 class="mb-3">Summary</h5>

                <div id="summaryContent">

                    <p class="text-muted mb-1">
                        Use the date selectors above to filter analytics.
                    </p>

                    <ul class="list-unstyled" id="trendList"></ul>

                </div>

            </div>

        </div>

    </div>

</div>


@section Scripts {

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>

        (function(){

        const $avg=document.getElementById('avgDaily');
        const $peak=document.getElementById('peakDaily');
        const $rec=document.getElementById('recommendedDaily');
        const $cmp=document.getElementById('comparisonPct');
        const $userLabel=document.getElementById('userLabel');
        const $trendList=document.getElementById('trendList');

        const ctx=document.getElementById('calorieChart').getContext('2d');

        let chart=null;

        function toIsoDate(d){
        const tzOff=d.getTimezoneOffset()*60000;
        return new Date(d-tzOff).toISOString().slice(0,10);
        }

        const today=new Date();
        const twoWeeksAgo=new Date();
        twoWeeksAgo.setDate(today.getDate()-13);

        document.getElementById('fromDate').value=toIsoDate(twoWeeksAgo);
        document.getElementById('toDate').value=toIsoDate(today);


        function renderTrendList(trend){

        $trendList.innerHTML='';

        if(!trend||!trend.length)return;

        trend.slice().reverse().forEach(pt=>{

        const li=document.createElement('li');

        li.innerHTML=`<strong>${pt.label}</strong> — ${pt.calories} kcal`;

        $trendList.appendChild(li);

        });

        }


        function fetchData(){

        $.getJSON('/CalorieTracker/GetAnalytics', {
            fromDate: document.getElementById('fromDate').value,
            toDate: document.getElementById('toDate').value
        })

        .done(function(model){

        if(!model)return;

        $userLabel.textContent=model.userName||'';

        $avg.textContent=(model.averageDaily??'—')+' kcal';
        $peak.textContent=(model.peakDaily??'—')+' kcal';

        const recommended=model.recommendedDaily??model.RecommendedDaily??2000;

        $rec.textContent=recommended+" kcal";

        $cmp.textContent=(model.comparisonPercent??'—')+" %";

        const today=model.todayCalories??0;

        document.getElementById("todayCalories").innerText=today;
        document.getElementById("recommendedCalories").innerText=recommended;

        let percent=0;

        if(recommended>0){
        percent=Math.min((today/recommended)*100,100);
        }

        const progressEl = document.getElementById("todayProgress");
        progressEl.style.width=percent+"%";

        const progressPercentEl = document.getElementById("progressPercent");
        if (today >= recommended && recommended > 0) {
            progressPercentEl.innerHTML = '<span class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> Your calorie intake for today is complete!</span>';
            progressEl.classList.remove("bg-success");
            progressEl.classList.add("bg-danger");
        } else {
            progressPercentEl.innerText = percent.toFixed(1)+"% of daily goal";
            progressEl.classList.remove("bg-danger");
            progressEl.classList.add("bg-success");
        }

        renderTrendList(model.trend||[]);

        const labels=model.trend.map(x=>x.label);
        const data=model.trend.map(x=>x.calories);

        if(chart){

        chart.data.labels=labels;
        chart.data.datasets[0].data=data;
        chart.update();

        }else{

        chart=new Chart(ctx,{
        type:'line',
        data:{
        labels:labels,
        datasets:[{
        label:'Calories',
        data:data,
        borderColor:'#16a34a',
        backgroundColor:'rgba(22,163,74,0.08)',
        fill:true,
        tension:0.25
        }]
        },
        options:{
        responsive:true,
        plugins:{legend:{display:false}}
        }
        });

        }

        });

        }

        document.getElementById('refreshBtn').addEventListener('click',fetchData);

        fetchData();

        })();

    </script>

}
