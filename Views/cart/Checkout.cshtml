@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "Checkout — NutriBite";
    var totalAmount = (ViewBag.TotalAmount as decimal?) ?? 0m;
    var totalInvariant = totalAmount.ToString(System.Globalization.CultureInfo.InvariantCulture);
    var totalDisplay = totalAmount.ToString("N2");
}

<div class="container py-4">
    <h2 class="mb-3">Checkout</h2>

    <div class="card p-4 mb-3">
        <h4>Order Summary</h4>
        <div class="d-flex justify-content-between mt-2">
            <div>Items total</div>
            <div>₹@totalDisplay</div>
        </div>
        <hr />
        <div class="d-flex justify-content-between fw-bold">
            <div>Total</div>
            <div>₹@totalDisplay</div>
        </div>
    </div>

    <div class="card p-4 mb-3 shadow-sm border-0">
        <h4 class="mb-3">Delivery Details</h4>
        <div id="deliverySection">
            <div class="card bg-light border-0 p-3 mb-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <label class="form-label fw-bold mb-0 text-dark">
                        <i class="bi bi-map"></i> Delivery Address <span class="text-danger">*</span>
                    </label>
                    <button type="button" id="getLocationBtn" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm">
                        <i class="bi bi-geo-alt-fill"></i> Get Current Location
                    </button>
                </div>
                <textarea id="deliveryAddress" class="form-control mb-3 border-2 shadow-sm" rows="3" 
                          placeholder="Example: Flat 402, Green Valley Apts, Sector 12, Noida..." 
                          style="font-size: 1.1rem;"></textarea>
                
                <label class="form-label fw-bold text-dark mb-2">
                    <i class="bi bi-chat-left-text"></i> Delivery Notes (Optional)
                </label>
                <textarea id="deliveryNotes" class="form-control border-1" rows="2" 
                          placeholder="Example: Near the blue gate, Don't ring the bell, Leave at the door..."></textarea>
                
                <div class="mt-3 text-success fw-bold small">
                    <i class="bi bi-check-circle"></i> Delivery within 5km radius only.
                </div>
            </div>
        </div>
    </div>

    <div class="card p-4 mb-3 shadow-sm border-0">
        <h4 class="mb-3">Payment Method</h4>
        <div class="row g-3">
            <div class="col-md-6">
                <div class="form-check card-glass p-3 border rounded-3 h-100">
                    <input class="form-check-input ms-0" type="radio" name="paymentMethod" id="payOnline" value="Online" checked>
                    <label class="form-check-label ms-4 w-100" for="payOnline">
                        <div class="fw-bold">Pay Online</div>
                        <small class="text-muted">UPI, Cards, Net Banking (via Razorpay)</small>
                    </label>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-check card-glass p-3 border rounded-3 h-100">
                    <input class="form-check-input ms-0" type="radio" name="paymentMethod" id="payCOD" value="COD">
                    <label class="form-check-label ms-4 w-100" for="payCOD">
                        <div class="fw-bold">Cash on Delivery</div>
                        <small class="text-muted">Pay when you receive your meal</small>
                    </label>
                </div>
            </div>
        </div>
    </div>

    <div class="mb-4">
        <button id="payNowBtn" class="btn btn-primary btn-lg px-5 shadow-sm">
            Proceed to Pay ₹@totalDisplay
        </button>
        <a href="@Url.Action("Index", "Cart")" class="btn btn-outline-secondary ms-2">Back to Cart</a>
    </div>

    <div id="paymentAlerts">
        <!-- Alerts injected here -->
    </div>
</div>

@section Scripts {
<script>
(function () {
    const amountMajor = parseFloat('@totalInvariant'); // major units
    const payBtn = document.getElementById('payNowBtn');
    const alertsRoot = document.getElementById('paymentAlerts');

    function updateButtonText() {
        const paymentMethod = document.querySelector('input[name="paymentMethod"]:checked').value;
        if (paymentMethod === 'COD') {
            payBtn.innerText = 'Confirm Order (COD) ₹' + parseFloat('@totalInvariant').toFixed(2);
        } else {
            payBtn.innerText = 'Proceed to Pay ₹' + parseFloat('@totalInvariant').toFixed(2);
        }
    }

    // Toggle Payment Method UI
    document.querySelectorAll('input[name="paymentMethod"]').forEach(radio => {
        radio.addEventListener('change', updateButtonText);
    });

    // Geolocation Handler
    document.getElementById('getLocationBtn').addEventListener('click', function() {
        const btn = this;
        const addressField = document.getElementById('deliveryAddress');
        
        if (!navigator.geolocation) {
            alert('Geolocation is not supported by your browser');
            return;
        }

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Fetching...';

        navigator.geolocation.getCurrentPosition(
            async (position) => {
                const { latitude, longitude } = position.coords;
                try {
                    // Reverse Geocoding using Nominatim (OpenStreetMap)
                    const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${latitude}&lon=${longitude}&addressdetails=1`);
                    const data = await response.json();
                    if (data && data.display_name) {
                        addressField.value = data.display_name;
                        addressField.classList.remove('is-invalid');
                        addressField.classList.add('is-valid');
                    } else {
                        addressField.value = `Latitude: ${latitude}, Longitude: ${longitude}`;
                    }
                } catch (error) {
                    console.error('Reverse geocoding failed:', error);
                    addressField.value = `Latitude: ${latitude}, Longitude: ${longitude}`;
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-geo-alt-fill"></i> Get Current Location';
                }
            },
            (error) => {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-geo-alt"></i> Get Current Location';
                let msg = 'Unable to retrieve your location';
                if (error.code === 1) msg = 'Location access denied. Please enable location permissions.';
                alert(msg);
            }
        );
    });

    function clearAlerts() {
        alertsRoot.innerHTML = '';
    }

    function showAlert(type, html, autoHideMs = 0) {
        clearAlerts();
        const wrapper = document.createElement('div');
        wrapper.className = `alert alert-${type} alert-dismissible fade show`;
        wrapper.setAttribute('role', 'alert');
        wrapper.innerHTML = html + '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>';
        alertsRoot.appendChild(wrapper);

        if (autoHideMs > 0) {
            setTimeout(() => {
                try { bootstrap.Alert.getOrCreateInstance(wrapper).close(); } catch {}
            }, autoHideMs);
        }
    }

    function loadScript(src) {
        return new Promise((resolve, reject) => {
            if (document.querySelector(`script[src="${src}"]`)) return resolve();
            const s = document.createElement('script');
            s.src = src;
            s.onload = () => resolve();
            s.onerror = () => reject(new Error('Failed to load ' + src));
            document.head.appendChild(s);
        });
    }

    async function createRazorpayOrder() {
        const res = await fetch('/Payment/CreateOrder', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({}) // server computes cart total
        });

        if (!res.ok) {
            const payload = await res.json().catch(()=>({}));
            throw new Error(payload?.message || 'Failed to create order');
        }

        return res.json();
    }

    async function verifyPayment(payload, localOrderId) {
        const res = await fetch('/Payment/VerifyPayment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ...payload, localOrderId: localOrderId })
        });

        return res.json();
    }

    async function finalizeOrderOnServer(clearCart = true) {
        const orderType = 'Delivery';
        const paymentMethod = document.querySelector('input[name="paymentMethod"]:checked').value;
        const deliveryAddress = document.getElementById('deliveryAddress').value;
        const deliveryNotes = document.getElementById('deliveryNotes').value;

        if (!deliveryAddress.trim()) {
            document.getElementById('deliveryAddress').classList.add('is-invalid');
            throw new Error('Please enter a delivery address to proceed.');
        } else {
            document.getElementById('deliveryAddress').classList.remove('is-invalid');
        }

        // Create local order and clear cart using existing flow
        const response = await fetch('/Cart/Checkout', {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/x-www-form-urlencoded',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: new URLSearchParams({ 
                pickupSlot: '',
                orderType: orderType,
                deliveryAddress: deliveryAddress,
                deliveryNotes: deliveryNotes,
                paymentMethod: paymentMethod,
                clearCart: clearCart
            }).toString()
        });

        if (!response.ok) {
            throw new Error('Failed to finalize order on server');
        }

        const data = await response.json();
        if (!data.success) {
            throw new Error(data.message || 'Order creation failed');
        }
        return data.orderId;
    }

    async function startPaymentFlow() {
        clearAlerts();
        const paymentMethod = document.querySelector('input[name="paymentMethod"]:checked').value;
        payBtn.disabled = true;
        payBtn.innerText = 'Processing...';

        try {
            if (amountMajor <= 0) {
                showAlert('danger', 'Cart total invalid. Please add items to cart.');
                payBtn.disabled = false;
                updateButtonText();
                return;
            }

            if (paymentMethod === 'COD') {
                // COD Flow: No Razorpay, just finalize order
                await finalizeOrderOnServer();
                showAlert('success', '<strong>Order placed successfully!</strong> Redirecting to success page...', 4000);
                setTimeout(() => { window.location.href = '/Cart/Success'; }, 2000);
                return;
            }

            // Online Payment Flow (Razorpay)
            // 1. Create local order first to get localOrderId, but DON'T clear cart yet
            const localOrderId = await finalizeOrderOnServer(false);

            // 2. Create Razorpay order
            const orderResp = await createRazorpayOrder();

            if (!orderResp || !orderResp.success) {
                throw new Error(orderResp?.message || 'Could not create payment order.');
            }

            await loadScript('https://checkout.razorpay.com/v1/checkout.js');

            // build options
            const options = {
                key: orderResp.keyId,
                amount: orderResp.amount,
                currency: orderResp.currency || 'INR',
                name: 'NutriBite',
                description: 'Food Order Payment',
                order_id: orderResp.orderId,
                handler: async function (response) {
                    try {
                        // verify payment on server
                        const verifyPayload = {
                            razorpay_payment_id: response.razorpay_payment_id,
                            razorpay_order_id: response.razorpay_order_id,
                            razorpay_signature: response.razorpay_signature
                        };

                        const verifyResult = await verifyPayment(verifyPayload, localOrderId);

                        if (!verifyResult || !verifyResult.success) {
                            showAlert('danger',
                                `<strong>Payment verification failed.</strong> ${verifyResult?.message || ''} <div class="mt-2"><button id="retryBtn" class="btn btn-sm btn-warning">Retry Payment</button></div>`
                            );
                            attachRetry();
                            payBtn.disabled = false;
                            updateButtonText();
                            return;
                        }

                        // show success message with brief delay, then redirect to confirmation
                        showAlert('success', `<strong>Payment successful.</strong> Payment ID: <code>${verifyResult.paymentId}</code>. Redirecting to confirmation...`, 4000);

                        setTimeout(() => {
                            window.location.href = '/Cart/Success';
                        }, 2000);
                    } catch (err) {
                        console.error(err);
                        showAlert('danger', `<strong>Processing failed.</strong> ${err.message || ''} <div class="mt-2"><button id="retryBtn" class="btn btn-sm btn-warning">Retry Payment</button></div>`);
                        attachRetry();
                        payBtn.disabled = false;
                        updateButtonText();
                    }
                },
                prefill: {
                    name: '@(User?.Identity?.IsAuthenticated == true ? User.Identity.Name : "")'
                },
                theme: { color: '#2d6a4f' }
            };

            const rzp = new Razorpay(options);

            rzp.on('payment.failed', function (response){
                // show friendly failure with retry option
                showAlert('danger', `<strong>Payment failed.</strong> ${response.error?.description || ''} <div class="mt-2"><button id="retryBtn" class="btn btn-sm btn-warning">Retry Payment</button></div>`);
                attachRetry();
                payBtn.disabled = false;
                updateButtonText();
            });

            rzp.open();
        } catch (err) {
            console.error(err);
            showAlert('danger', `<strong>Error:</strong> ${err.message || 'Unable to initiate payment.'} <div class="mt-2"><button id="retryBtn" class="btn btn-sm btn-warning">Retry Payment</button></div>`);
            attachRetry();
            payBtn.disabled = false;
            updateButtonText();
        }
    }

    function attachRetry() {
        const retry = document.getElementById('retryBtn');
        if (!retry) return;
        retry.addEventListener('click', function () {
            clearAlerts();
            startPaymentFlow();
        });
    }

    // initial button text ensured
    updateButtonText();
    payBtn.addEventListener('click', startPaymentFlow);
})();
</script>
}